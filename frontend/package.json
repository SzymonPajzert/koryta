{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "nuxt typecheck",
    "build": "nuxt build",
    "stop": "npx kill-port --port 8080,9000,9099,5001,8085,3000,5002,4000",
    "emulators": "firebase emulators:start --project demo-koryta-pl --only auth,functions,firestore,database",
    "seed": "npx tsx scripts/seed-emulator.ts",
    "migrate:teryt": "npx tsx scripts/migrate-teryt.ts",
    "dev": "export USE_EMULATORS=true FIRESTORE_EMULATOR_HOST='127.0.0.1:8080' FIREBASE_AUTH_EMULATOR_HOST='127.0.0.1:9099'; nuxt dev --loglevel=verbose",
    "dev:local": "npm run stop; concurrently \"npm run emulators\" \"npm run seed; npm run dev\"",
    "db:pull": "bash scripts/pull-db.sh",
    "emulators:prod-data": "firebase emulators:start --project koryta-pl --import=.firebase/firestore_export --only auth,functions,firestore,database",
    "dev:prod-data": "curl -s -I http://127.0.0.1:3000 >/dev/null 2>&1 && echo 'Server already running on port 3000, skipping restart' || (npm run stop; concurrently \"npm run emulators:prod-data\" \"export USE_PROD_PROJECT=true; npx tsx scripts/seed-emulator.ts --empty; npm run dev\")",
    "dev:build": "npm run stop; concurrently \"npm run emulators\" \"export USE_EMULATORS=true FIRESTORE_EMULATOR_HOST='127.0.0.1:8080' FIREBASE_AUTH_EMULATOR_HOST='127.0.0.1:9099'; nuxt build; npm run seed; nuxt preview\"",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test:ci": "vitest run",
    "test:e2e": "start-server-and-test dev:local http://127.0.0.1:3000 'cypress run'",
    "test:e2e:prod": "start-server-and-test dev:prod-data http://127.0.0.1:3000 'cypress run -s cypress/e2e/prod'",
    "test:e2e:open": "start-server-and-test dev:local http://127.0.0.1:3000 'cypress open'",
    "test:e2e:build": "start-server-and-test dev:build http://127.0.0.1:3000 'cypress run'",
    "backstop:test": "backstop test",
    "backstop:approve": "backstop approve",
    "test:visual": "start-server-and-test dev:build http://localhost:3000 'backstop test'",
    "test:playwright": "start-server-and-test dev:local http://127.0.0.1:3000 'playwright test'",
    "test:playwright:prod": "start-server-and-test dev:prod-data http://127.0.0.1:3000 'playwright test tests/e2e/private_visibility.spec.ts'",
    "test": "npm run test:ci && npm run test:e2e",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:duplication": "jscpd app server --ignore app/coverage",
    "quick-check": "npm run format; npm run format:check && npm run test:ci && npm run typecheck && npx eslint && npm run check:duplication && npm run test:playwright",
    "quick-check:failsafe": "npm run format; npm run format:check; npm run test:ci; npm run typecheck; npx eslint; npm run check:duplication; npm run test:playwright"
  },
  "dependencies": {
    "@firebase/app-types": "^0.9.4",
    "@nuxt/content": "^3.6.3",
    "@nuxt/eslint": "^1.7.1",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^1.15.0",
    "@nuxt/image": "^1.11.0",
    "@nuxt/scripts": "^0.13.2",
    "@nuxtjs/plausible": "^3.0.2",
    "@pinia/nuxt": "^0.11.2",
    "@sentry/nuxt": "^10.48.0",
    "@unhead/vue": "^2.0.13",
    "@vueuse/firebase": "^14.2.1",
    "better-sqlite3": "^12.2.0",
    "cac": "^6.7.14",
    "commander": "^13.1.0",
    "d3-force": "^3.0.0",
    "digraph-js": "==2.2.3",
    "eslint": "^9.32.0",
    "eslint-plugin-cypress": "^5.2.1",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "nuxt": "^4.4.0",
    "nuxt-vuefire": "^1.1.0",
    "sharp": "^0.34.5",
    "string-similarity": "^4.0.4",
    "v-network-graph": "^0.9.21",
    "vue": "^3.5.18",
    "vue-router": "^5.0.6",
    "vue3-apexcharts": "^1.8.0",
    "vuefire": "^3.2.2",
    "vuetify": "^3.12.0",
    "vuetify-nuxt-module": "^0.19.5"
  },
  "devDependencies": {
    "@cypress/vite-dev-server": "^7.1.0",
    "@cypress/vue": "^6.0.2",
    "@nuxt/test-utils": "^3.23.0",
    "@nuxtjs/seo": "^5.1.3",
    "@percy/cli": "^1.30.1",
    "@percy/cypress": "^3.1.2",
    "@plausible-analytics/tracker": "^0.4.4",
    "@playwright/test": "^1.59.1",
    "@simonsmith/cypress-image-snapshot": "^10.0.3",
    "@types/d3-force": "^3.0.10",
    "@types/string-similarity": "^4.0.2",
    "@types/wait-on": "^5.3.4",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "backstopjs": "^6.3.25",
    "concurrently": "^9.2.1",
    "cypress": "^15.13.1",
    "eslint-config-prettier": "^10.1.8",
    "firebase-tools": "^15.14.0",
    "happy-dom": "^20.0.11",
    "jscpd": "^4.0.9",
    "kill-port": "^2.0.1",
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2",
    "prettier": "^3.8.2",
    "start-server-and-test": "^2.1.3",
    "unplugin-auto-import": "^21.0.0",
    "vite-plugin-eslint2": "^5.0.4",
    "vite-plugin-vuetify": "^2.1.2",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "@vercel/nft": "^0.27.4",
    "minimatch": "^10.2.1",
    "serialize-javascript": "^7.0.3",
    "citty": "0.2.1"
  }
}

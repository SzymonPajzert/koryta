zeszow24/articles/image/ff9208a5-a6ff-4739-bc48-228eaa7b4322","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/0ed4c671-18d7-4dd8-a400-5d8ec3377cbd","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/777dd5d9-4ac4-49e4-b183-ba38444eead4","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/3d2b9565-e150-41a6-9825-2676b95ffb9a","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/26335f51-f7ce-449d-8da2-4788d93aac40","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/e832da85-07f0-4cc4-8097-f3e38d5f617b",[88],"MKQyHAlaI0K3yp08Bidg","Na osiedlu Nova Graniczna kończy się budowa nowego obiektu usługowego przy ulicy Granicznej. Dwukondygnacyjny budynek, w którym powstaną m.in. Delikatesy Centrum oraz lokale biurowo-usługowe, jest już w pełni wzniesiony, a obecnie trwają ostatnie prace wykończeniowe i zagospodarowanie terenu wokół inwestycji.","2026-03-10 20:12:16","Jak idzie budowa lokalu handlowo- usługowego przy ulicy Granicznej? [ZDJĘCIA]","jak-idzie-budowa-lokalu-handlowo-uslugowego-przy-ulicy-granicznej-zdjecia",{"comments":24},{"name":838,"config":1709,"type":842,"articles":1710},{"mobile":14,"mobile_full":56,"mobile_intern":56,"type":1024,"query":21,"limit":63,"skip":224},[1711],{"aid":1644,"attachments":1712,"category":1713,"category_id":32,"featured":24,"id":1658,"is_redirect":24,"lead":1659,"locked":24,"origin_domain":11,"parent_domain":56,"parent_id":56,"premium":24,"priority":63,"published":63,"published_at":1660,"recommended":24,"redirect_url":56,"short_title":1661,"slug":1662,"sponsored":21,"sub_title":56,"title":1661,"uid":1658,"updated_at":1660,"stats":1714,"is_photostory":24,"is_advertisement":24,"is_pool":24,"show_quiz_cover":21,"view_type":872},{"id":1646,"name":59,"url":1647,"thumbnail":59,"created_at":1648,"tags":59,"author":934,"type":851,"filename":1649,"description":1650,"750x750px":1651,"160x90px":1652,"365x225px":1653,"100x100px":1654,"760xautopx":1655,"1200x675px":1656},[103],{"comments":24},{"size":32,"module":1716},[1717,1743],{"name":838,"config":1718,"type":842,"articles":1719},{"mobile":14,"mobile_full":56,"mobile_intern":56,"type":1024,"query":21,"limit":63,"skip":116},[1720],{"aid":1721,"attachments":1722,"category":1735,"category_id":62,"featured":24,"id":1736,"is_redirect":24,"lead":1737,"locked":24,"origin_domain":11,"parent_domain":56,"parent_id":56,"premium":24,"priority":63,"published":63,"published_at":1738,"recommended":24,"redirect_url":56,"short_title":1739,"slug":1740,"sponsored":21,"sub_title":56,"title":1739,"uid":1736,"updated_at":1741,"stats":1742,"is_photostory":24,"is_advertisement":24,"is_pool":24,"show_quiz_cover":21,"view_type":872},32255,{"id":1723,"name":59,"url":1724,"thumbnail":59,"created_at":1725,"tags":59,"author":1726,"type":851,"filename":1727,"description":1728,"750x750px":1729,"160x90px":1730,"365x225px":1731,"100x100px":1732,"760xautopx":1733,"1200x675px":1734},58370,"https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/9ac1cc02-a117-4e85-81cf-68d6e58c92fc","2026-03-10 16:01:38","OSP KSRG Zarzecze","9ac1cc02-a117-4e85-81cf-68d6e58c92fc","Pożar samochodu","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/914b9767-05c6-485c-839c-f8ee09af42f3","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/476fc6a7-101f-419e-bce6-0d5c1d84d48c","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/a82cfb40-4e55-4503-8ee8-77ce96197f7b","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/9643a7a4-0e3d-46a2-9cb8-43894f140697","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/42870469-76ec-48b3-89d9-40004261225d","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/f8a0aba0-31eb-4a1a-8d91-2c23fb769061",[88],"W2K1lSmJYJNuGlbc9glZ","Ogień na parkingu w Żurawiczkach w powiecie przeworskim! Dzisiaj przed godziną 13.00 strażacy interweniowali przy pożarze samochodu osobowego. Choć sytuacja wyglądała groźnie, to prawdziwy szok wywołała dopiero przyczyna pojawienia się płomieni. Okazało się, że wystarczyła chwila nieuwagi podczas porządków i niefortunne miejsce postoju, by auto błyskawicznie stanęło w ogniu.","2026-03-10 16:14:55","Zaparkowała w fatalnym miejscu. Chwilę później jej samochód stanął  w ogniu [ZDJĘCIA]","zaparkowala-w-fatalnym-miejscu-chwile-pozniej-jej-samochod-stanal-w-ogniu-zdjecia","2026-03-10 16:29:31",{"comments":24},{"name":838,"config":1744,"type":842,"articles":1746},{"mobile":14,"mobile_full":56,"mobile_intern":56,"type":1024,"query":21,"limit":63,"skip":1745},17,[1747],{"aid":1748,"attachments":1749,"category":1760,"category_id":62,"featured":24,"id":1761,"is_redirect":24,"lead":1762,"locked":24,"origin_domain":11,"parent_domain":56,"parent_id":56,"premium":24,"priority":63,"published":63,"published_at":1763,"recommended":24,"redirect_url":56,"short_title":1764,"slug":1765,"sponsored":21,"sub_title":56,"title":1766,"uid":1761,"updated_at":1763,"stats":1767,"is_photostory":24,"is_advertisement":24,"is_pool":24,"show_quiz_cover":21,"view_type":872},32249,{"id":1750,"name":59,"url":1751,"thumbnail":59,"created_at":1752,"tags":59,"author":890,"type":851,"filename":1753,"description":853,"750x750px":1754,"160x90px":1755,"365x225px":1756,"100x100px":1757,"760xautopx":1758,"1200x675px":1759},58367,"https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/fec979bc-63d7-4a40-8fb7-f6535d8a9e53","2026-03-10 14:13:08","fec979bc-63d7-4a40-8fb7-f6535d8a9e53","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/5a4384dd-c78d-4f05-aebb-7b76841f1a89","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/7bf51395-c6e3-46ff-a877-ad3f133f817c","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/5c38d012-4b53-440d-a082-eb8ee63cff7e","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/d810e7e3-3d36-477a-8226-837df5c036ed","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/cde6f8c4-1375-470e-b134-f1164879548c","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/49470b15-4f8d-41da-9a08-b36ee561ea81",[88],"DIMI47nbjbrOAKsAMgxM","Gdy za zamkniętymi drzwiami jednego z domów w gminie Roźwienica zapadła nienaturalna cisza, tylko czujność sąsiadki zapobiegła tragedii. Mundurowi z Pruchnika i strażacy z OSP Węgierka musieli działać bez wahania – siłowe wejście przez okno było jedyną szansą na dotarcie do półprzytomnej seniorki. W walce z udarem liczyła się każda sekunda, a ta historia to poruszający dowód na to, że zwykła troska o sąsiada potrafi czynić cuda.","2026-03-10 14:13:40","Sama w domu, na podłodze leżała półprzytomna kobieta. Dramatyczna akcja służb –","sama-w-domu-na-podlodze-lezala-polprzytomna-kobieta-dramatyczna-akcja-sluzb-policja-wchodzila-przez-okno","Sama w domu, na podłodze leżała półprzytomna kobieta. Dramatyczna akcja służb – policja wchodziła przez okno",{"comments":24},{"size":32,"module":1769},[1770,1797],{"name":838,"config":1771,"type":842,"articles":1773},{"mobile":14,"mobile_full":56,"mobile_intern":56,"type":1024,"query":21,"limit":63,"skip":1772},18,[1774],{"aid":1775,"attachments":1776,"category":1789,"category_id":62,"featured":24,"id":1790,"is_redirect":24,"lead":1791,"locked":24,"origin_domain":11,"parent_domain":56,"parent_id":56,"premium":24,"priority":63,"published":63,"published_at":1792,"recommended":24,"redirect_url":56,"short_title":1793,"slug":1794,"sponsored":21,"sub_title":56,"title":1795,"uid":1790,"updated_at":1792,"stats":1796,"is_photostory":24,"is_advertisement":24,"is_pool":24,"show_quiz_cover":21,"view_type":872},32246,{"id":1777,"name":59,"url":1778,"thumbnail":59,"created_at":1779,"tags":59,"author":1780,"type":851,"filename":1781,"description":1782,"750x750px":1783,"160x90px":1784,"365x225px":1785,"100x100px":1786,"760xautopx":1787,"1200x675px":1788},58364,"https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/2e0be7c3-17b8-4593-869f-38419237d90e","2026-03-10 13:11:26","Rzeszów Jasionka","2e0be7c3-17b8-4593-869f-38419237d90e","Lotnisko Rzeszów - Jasionka","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/d508f857-b9a3-4e14-b49f-c4248b3877f8","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/7d44534d-3fb2-41fe-a597-3b6c6efc5ff0","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/f62fa7de-bbfd-4781-8e9b-02cf312051cc","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/932d46a5-cc56-47b7-827a-4e02b30a78aa","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/d2a23799-f1a3-45e6-becf-7bc7c02a26da","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/dd01a07c-fb68-4ce3-b29d-21fcb76cfaf4",[88],"mX4pqAfzCkgC8571jQpe","Skandal w Placówce Straży Granicznej w Jasionce znajduje swój finał w sądzie. Prokuratura Okręgowa w Rzeszowie skierowała akt oskarżenia przeciwko byłej już funkcjonariuszce, Edycie H., która bezprawnie wykorzystywała dostęp do systemu PESEL. Śledczy ustalili, że kobieta nieuprawnienie przeglądała dane aż 265 osób, wnikliwie sprawdzając ich adresy zamieszkania i pełne dane osobowe. Choć oskarżona początkowo milczała, teraz chce dobrowolnie poddać się karze, a prokurator domaga się publicznego ujawnienia wyroku.","2026-03-10 13:11:55","Szokujące ustalenia prokuratury w Rzeszowie","szokujace-ustalenia-prokuratury-w-rzeszowie-setki-osob-na-liscie-bylej-strazniczki-z-jasionki-czy-twoje-dane-byly-bezpieczne","Szokujące ustalenia prokuratury w Rzeszowie. Setki osób na „liście” byłej strażniczki z Jasionki! Czy Twoje dane były bezpieczne?",{"comments":24},{"name":35,"config":1798,"type":39},{"slot_id":37,"slot_view":38},{"size":32,"module":1800},[1801],{"name":29,"config":1802,"type":33,"articles":1803},{"type":882,"query":21,"limit":62,"skip":214},[1804,1825,1846,1868,1891],{"aid":1805,"attachments":1806,"category":1818,"category_id":62,"featured":24,"id":1819,"is_redirect":24,"lead":1820,"locked":24,"origin_domain":11,"parent_domain":56,"parent_id":56,"premium":24,"priority":63,"published":63,"published_at":1821,"recommended":24,"redirect_url":56,"short_title":1822,"slug":1823,"sponsored":21,"sub_title":56,"title":1822,"uid":1819,"updated_at":1821,"stats":1824,"is_photostory":24,"is_advertisement":24,"is_pool":24,"show_quiz_cover":21,"view_type":872},32243,{"id":1807,"name":59,"url":1808,"thumbnail":59,"created_at":1809,"tags":59,"author":282,"type":851,"filename":1810,"description":1811,"750x750px":1812,"160x90px":1813,"365x225px":1814,"100x100px":1815,"760xautopx":1816,"1200x675px":1817},58361,"https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/c8fde9d8-e210-452e-a9e0-d193faeace6e","2026-03-10 12:52:02","c8fde9d8-e210-452e-a9e0-d193faeace6e","Stadion miejski w Rzeszowie","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/d91190ff-2c21-48ff-8c15-3c679d9ab1d0","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/3648f61d-fb20-4bbe-8dac-f2302cdf29b4","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/7e4483bd-2022-4a0e-805b-7d1322886201","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/e65822d4-fd96-4d30-9a73-aa4f11778f2a","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/ef5bde38-26f8-400f-a186-9f91c91ef6c8","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/f07806fb-9d04-44e0-9fe5-2c538e07122d",[88],"Vm956uIcMZFqBNDwT4kd","Wychowanek Stali Rzeszów podbija krajowe boiska! Michał Synoś otrzymał oficjalne powołanie do Reprezentacji Polski U19 na nadchodzący turniej kwalifikacyjny do Mistrzostw Europy. To wielkie wyróżnienie dla naszej Akademii i dowód na to, że przy Hetmańskiej 69 rosną talenty na miarę starć z takimi potęgami jak Anglia czy Portugalia.","2026-03-10 12:53:02","Zawodnik Stali Rzeszów powołany do reprezentacji Polski","zawodnik-stali-rzeszow-powolany-do-reprezentacji-polski",{"comments":24},{"aid":1826,"attachments":1827,"category":1838,"category_id":62,"featured":24,"id":1839,"is_redirect":24,"lead":1840,"locked":24,"origin_domain":11,"parent_domain":56,"parent_id":56,"premium":24,"priority":63,"published":63,"published_at":1841,"recommended":24,"redirect_url":56,"short_title":1842,"slug":1843,"sponsored":21,"sub_title":56,"title":1842,"uid":1839,"updated_at":1844,"stats":1845,"is_photostory":24,"is_advertisement":24,"is_pool":24,"show_quiz_cover":21,"view_type":872},32240,{"id":1828,"name":59,"url":1829,"thumbnail":59,"created_at":1830,"tags":59,"author":890,"type":851,"filename":1831,"description":853,"750x750px":1832,"160x90px":1833,"365x225px":1834,"100x100px":1835,"760xautopx":1836,"1200x675px":1837},58358,"https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/00cd86b6-d968-4392-ae4d-41d8217d564c","2026-03-10 12:31:48","00cd86b6-d968-4392-ae4d-41d8217d564c","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/b7ad1d79-fe30-42d8-b1f8-ed1fe3ee8641","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/a74392bb-e5cf-48d0-93ec-253ac4ee3016","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/15cbf653-2165-41b7-ae08-1a5790422380","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/1966439b-5990-44c9-96bf-fd2ab37538c3","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/b7e28106-94f4-4b67-af45-4daa4512f500","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/baf163a5-5f0f-448a-be10-166222a77f9f",[88],"r2HozHOgo9qoJoALug4O","W poniedziałek (9 marca) z młodzieżowego ośrodka wychowawczego w Tyczynie uciekło siedmiu podopiecznych. Policja natychmiast podjęła działania, dzięki którym udało się już odnaleźć pięciu nastolatków. Funkcjonariusze wciąż pracują nad ustaleniem miejsca pobytu pozostałej dwójki. Na ten moment służby nie podają szczegółowych okoliczności zdarzenia.","2026-03-10 12:32:38","Ucieczka z ośrodka wychowawczego pod Rzeszowem. Trwają policyjne poszukiwania","ucieczka-z-osrodka-wychowawczego-pod-rzeszowem-trwaja-policyjne-poszukiwania","2026-03-10 12:33:08",{"comments":24},{"aid":1847,"attachments":1848,"category":1860,"category_id":62,"featured":24,"id":1861,"is_redirect":24,"lead":1862,"locked":24,"origin_domain":11,"parent_domain":56,"parent_id":56,"premium":24,"priority":63,"published":63,"published_at":1863,"recommended":24,"redirect_url":56,"short_title":1864,"slug":1865,"sponsored":21,"sub_title":56,"title":1864,"uid":1861,"updated_at":1866,"stats":1867,"is_photostory":24,"is_advertisement":24,"is_pool":24,"show_quiz_cover":21,"view_type":872},32237,{"id":1849,"name":59,"url":1850,"thumbnail":59,"created_at":1851,"tags":59,"author":1032,"type":851,"filename":1852,"description":1853,"750x750px":1854,"160x90px":1855,"365x225px":1856,"100x100px":1857,"760xautopx":1858,"1200x675px":1859},58355,"https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/537d13c2-45af-4ddd-a2a5-4c24f599b98d","2026-03-10 11:56:53","537d13c2-45af-4ddd-a2a5-4c24f599b98d","Centrum Rzeszowa","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/96014689-2867-40fe-aa3e-ab25de5cd543","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/5e93efe3-a0b2-4f2f-9762-83b7da3c4ccb","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/50c78f29-0a65-4512-b905-2d11510f8321","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/e52eac75-6aca-4d77-9d27-a6cbab464a86","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/269d07d3-9193-4d59-9972-d6bb87bee185","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/2026b795-dbe4-454e-b4dc-3306545ba53e",[88],"RBtDXtslbJRiCY8QyJGA","Bezpieczeństwo na osiedlowych uliczkach staje się tematem numer jeden w stolicy Podkarpacia. Czy rzeszowskie osiedla powinny zamienić się w strefy ograniczenia prędkości do 30 km/h? Radny Mateusz Maciejczyk wychodzi z inicjatywą prosto do mieszkańców i uruchamia specjalną ankietę, w której to rzeszowianie zdecydują o przyszłości swoich dróg","2026-03-10 11:57:09","Ograniczenie do 30 km/h na każdym osiedlu w Rzeszowie? Radny pyta mieszkańców!","ograniczenie-do-30-kmh-na-kazdym-osiedlu-w-rzeszowie-radny-pyta-mieszkancow","2026-03-10 12:06:26",{"comments":24},{"aid":1869,"attachments":1870,"category":1882,"category_id":62,"featured":24,"id":1883,"is_redirect":24,"lead":1884,"locked":24,"origin_domain":11,"parent_domain":56,"parent_id":56,"premium":24,"priority":63,"published":63,"published_at":1885,"recommended":24,"redirect_url":56,"short_title":1886,"slug":1887,"sponsored":21,"sub_title":56,"title":1888,"uid":1883,"updated_at":1889,"stats":1890,"is_photostory":24,"is_advertisement":24,"is_pool":24,"show_quiz_cover":21,"view_type":872},32234,{"id":1871,"name":59,"url":1872,"thumbnail":59,"created_at":1873,"tags":59,"author":1459,"type":851,"filename":1874,"description":1875,"750x750px":1876,"160x90px":1877,"365x225px":1878,"100x100px":1879,"760xautopx":1880,"1200x675px":1881},58352,"https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/fd29acb5-0ff5-4fe2-9efd-6263066757d2","2026-03-10 11:32:37","fd29acb5-0ff5-4fe2-9efd-6263066757d2","Zdarzenie na alei Wyzwolenia w Rzeszowie","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/a691671c-b697-4da3-aa5d-4a65d53e5ffb","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/0f0356b7-f469-455a-801b-6016025d4c98","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/b3513640-bdb7-41f3-85d0-b7ca92cc6b49","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/447b21fc-4f8e-401f-b707-4f6eafc90e56","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/1a2b7bfe-ec52-42ca-939a-16d6cf1a0cd8","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/b35e4ccb-c559-403e-a931-b0e8657532f1",[88],"K1Hfru0nNwOEChSNVAER","Kierowcy poruszający się po Rzeszowie muszą uzbroić się w anielską cierpliwość. W stolicy Podkarpacia doszło do serii niefortunnych zdarzeń, które sparaliżowały główne arterie miasta. Najpierw na alei Wyzwolenia samochód osobowy uderzył w rowerzystę, a zaledwie chwilę później na ulicy Warszawskiej doszło do kolizji dwóch aut. Służby pracują na miejscu, a mapy drogowe świecą się na czerwono – sprawdźcie, gdzie utkniecie najdłużej i jakie są aktualne ustalenia policji!","2026-03-10 11:33:47","Senior potrącił 15-latka na alei Wyzwolenia w Rzeszowie - spore utrudnienia w mieście [ZDJĘCIA]","senior-potracil-15-latka-na-rowerze-na-alei-wyzwolenia-w-rzeszowie-spore-utrudnienia-w-miescie-zdjecia","Senior potrącił 15-latka  na rowerze na alei Wyzwolenia w Rzeszowie - spore utrudnienia w mieście [ZDJĘCIA]","2026-03-10 11:38:35",{"comments":24},{"aid":1892,"attachments":1893,"category":1906,"category_id":62,"featured":24,"id":1907,"is_redirect":24,"lead":1908,"locked":24,"origin_domain":11,"parent_domain":56,"parent_id":56,"premium":24,"priority":63,"published":63,"published_at":1909,"recommended":24,"redirect_url":56,"short_title":1910,"slug":1911,"sponsored":21,"sub_title":56,"title":1910,"uid":1907,"updated_at":1912,"stats":1913,"is_photostory":24,"is_advertisement":24,"is_pool":24,"show_quiz_cover":21,"view_type":872},32231,{"id":1894,"name":59,"url":1895,"thumbnail":59,"created_at":1896,"tags":59,"author":1897,"type":851,"filename":1898,"description":1899,"750x750px":1900,"160x90px":1901,"365x225px":1902,"100x100px":1903,"760xautopx":1904,"1200x675px":1905},58349,"https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/fc49d622-a40e-44fa-8d3c-2d280ab89577","2026-03-10 09:28:59","KPP Łańcut","fc49d622-a40e-44fa-8d3c-2d280ab89577","Wypadek w regionie","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/0c47fce7-ad51-4ba8-a650-f0c162bd51c0","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/a149451b-a6ff-48d1-a8c5-971116690a68","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/adb93925-bf1e-49f1-99d8-fb3c0da5cc86","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/eccee514-fec0-4645-b722-cfe38ec9ff20","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/a0c00059-73f5-4814-af70-06e651f132ab","https://storage.googleapis.com/bieszczady/rzeszow24/articles/image/2c278a0f-24cb-4ba0-a315-ebc4d0839480",[88],"Cdi87fJBmBDhonVMlLJz","Huk gniecionej blachy w Markowej – Volkswagen z potężną siłą wbił się w pług orny. Choć z auta został wrak, 51-letni kierowca wyszedł z niego bez draśnięcia. Szybko jednak okazało się, że to nie brak szczęścia, a ponad 0,6 promila odebrało mu czujność.","2026-03-10 09:38:03","Rozstrzaskał się o pług!  Volkswagen wbił się w traktor – z auta został wrak [ZDJĘCIA]","rozstrzaskal-sie-o-plug-volkswagen-wbil-sie-w-traktor-z-auta-zostal-wrak-zdjecia","2026-03-10 09:40:24",{"comments":24},{"config":1915,"column":1916,"id":1745,"variant":1923},{"color":1617,"background":1670},[1917],{"module":1918,"size":826},[1919],{"name":1222,"config":1920,"type":1225},{"title":1921,"link":1922,"alternativeView":21},"PRACA RZESZÓW","/tagi/praca-rzeszow",[826],{"id":1772,"config":1925,"variant":1926,"column":1927},{"background":1010,"color":49},[32,32,32,32],[1928,1958,1962,1990],{"size":32,"module":1929},[1930],{"name":838,"config":1931,"type":842,"articles":1933},{"mobile":14,"mobile_full":56,"mobile_intern":56,"type":1024,"query":1932,"limit":63,"skip":24,"category":1932},"category:array-contains:praca-rzeszow",[1934],{"aid":1935,"attachments":1936,"category":1949,"category_id":156,"featured":24,"id":1950,"is_redirect":24,"lead":1951,"locked":24,"origin_domain":11,"parent_domain":56,"parent_id":56,"premium":24,"priority":1389,"published":63,"published_at":1952,"recommended":24,"redirect_url":56,"short_title":1953,"slug":1954,"sponsored":21,"sub_title":56,"title":1955,"uid":1950,"updated_at":1956,"stats":1957,"is_photostory":24,"is_advertisement":24,"is_pool":24,"show_quiz_cover":21,"view_type":872},29753,{"id":1937,"name":59,"url":1938,"thumbnail":59,"created_at":1939,"tags":59,"author":1940,"type":851,"fi
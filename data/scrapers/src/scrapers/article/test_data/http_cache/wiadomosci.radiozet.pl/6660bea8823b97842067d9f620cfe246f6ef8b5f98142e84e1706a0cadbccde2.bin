    <script>
        function readCookie(name) {
            var result = document.cookie.match('(^|;)\\s*' + name + '\\s*=\\s*([^;]+)');
            return result ? result.pop() : '';
        }
        var rodoConsents = readCookie('rodoConsents')
        if (rodoConsents) {
            try {
                window.site_details = JSON.parse(rodoConsents)
            } catch (error) {
                window.site_details = {
                    tcf_e: error,
                }
            }
        } else {
            window.site_details = {
                tcf_r: false
            }
        }
    </script>


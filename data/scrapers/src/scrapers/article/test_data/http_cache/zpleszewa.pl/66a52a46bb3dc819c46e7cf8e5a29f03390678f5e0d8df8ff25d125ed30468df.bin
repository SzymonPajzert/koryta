3e%3cline%20class=&#39;cls-1&#39;%20x1=&#39;11.58&#39;%20y1=&#39;32.66&#39;%20x2=&#39;9.12&#39;%20y2=&#39;36.43&#39;/%3e%3cpath%20class=&#39;cls-2&#39;%20d=&#39;M41.37,12.59a6.32,6.32,0,0,0-6.29-6.36l-.52,0A7.11,7.11,0,0,0,20.9,8h-.08a5.5,5.5,0,0,0,0,11H35.08A6.31,6.31,0,0,0,41.37,12.59Z&#39;/%3e%3cpath%20class=&#39;cls-3&#39;%20d=&#39;M31.83,19.6a7.3,7.3,0,0,0-7.26-7.34c-.21,0-.41,0-.61,0a8.2,8.2,0,0,0-15.77,2H8.1a6.35,6.35,0,0,0,0,12.7H24.57A7.3,7.3,0,0,0,31.83,19.6Z&#39;/%3e%3c/g%3e%3c/g%3e%3c/svg%3e" alt="" data-not-lazy><p class="weather-box__temp">+9° </p></div><!--]--></div></div><div class="col-custom-4 col-custom-mid-4 col-custom-mobile-12"><div class="d-flex align-items-center justify-content-start h-100"><a href="/" class="d-block w-100 text-center"><div class="nav-top__logo-wrapper"><img rel="preload" fetchpriority="high" src="https://static.zpleszewa.pl/attachments/ca8f8a19-034a-4a2e-9f05-cc855019dc86" alt="Najnowsze i najciekawsze wiadomości z Pleszewa, gminy i powiatu pleszewskiego w jednym miejscu. Codziennie ciekawe treści specjalnie dla Ciebie! Zobacz co się dzieje Dziś w Pleszewie." data-not-lazy></div></a></div></div><div class="col-custom-4 col-custom-mid-4 col-custom-mobile-12"><div class="d-flex align-items-center justify-content-end h-100"><div class="nav-top__icon-wrapper d-flex align-items-center justify-content-center me-0 cursor-pointer"><svg class="svg-inline--fa fa-magnifying-glass nav-top__icon-wrapper-icon" style="" aria-hidden="true" focusable="false" data-prefix="fas" data-icon="magnifying-glass" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"><path class="" style="" fill="currentColor" d="M416 208c0 45.9-14.9 88.3-40 122.7L502.6 457.4c12.5 12.5 12.5 32.8 0 45.3s-32.8 12.5-45.3 0L330.7 376c-34.4 25.2-76.8 40-122.7 40C93.1 416 0 322.9 0 208S93.1 0 208 0S416 93.1 416 208zM208 352a144 144 0 1 0 0-288 144 144 0 1 0 0 288z"></path></svg></div><!----><div class="nav-top__icon-wrapper d-flex align-items-center justify-content-center"><a class="d-flex align-items-center justify-content-center w-100 h-100" href="/login" aria-label="Logowanie"><svg class="svg-inline--fa fa-circle-user nav-top__icon-wrapper-icon" style="" aria-hidden="true" focusable="false" data-prefix="fas" data-icon="circle-user" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"><path class="" style="" fill="currentColor" d="M399 384.2C376.9 345.8 335.4 320 288 320l-64 0c-47.4 0-88.9 25.8-111 64.2c35.2 39.2 86.2 63.8 143 63.8s107.8-24.7 143-63.8zM0 256a256 256 0 1 1 512 0A256 256 0 1 1 0 256zm256 16a72 72 0 1 0 0-144 72 72 0 1 0 0 144z"></path></svg></a></div></div></div></div><div class="row"><div class="col-custom-12 col-custom-mid-12 col-custom-mobile-12"><div class="nav-top__footer d-flex justify-content-between col-custom-12"><p class="nav-top__footer-todays d-custom-mobile-none d-custom-mid-none d-custom-block"><strong>czw.</strong>, 12 marca 2026</p><div><!----><div><ul class="nav-top__footer-categories ms-auto"><!--[--><li><a href="/k/wiadomosci"><p>Wiadomości</p></a></li><li><a href="/k/praca"><p>Praca</p></a></li><li><a href="/k/sport"><p>Sport</p></a></li><li><a href="/k/kultura"><p>Kultura</p></a></li><!--]--><li><a href="https://kalkulator.itpow.pl/" target="_blank"><strong><p>OGŁOSZENIA DO GAZETY</p></strong></a></li><li><a href="/kontakt"><strong><p>Daj znać</p></strong></a></li><li><a href="/ogloszenia"><strong><span><p>OGŁOSZENIA PORTAL</p></span></strong></a></li></ul></div></div><div class="nav-top__footer-burger"><div class="d-flex flex-column justify-content-between w-100 h-100"><span></span><span></span><span></span></div></div></div></div></div></div></nav><!--]--><section class="article my-4" itemscope><div class="container-custom"><div class="row"><!----></div><div class="row"><aside class="col-custom-2 col-custom-mid-12 col-custom-mobile-12 left-sidenav d-none d-xl-block"><div class="ad__sky laptopUp"><!----></div></aside><article class="col-custom-7 col-custom-mid-12 col-custom-mobile-12 px-xl-0"><div class="article__wrapper ms-auto"><h1 class="article__title o-0">Fundusze Europejskie wspierają rozwój wielkopolskich wsi</h1><span class="text-muted font-weight-light article__promo-material">Materiał promocyjny</span><div class="d-flex align-items-center my-2"><p class="article__details"><span class="text-muted fw-normal me-2"> Opublikowano: <time class="text-dark fw-bold" datetime="2025-11-03T07:00:00.000Z">poniedziałek, 3 lis 2025 08:00</time><span class="article__details-datemb"> Aktualizacja: <time class="text-dark fw-bold" datetime="2025-11-03T11:36:29.000Z">poniedziałek, 3 lis 2025 12:36</time></span><br><span class="text-muted fw-normal"> Autor: <strong class="text-dark fw-bold">Materiał promocyjny</strong></span><!----></span></p></div><div class="article__img--wrapper"><div class="article__img" style="position:relative;"><img data-not-lazy alt="Fundusze Europejskie wspierają rozwój wielkopolskich wsi - Zdjęcie główne" style="object-fit:cover;object-position:center;position:absolute;left:0;top:0;width:100%;height:100%;" src="https://static.zpleszewa.pl/zpleszewa/articles/image/afd20343-037d-4ad6-88d6-074f628fc614"></div><div style="font-size:12px;margin-top:4px;margin-bottom:4px;"><!--[--><span class="text-muted fw-normal">Autor:</span> Stowarzyszenie „Wspólnie dla Przyszłości”<!--]--><!--[--> | <!--]--><!--[--><span class="text-muted fw-normal">Opis: </span><span>Na początku 2024 roku Stowarzyszenie „Wspólnie dla Przyszłości” otrzymało ponad 4 mln euro do rozdystrybuowania wśród beneficjentów w ramach ogłaszanych sukcesywnie naborów wniosków. Środki na ten cel pochodzą z trzech funduszy: rolnego, społecznego oraz rozwoju regionalnego.</span><!--]--></div><!----></div><p class="article__img-title"><!---->   </p><!----><div class="article__socials my-3 d-flex"><div class="article__socials-info">Udostępnij na:</div><div class="article__socials-right"><a href="https://www.facebook.com/sharer/sharer.php?u=https://zpleszewa.pl//promowane/fundusze-europejskie-wspieraja-rozwoj-wielkopolskich-wsi/oQNxGfXvu8ACC5ruEIsD" class="article__socials-btn article__socials--fb" target="_blank"><span class="article__socials-icon"><svg class="svg-inline--fa fa-facebook-f" style="" aria-hidden="true" focusable="false" data-prefix="fab" data-icon="facebook-f" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512"><path class="" style="" fill="currentColor" d="M80 299.3V512H196V299.3h86.5l18-97.8H196V166.9c0-51.7 20.3-71.5 72.7-71.5c16.3 0 29.4 .4 37 1.2V7.9C291.4 4 256.4 0 236.2 0C129.3 0 80 50.5 80 159.4v42.1H14v97.8H80z"></path></svg></span><span class="article__socials-text">Facebook</span></a><a href="https://twitter.com/intent/tweet?text=https://zpleszewa.pl//promowane/fundusze-europejskie-wspieraja-rozwoj-wielkopolskich-wsi/oQNxGfXvu8ACC5ruEIsD" class="article__socials-btn article__socials--twitter" target="_blank"><span class="article__socials-icon"><svg class="svg-inline--fa fa-twitter" style="" aria-hidden="true" focusable="false" data-prefix="fab" data-icon="twitter" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"><path class="" style="" fill="currentColor" d="M459.37 151.716c.325 4.548.325 9.097.325 13.645 0 138.72-105.583 298.558-298.558 298.558-59.452 0-114.68-17.219-161.137-47.106 8.447.974 16.568 1.299 25.34 1.299 49.055 0 94.213-16.568 130.274-44.832-46.132-.975-84.792-31.188-98.112-72.772 6.498.974 12.995 1.624 19.818 1.624 9.421 0 18.843-1.3 27.614-3.573-48.081-9.747-84.143-51.98-84.143-102.985v-1.299c13.969 7.797 30.214 12.67 47.431 13.319-28.264-18.843-46.781-51.005-46.781-87.391 0-19.492 5.197-37.36 14.294-52.954 51.655 63.675 129.3 105.258 216.365 109.807-1.624-7.797-2.599-15.918-2.599-24.04 0-57.828 46.782-104.934 104.934-104.934 30.213 0 57.502 12.67 76.67 33.137 23.715-4.548 46.456-13.32 66.599-25.34-7.798 24.366-24.366 44.833-46.132 57.827 21.117-2.273 41.584-8.122 60.426-16.243-14.292 20.791-32.161 39.308-52.628 54.253z"></path></svg></span><span class="article__socials-text">Twitter</span></a></div></div><div><div class="article__recommended my-4"><p class="article__recommended-text1 fw-normal text-muted text-uppercase ms-4 mb-2"> Przeczytaj również: </p><div class="bg-light pt-3 pb-3"><!--[--><div class="image-listing-item ps-4 pe-3"><a href="https://zpleszewa.pl/wiadomosci/tu-w-wielkopolsce-zyje-sie-najlepiej-ai-wskazala-konkretne-powiaty/NEmKPTcmGMilMyscuBUk" target="_self"><div class="image-listing-item__wrapper d-flex align-items-center"><ul class="image-listing-item__text"><li class="mb-1 fw-bold">Tu w Wielkopolsce żyje się najlepiej. <span class="mb-3 fw-normal">AI wskazała konkretne powiaty</span></li></ul></div></a></div><div class="image-listing-item ps-4 pe-3"><a href="https://zpleszewa.pl/wiadomosci/najpopularniejsze-imiona-2025-roku-polska-ma-liderow-wielkopolska-ma-wlasne-trendy/PXYQBdEbd6Sk2GcVrShT" target="_self"><div class="image-listing-item__wrapper d-flex align-items-center"><ul class="image-listing-item__text"><li class="mb-1 fw-bold">Najpopularniejsze imiona 2025 roku. <span class="mb-3 fw-normal">Polska ma liderów, Wielkopolska ma własne trendy</span></li></ul></div></a></div><div class="image-listing-item ps-4 pe-3"><a href="https://zpleszewa.pl/wiadomosci/wrzutnia-ksiazek-mapy-dotykowe-i-nowa-strefa-dla-dzieci-wielkie-zmiany-w-pleszewskiej-bibliotece/98CAZkb7b1qOkAKxq6CW" target="_self"><div class="image-listing-item__wrapper d-flex align-items-center"><ul class="image-listing-item__text"><li class="mb-1 fw-bold">Wielkie zmiany dla czytelników <span class="mb-3 fw-normal">Biblioteka w Pleszewie idzie „Równym torem”</span></li></ul></div></a></div><!--]--></div></div></div><div class="article__subtitle"><span class="article__badge default-badge"><a href="/k/promowane">Promowane</a><!----></span><span>Rozpoczęły się nabory wniosków w ramach Planu Strategicznego dla Wspólnej Polityki Rolnej na lata 2023-2027 ze środków Unii Europejskiej przewidzianych na wsparcie rozwoju lokalnego przy udziale lokalnych grup działania. Do końca 2029 roku na rozwój lokalny  rozdystrybuowane zostanie aż 128,5 mln euro z trzech unijnych funduszy. Blisko dwie trzecie tej kwoty pochodzi z Europejskiego Funduszu Rolnego na rzecz Rozwoju Obszarów Wiejskich.</span></div><div class="article__tags pb-4"><!--[--><a href="/tagi/wielkopolska" class="article__tags-tag badge me-1">Wielkopolska</a><a href="/tagi/wies" class="article__tags-tag badge me-1">wieś</a><a href="/tagi/fundusze-europejskie" class="article__tags-tag badge me-1">Fundusze Europejskie</a><!--]--></div><!--[--><!----><!--[--><!----><div class="article__content"><!--[--><!--[--><div><p>Od początku 2025 roku odbywają się nabory wniosków cyklicznie ogłaszane przez lokalne grupy działania (LGD) z przeznaczeniem na wsparcie rozwoju lokalnego kierowanego przez społeczność. W obecnej perspektywie budżetu unijnego, którego realizację przewidziano do końca 2029 roku, na terenie województwa wielkopolskiego funkcjonuje 30 LGD. Zakres terytorialny poszczególnych grup obejmuje obszar od kilku do kilkunastu gmin. &nbsp;Mieszkańcy tych gmin, przedsiębiorcy, organizacje samorządowe, a także same gminy i powiaty mogą ubiegać się o dofinansowanie szeregu zadań wpisujących się w założenia wynikające z opracowanych w 2023 roku strategii rozwoju lokalnego kierowanego przez społeczność.&nbsp;</p></div><!--]--><!--[--><div><blockquote>
<p>- Od 2024 roku na rozwój lokalny w województwie wielkopolskim przeznaczamy środki z trzech funduszy: rolnego, rozwoju regionalnego oraz funduszu społecznego. Do dyspozycji beneficjentów jest aż 128,5 miliona euro. Środki dystrybuowane są przy udziale lokalnych grup działania, które ogłaszają nabory wniosków. W drugiej połowie 2025 roku zakontraktowaliśmy pierwsze umowy w ramach wspólnej polityki rolnej. Do środowisk lokalnych trafiają pieniądze na niezbędne inwestycje, poprawę jakości życia mieszkańców, ale również na rozwój przedsiębiorczości i aktywizację mieszkańców – mówi Krzysztof Grabowski, Wicemarszałek Województwa Wielkopolskiego.</p>
</blockquote></div><!--]--><!--[--><div><h2 id="t4_1761823169492">Szansa dla przedsiębiorców</h2></div><!--]--><!--[--><div><p>Nabory wniosków ogłaszane w ramach PS WPR 2023-2027 przez lokalne grupy działania adresowane są zarówno do nowych przedsiębiorców, którzy mogą skorzystać ze środków na podejmowanie działalności gospodarczej, jak i już działających na rynku firm, dla których przewidziano możliwość pozyskania funduszy na rozwój prowadzonej działalności. W porównaniu z Programem Rozwoju Obszarów Wiejskich na lata 2014-2020 fundusze przyznawane z Planu Strategicznego dla Wspólnej Polityki Rolnej na lata 2023-2027 jeszcze silniej ukierunkowane są na wsparcie konkretnych tematów i branż. Duże znaczenie zyskują przedsięwzięcia z zakresu rozwoju biogospodarki i zielonej gospodarki.&nbsp;</p></div><!--]--><!--[--><div><p>Lokalne grupy działania opracowując strategie rozwoju były zobowiązane do zdefiniowania obszarów gospodarki, które mają kluczowe znaczenie dla rozwoju danego obszaru. W strategiach pojawiają się takie branże jak przetwórstwo lokalne, edukacja, usługi turystyczne, rekreacyjne, rehabilitacyjne, zdrowotne, „zielone miejsca pracy”, czy usługi związane z nowymi technologiami. Nowym zakresem wsparcia, tworzącym przestrzeń do realizacji zadań o charakterze komercyjnym, &nbsp;jest rozwój pozarolniczych funkcji małych gospodarstw rolnych w zakresie tworzenia &nbsp;lub rozwijania gospodarstw agroturystycznych, zagród edukacyjnych lub gospodarstw opiekuńczych. Na realizację takich projektów dofinansowanie mogą uzyskać rolnicy lub członkowie ich rodzin.&nbsp;</p></div><!--]--><!--[--><div><h2 id="t6_1761823209396">Inwestycje w przestrzeń publiczną</h2></div><!--]--><!--[--><div><p>Realizacja inicjatywy LEADER (takim mianem od ponad 20 lat określa się rozwój lokalny kierowany przez społeczność danego obszaru) stwarza warunki finansowe powiatom, gminom oraz organizacjom pozarządowym do inwestowania w poprawę dostępu mieszkańców do małej infrastruktury publicznej. Chodzi przede wszystkim o obiekty o charakterze rekreacyjnym, turystycznym lub sportowym. Fundusze Europejskie umożliwiają zatem powstanie lub modernizację świetlic wiejskich, parków, skwerów, budowę wiat rekreacyjnych, placów zabaw, siłowni zewnętrznych, boisk, bieżni lekkoatletycznych czy wyposażenia stadionów wiejskich.&nbsp;</p></div><!--]--><!--[--><div><p style="text-align: center;"><img loading="lazy" style="display: block; margin-left: auto; margin-right: auto;" src="https://storage.googleapis.com/poludniowaoficyna-pbem/attachments/65d3ae65-222c-4157-80fb-c31fa372932b" alt="" width="1200" height="675"><em><span style="font-size: 10pt;">Dzięki środkom z PROW 2014-2020 w ramach inicjatywy LEADER w Dobrzycy powstał nowoczesny pumptruck. Źródło: Profil FB VeloProjekt – wykonawcy inwestycji&nbsp;</span></em></p></div><!--]--><!--[--><div><h2 id="t8_1761823218818">Gdzie szukać informacji o naborach?</h2></div><!--]--><!--[--><div><p>Na terenie powiatu pleszewskiego funkcjonuje lokalna grupy działania Stowarzyszenie „Wspólnie dla Przyszłości”. Zgodnie z zawartą umową ramową z Samorządem Województwa Wielkopolskiego LGD ma do dyspozycji blisko 2,5 miliona euro dla beneficjentów aplikujących o środki w ramach Planu Strategicznego dla Wspólnej Polityki Rolnej. Bieżące informacje na temat przeprowadzonych i zaplanowanych naborów wniosków można znaleźć na stronie internetowej <a href="https://lgd.pleszew.pl/" rel="dofollow">lgd.pleszew.pl</a>. Do końca 2025 roku LGD ma obowiązek opublikowania harmonogramu naborów na kolejny rok.</p></div><!--]--><!--[--><div><p>Cały proces aplikowania o pomoc finansową do lokalnych grup działania, rozpatrywania wniosków przez LGD oraz Samorząd Województwa Wielkopolskiego, zawierania umów oraz rozliczenia zrealizowanych przedsięwzięć odbywa się w formie elektronicznej przy użyciu Platformy Usług Elektronicznych ARiMR oraz Centralnego Systemu Obsługi Beneficjentów.&nbsp;</p></div><!--]--><!--[--><div><p style="text-align: center;"><span style="font-size: 10pt;"><em>Materiał finansowany ze środków UE w ramach Planu Strategicznego dla Wspólnej Polityki Rolnej na lata 2023-2027.</em></span><br><span style="font-size: 10pt;"><em>Materiał opracowany przez Samorząd Województwa Wielkopolskiego.&nbsp;</em></span><br><span style="font-size: 10pt;"><em>Instytucja Zarządzająca Planem Strategicznym dla Wspólnej Polityki Rolnej na lata 2023-2027 – Minister Rolnictwa i Rozwoju Wsi.</em></span></p></div><!--]--><!--[--><div><p><img loading="lazy" style="display: block; margin-left: auto; margin-right: auto;" src="https://storage.googleapis.com/poludniowaoficyna-pbem/attachments/e5327175-0672-4445-b42d-2d0bbc059385" alt="" width="999" height="103"></p></div><!--]--><!--]--></div><!----><!----><!----><!----><!----><!----><!----><!----><!----><div class="pt-3 mb-3"><p class="article__recommended-text fw-normal text-muted text-uppercase mb-2"> Polecane artykuły: </p><div class="article__recommended-background position-relative bg-light p-3"><div class="d-flex row justify-content-around"><!--[--><div class="image-listing-small-item article__recommended-small-tile-first col-custom-mobile-12 d-flex"><a href="https://zpleszewa.pl/wiadomosci/wazne-dla-rolnikow-nowy-termin-na-rozliczenie-silosow-masz-czas-do-30-kwietnia/9CLPZaL9bY6kef4BBFCA" target="_self"><div class="image-listing-small-item__wrapper d-flex align-items-center"><div class="image-listing-small-item__img" lazy-background="https://static.zpleszewa.pl/zpleszewa/articles/image/5c219672-9981-4f82-9924-83e6a474f6f9" style="background:center center/cover no-repeat;"><!----></div><div><p class="image-listing-small-item__text">Ważne dla rolników!</p></div></div></a></div><div class="image-listing-small-item article__recommended-small-tile-first col-custom-mobile-12 d-flex"><a href="https://zpleszewa.pl/wiadomosci/dzien-dobry-pleszew-dzis-czwartek-12-marca-2026-roku/RDXHDmHBR9ekp5yxC2aF" target="_self"><div class="image-listing-small-item__wrapper d-flex align-items-ce
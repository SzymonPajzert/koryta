94,"365x225px":94,"100x100px":94,"760xautopx":94,"1200x675px":94,"gallery_id":3448},{"id":3459,"name":97,"url":3460,"thumbnail":3460,"created_at":3461,"tags":97,"author":97,"type":1064,"filename":3462,"description":3463,"750x750px":94,"160x90px":94,"365x225px":94,"100x100px":94,"760xautopx":94,"1200x675px":94,"gallery_id":3448},5369759,"https://storage.googleapis.com/poludniowaoficyna-pbem/galleries/206a51e6-071e-4d70-ac86-3ead30d9d7a8","2026-03-10 13:51:40","206a51e6-071e-4d70-ac86-3ead30d9d7a8","\u003Cp>To odpowiedź na potrzeby młodych talent&oacute;w, kt&oacute;re dotychczas często szukały możliwości rozwoju poza powiatem\u003C/p>",{"id":3465,"name":97,"url":3466,"thumbnail":3466,"created_at":3467,"tags":97,"author":97,"type":1064,"filename":3468,"description":3469,"750x750px":94,"160x90px":94,"365x225px":94,"100x100px":94,"760xautopx":94,"1200x675px":94,"gallery_id":3448},5369765,"https://storage.googleapis.com/poludniowaoficyna-pbem/galleries/62db36e2-2cdf-45e7-8c01-0ca8e3634ad1","2026-03-10 13:51:41","62db36e2-2cdf-45e7-8c01-0ca8e3634ad1","\u003Cp>Klasa, kt&oacute;ra zostanie uruchomiona w SP nr 3 w Pleszewie ma liczyć 26 uczni&oacute;w. Zgodnie z założeniami, będzie to zesp&oacute;ł zr&oacute;żnicowany: 16 miejsc przeznaczono dla młodych piłkarzy, a 10 dla lekkoatletyki\u003C/p>",{"id":3471,"name":97,"url":3472,"thumbnail":3472,"created_at":3473,"tags":97,"author":97,"type":1064,"filename":3474,"description":3475,"750x750px":94,"160x90px":94,"365x225px":94,"100x100px":94,"760xautopx":94,"1200x675px":94,"gallery_id":3448},5369777,"https://storage.googleapis.com/poludniowaoficyna-pbem/galleries/ae70501f-f6d0-45fb-95ff-de58cefd86b6","2026-03-10 13:51:43","ae70501f-f6d0-45fb-95ff-de58cefd86b6","\u003Cp>Do klasy sportowej mogą aplikować uczniowie z terenu miasta i gminy Pleszew. Rekrutacja składa się z dw&oacute;ch etap&oacute;w\u003C/p>",{"id":3477,"name":97,"url":3478,"thumbnail":3478,"created_at":3479,"tags":97,"author":97,"type":1064,"filename":3480,"descripti
    <p class="font-bold text-sm [&>a]:hover:underline text-[#757575] font-['Roboto']"><span class="text-sm">Autor:</span> <a href="https://niezalezna.pl/autor/mateusz-mol" rel="author">Mateusz Mol</a></p>
    <!-- Social Share Buttons -->

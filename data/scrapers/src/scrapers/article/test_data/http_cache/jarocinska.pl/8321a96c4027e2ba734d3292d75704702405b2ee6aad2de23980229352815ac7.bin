eries/daca6bd6-5990-438d-86d0-42a99a0b8448","2026-03-11 12:20:10","daca6bd6-5990-438d-86d0-42a99a0b8448",{"id":1679,"name":1629,"url":1680,"thumbnail":1680,"created_at":1681,"tags":91,"author":1458,"type":1129,"filename":1682,"description":91,"750x750px":88,"160x90px":88,"365x225px":88,"100x100px":88,"760xautopx":88,"1200x675px":88,"gallery_id":1633},5371640,"https://storage.googleapis.com/poludniowaoficyna-pbem/galleries/fe4f773e-6782-4d78-b591-361669dece66","2026-03-11 12:20:11","fe4f773e-6782-4d78-b591-361669dece66",{"id":1684,"name":1629,"url":1685,"thumbnail":1685,"created_at":1681,"tags":91,"author":1458,"type":1129,"filename":1686,"description":91,"750x750px":88,"160x90px":88,"365x225px":88,"100x100px":88,"760xautopx":88,"1200x675px":88,"gallery_id":1633},5371646,"https://storage.googleapis.com/poludniowaoficyna-pbem/galleries/471b5fbe-0d5b-49a7-af39-c337bbc947ea","471b5fbe-0d5b-49a7-af39-c337bbc947ea","j54adCTtEyY80BJr1M0a",[1689,1690,1537,1691,1692,1693,1205,1694,1211,1695,1696,1697,1698,1699,1537,1700,1701],"centrum","przesiadkowe","przejscie","pod","torami","dworzec","jarocinie","takie","plany","ma","miasto","pkp","zdjecia","Poprawa dostępności dworca kolejowego w Jarocinie była przedmiotem rozmów między samorządem gminy Jarocin a PKP. Czy rzeczywiście w Jarocinie powstanie tunel przejście pod torami? Taka koncepcja nie jest wykluczona i to nie tylko ze względów komunikacyjnych.",{"title":1704,"description":1705,"keywords":1706,"fb_cover":1707,"fb_title":88,"fb_description":88},"Centrum przesiadkowe i przejście pod torami na dworzec w Jarocinie - takie plany ma miasto i PKP [ZDJĘCIA]","Poprawa dostępności dworca kolejowego w Jarocinie była przedmiotem rozmów między samorządem gminy Jarocin a PKP. Są już pierwsze efekty tych negocjacji. Jakie - podajemy szczegóły.","Dworzec PKP w Jarocinie, PKP",{"value":1708},{"filename":88,"name":88,"tags":88,"thumbnail":88,"type":88,"url":88},{"id":1710,"options":1711,"all_votes":169,"created_at":1715,"updated_at":1715,
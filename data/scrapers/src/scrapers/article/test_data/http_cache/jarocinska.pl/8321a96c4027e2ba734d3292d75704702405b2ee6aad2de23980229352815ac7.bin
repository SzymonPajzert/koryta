:1507},"szkola","2026-03-11 10:38:55",["Reactive",1510],{"ads":29,"aid":1511,"alternative_gallery_style":29,"attachments":1512,"author":1526,"author_info":44,"category":1527,"comments":29,"comments_auth":29,"content":91,"created_by":1528,"created_by_name":91,"custom_html":88,"featured":44,"gallery_ads":1529,"gallery_picked":28,"id":1530,"is_advertisement":44,"is_photostory":44,"is_pool":44,"multiportal":88,"view_type":88,"is_redirect":44,"keywords":1531,"lead":1541,"locked":44,"meta":1542,"parent_domain":88,"parent_id":88,"photostory_added":28,"pool_picked":88,"pool_under_photostory":28,"premium":44,"published":13,"published_at":1547,"quiz_picked":88,"recommended":44,"redirect_url":88,"self_url":1548,"show_quiz_cover":28,"slug":1549,"sponsored":28,"short_title":1550,"tags":1551,"tagsRaw":1554,"title":1543,"type":1176,"uid":1530,"updated_at":1559},73484,[1513],{"id":1514,"name":91,"url":1515,"thumbnail":91,"created_at":1516,"tags":91,"author":1517,"type":1129,"filename":1518,"description":1519,"750x750px":1520,"160x90px":1521,"365x225px":1522,"100x100px":1523,"760xautopx":1524,"1200x675px":1525,"article_id":1511},193940,"https://storage.googleapis.com/poludniowaoficyna-pbem/jarocinska/articles/image/3b0ff1cf-7ae9-4911-8e89-10c5d8500009","2026-03-11 15:11:00","KPP w Środzie Wielkopolskiej","3b0ff1cf-7ae9-4911-8e89-10c5d8500009","Policja poszukuje zaginionego Łukasza Depta","https://storage.googleapis.com/poludniowaoficyna-pbem/jarocinska/articles/image/163da794-6bba-4b02-92de-c62b96f27cf0","https://storage.googleapis.com/poludniowaoficyna-pbem/jarocinska/articles/image/15308dba-9185-4c84-90c5-9acde3e3b2d2","https://storage.googleapis.com/poludniowaoficyna-pbem/jarocinska/articles/image/d0773c19-4953-44cf-a98c-04dfd8ca3170","https://storage.googleapis.com/poludniowaoficyna-pbem/jarocinska/articles/image/fdf13356-89e4-4a89-8923-4f22bffa184b","https://storage.googleapis.com/poludniowaoficyna-pbem/jarocinska/articles/image/07a693e6-cd64-4388-a8a9-6ccd2e66d31f","https://st
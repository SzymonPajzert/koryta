udniowaoficyna-pbem/jarocinska/articles/image/8783b118-6089-49bb-b777-fd11704ed9b3","https://storage.googleapis.com/poludniowaoficyna-pbem/jarocinska/articles/image/ecc2026c-b555-474b-81e9-62dfcbe67e62","https://storage.googleapis.com/poludniowaoficyna-pbem/jarocinska/articles/image/a87ab802-66de-4cc4-93c6-c201d0727958","https://storage.googleapis.com/poludniowaoficyna-pbem/jarocinska/articles/image/12714ac4-18d3-44e1-a439-42daca3424c4",[122],"54",{"id":88,"frequency":88},{"id":1931,"uid":1932,"title":1933,"slug":1934,"type":1639,"image_type":44,"description":91,"origin_portal":88,"created_at":1935,"updated_at":1936,"created_by":459,"updated_by":88,"ads":28,"deleted":44,"ads_placement":44,"unauthorizedLikes":13,"main_image":1937,"attachments":1938},59957,"rpeLp5uTx3TfjEk0N5JN","Jarocin. Wyburzają budynek wielorodzinny na ul. Św. Ducha. W tym miejscu powstaną mieszkania wspomagane dla seniorów","jarocin-wyburzaja-budynek-wielorodzinny-na-ul-sw-ducha-w-tym-miejscu-powstana-mieszkania-wspomagane-dla-seniorow","2026-03-11 10:02:26","2026-03-11 10:53:02","https://storage.googleapis.com/poludniowaoficyna-pbem/galleries/eb9f2987-bcb7-4589-9f0b-940a09fe50f7",[1939,1944,1950,1956,1962,1968,1973,1978,1983,1987,1992,1997,2002,2006,2011,2016,2020,2025,2030,2035,2039,2044,2049,2054,2059,2064,2068,2073,2077,2082,2087,2091,2096],{"id":1940,"name":1933,"url":1937,"thumbnail":1937,"created_at":1941,"tags":91,"author":1942,"type":1129,"filename":1943,"description":91,"750x750px":88,"160x90px":88,"365x225px":88,"100x100px":88,"760xautopx":88,"1200x675px":88,"gallery_id":1931},5370758,"2026-03-11 10:02:01","Bartosz NAWROCKI","eb9f2987-bcb7-4589-9f0b-940a09fe50f7",{"id":1945,"name":1933,"url":1946,"thumbnail":1946,"created_at":1947,"tags":91,"author":1942,"type":1129,"filename":1948,"description":1949,"750x750px":88,"160x90px":88,"365x225px":88,"100x100px":88,"760xautopx":88,"1200x675px":88,"gallery_id":1931},5370668,"https://storage.googleapis.com/poludniowaoficyna-pbem/galleries/ea6452ca-2157-4b5b-99ab-62f0e48a2822","2026-03-11 10:01:49","ea6452ca-2157-4b5b-99ab-62f0e48a2822","\u003Cp>Rozpoczęło się zapowiadane burzenie budynku wielorodzinnego, kt&oacute;ry stał w sąsiedztwie wieży ciśnień w Jarocinie. Na działce planowany jest obiekt z mieszkaniami wspomaganymi. Gmina szuka właśnie projektanta.\u003C/p>",{"id":1951,"name":1933,"url":1952,"thumbnail":1952,"created_at":1953,"tags":91,"author":1942,"type":1129,"filename":1954,"description":1955,"750x750px":88,"160x90px":88,"365x225px":88,"100x100px":88,"760xautopx":88,"1200x675px":88,"gallery_id":1931},5370674,"https://storage.googleapis.com/poludniowaoficyna-pbem/galleries/33f52840-2620-4580-afcf-c1c75a0ff9cd","2026-03-11 10:01:50","33f52840-2620-4580-afcf-c1c75a0ff9cd","\u003Cp>Na działce planowany jest obiekt z mieszkaniami wspomaganymi. Gmina szuka właśnie projektanta.\u003C/p>",{"id":1957,"name":1933,"url":1958,"thumbnail":1958,"created_at":1959,"tags":91,"author":1942,"type":1129,"filename":1960,"description":1961,"750x750px":88,"160x90px":88,"365x225px":88,"100x100px":88,"760xautopx":88,"1200x675px":88,"gallery_id":1931},5370692,"https://storage.googleapis.com/poludniowaoficyna-pbem/galleries/b48fdbd9-06d0-4ae5-818f-b01b59fce563","2026-03-11 10:01:53","b48fdbd9-06d0-4ae5-818f-b01b59fce563","\u003Cp>Ostatni lokatorzy opuścili budynek przy. Ul. Św. Ducha 71 w ubiegłym roku. Obiekt, kt&oacute;rym odministruje Jarocińskie Towarzystwo Budownictwa Społecznego nie nadawał się do remontu i dalszego zamieszkania.\u003C/p>\n\u003Cp>&nbsp;\u003C/p>",{"id":1963,"name":1933,"url":1964,"thumbnail":1964,"created_at":1965,"tags":91,"author":1942,"type":1129,"filename":1966,"description":1967,"750x750px":88,"160x90px":88,"365x225px":88,"100x100px":88,"760xautopx":88,"1200x675px":88,"gallery_id":1931},5370686,"https://storage.googleapis.com/poludniowaoficyna-pbem/galleries/85e07061-7e89-4743-ad32-20dc87d903d5","2026-03-11 10:01:52","85e07061-7e89-4743-ad32-20dc87d903d5","\u003Cp>Pojawiły się nawet plotki, że nieruchomość - znajdująca się w świetnym punkcie miasta - może zostać sprzedana. Władze gminy, o czym pisaliśmy na przełomie roku, zdementowały te informacje.&nbsp;\u003C/p>",{"id":1969,"name":1933,"url":1970,"thumbnail":1970,"created_at":1971,"tags":91,"author":1942,"type":1129,"filename":1972,"description":91,"750x750px":88,"160x90px":88,"365x225px":88,"100x100px":88,"760xautopx":88,"1200x675px":88,"gallery_id":1931},5370680,"https://storage.googleapis.com/poludniowaoficyna-pbem/galleries/cad15cdd-e910-47b2-a842-7476514d709a","2026-03-11 10:01:51","cad15cdd-e910-47b2-a842-7476514d709a",{"id":1974,"name":1933,"url":1975,"thumbnail":1975,"created_at":1976,"tags":91,"author":1942,"type":1129,"filename":1977,"description":91,"750x750px":88,"160x90px":88,"365x225px":88,"100x100px":88,"760xautopx":88,"1200x675px":88,"gallery_id":1931},5370698,"https://storage.googleapis.com/poludniowaoficyna-pbem/galleries/d8ee3ff4-77b6-4b10-b3e4-4ffdd34d19cb","2026-03-11 10:01:54","d8ee3ff4-77b6-4b10-b3e4-4ffdd34d19cb",{"id":1979,"name":1933,"url":1980,"thumbnail":1980,"created_at":1981,"tags":91,"author":1942,"type":1129,"filename":1982,"description":91,"750x750px":88,"160x90px":88,"365x225px":88,"100x100px":88,"760xautopx":88,"1200x675px":88,"gallery_id":1931},5370722,"https://storage.googleapis.com/poludniowaoficyna-pbem/galleries/867856e2-2f70-4438-8b0e-bf444791ba53","2026-03-11 10:01:57","867856e2-2f70-4438-8b0e-bf444791ba53",{"id":1984,"name":1933,"url":1985,"thumbnail":1985,"created_at":1976,"tags":91,"author":1942,"type":1129,"filename":1986,"description":91,"750x750px":88,"160x90px":88,"365x225px":88,"100x100px":88,"760xautopx":88,"1200x675px":88,"gallery_id":1931},5370704,"https://storage.googleapis.com/poludniowaoficyna-pbem/galleries/467c525d-5226-467e-816b-2b0f7a466cbf","467c525d-5226-467e-816b-2b0f7a466cbf",{"id":1988,"name":1933,"url":1989,"thumbnail":1989,"created_at":1990,"tags":91,"author":1942,"type":1129,"filename":1991,"description":91,"750x750px":88,"160x90px":88
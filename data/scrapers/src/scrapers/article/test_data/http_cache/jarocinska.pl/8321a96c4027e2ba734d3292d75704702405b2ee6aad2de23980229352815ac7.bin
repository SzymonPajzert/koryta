":88,"fb_description":88},"Hokejowe emocje na lodowisku w Jarocinie [ZDJĘCIA]","hokej na lodzie, Turniej Hokeja w Jarocinie, Hockey Rock Jarocin, Fundacja Ogród Marzeń",{"value":2600},{"filename":88,"name":88,"tags":88,"thumbnail":88,"type":88,"url":88},"2026-03-10 19:24:39","https://jarocinska.pl/sport/hokejowe-emocje-na-lodowisku-w-jarocinie-zdjecia/fEF4qDtSV7ZJWpeWdwKa","hokejowe-emocje-na-lodowisku-w-jarocinie-zdjecia",[2605,2606,2607,2608],"Turniej Hokeja w Jarocinie","Fundacja Ogród Marzeń","hokej na lodzie","Hockey Rock Jarocin",[2610,2612,2614,2616],{"tag":2605,"slug":2611},"turniej-hokeja-w-jarocinie",{"tag":2606,"slug":2613},"fundacja-ogrod-marzen",{"tag":2607,"slug":2615},"hokej-na-lodzie",{"tag":2608,"slug":2617},"hockey-rock-jarocin","2026-03-11 07:31:14",["Reactive",2620],{"ads":28,"aid":2621,"alternative_gallery_style":29,"attachments":2622,"author":2634,"author_info":44,"category":2635,"comments":28,"comments_auth":29,"content":91,"created_by":2636,"created_by_name":91,"custom_html":88,"featured":44,"gallery_ads":2637,"gallery_picked":28,"id":2638,"is_advertisement":13,"is_photostory":44,"is_pool":44,"multiportal":88,"view_type":88,"is_redirect":44,"keywords":2639,"lead":2652,"locked":44,"meta":2653,"parent_domain":88,"parent_id":88,"photostory_added":28,"pool_picked":88,"pool_under_photostory":28,"premium":44,"published":13,"published_at":2658,"quiz_picked":88,"recommended":44,"redirect_url":88,"self_url":2659,"show_quiz_cover":28,"slug":2660,"sponsored":28,"short_title":2661,"tags":2662,"tagsRaw":2663,"title":2654,"type":1176,"uid":2638,"updated_at":2658},73445,[2623],{"id":2624,"name":91,"url":2625,"thumbnail":91,"created_at":2626,"tags":91,"author":91,"type":1129,"filename":2627,"description":91,"750x750px":2628,"160x90px":2629,"365x225px":2630,"100x100px":2631,"760xautopx":2632,"1200x675px":2633,"article_id":2621},193904,"https://storage.googleapis.com/poludniowaoficyna-pbem/jarocinska/articles/image/c2504ae1-4e7b-4be6-b86a-5e65050ed424","2026-03-10 15:43:36","c2504ae1-4e7b-4be6-b86a-5e65050ed424","https://storage.googleapis.com/poludniowaoficyna-pbem/jarocinska/articles/image/de23febd-35de-4823-bd36-3d0f5aab5e24","https://storage.googleapis.com/poludniowaoficyna-pbem/jarocinska/articles/image/e862a009-45ae-4923-bb79-2cec097f2cfd","https://storage.googleapis.com/poludniowaoficyna-pbem/jarocinska/articles/image/21806289-38d6-4acc-8b09-ef167815ac67","https://storage.googleapis.com/poludniowaoficyna-pbem/jarocinska/articles/image/5f501fd8-b891-4459-bf77-6581fa40f354","https://storage.googleapis.com/poludniowaoficyna-pbem/jarocinska/articles/image/86582b57-5f78-47fb-a557-840c61f888d3","https://storage.googleapis.com/poludniowaoficyna-pbem/jarocinska/articles/image/b0c93944-4321-4179-99c6-9d5d7488a233","Redakcja",[454],"42",{"id":88,"frequency":88},"bply0Q1Ejk5yWqAeHU9s",[2640,2641,2642,2643,2644,2645,2646,2647,2644,2648,1537,2649,2650,2651],"mokra","czy","sucha","karma","dla","psa","co","wybrac","zdrowia","codziennego","komfortu","pupila","Lepsza będzie mokra czy sucha karma dla psa? Nie ma jednej odpowiedzi, bo wiele zależy od wieku, zdrowia, apetytu i trybu życia pupila. Obie opcje mogą dobrze wspierać psa, jeśli są pełnoporcjowe i właściwie dobrane. W dalszej części porównamy je pod kątem zdrowia oraz codziennej wygody psa i opiekuna, więc czytaj dalej.",{"title":2654,"description":2652,"keywords":2655,"fb_cover":2656,"fb_title":88,"fb_description":88},"Mokra czy sucha karma dla psa – co wybrać dla zdrowia i codziennego komfortu pupila?","psy",{"value":2657},{"filename":88,"name":88,"tags":88,"thumbnail":88,"type":88,"url":88},"2026-03-10 15:43:37","https://jarocinska.pl/artykul-partnera/mokra-czy-sucha-karma-dla-psa-co-wybrac-dla-zdrowia-i-codziennego-komfortu-pupila/bply0Q1Ejk5yWqAeHU9s","mokra-czy-sucha-karma-dla-psa-co-wybrac-dla-zdrowia-i-codziennego-komfortu-pupila","Mokra czy sucha karma dla psa",[2655],[2664],{"tag":2655,"slug":2655},["Reactive",2666],{"ads":29,"aid":2667,"alternative_gallery_style":29,"attachments":2668,"author":1809,"author_info":44,"category":2678,"comments":29,"comments_auth":29,"content":91,"created_by":1811,"created_by_name":91,"custom_html":88,"featured":44,"gallery_ads":2679,"gallery_picked":2680,"id":2716,"is_advertisement":44,"is_photostory":44,"is_pool":44,"multiportal":88,"view_type":88,"is_redirect":44,"keywords":2717,"lead":2676,"locked":13,"meta":2725,"parent_domain":88,"parent_id":88,"photostory_added":29,"pool_picked":88,"pool_under_photostory":28,"premium":44,"published":13,"published_at":2730,"quiz_picked":88,"recommended":44,"redirect_url":88,"self_url":2731,"show_quiz_cover":28,"slug":2732,"sponsored":28,"short_title":2733,"tags":2734,"tagsRaw":2735,"title":2726,"type":1176,"uid":2716,"updated_at":2738},73442,[2669],{"id":2670,"name":2671,"url":2672,"thumbnail":2672,"created_at":2673,"tags":91,"author":2674,"type":1129,"filename":2675,"description":2676,"750x750px":88,"160x90px":88,"365x225px":88,"100x100px":88,"760xautopx":88,"1200x675px":88,"gallery_id":2677},5369537,"Poświęcenie sztandaru Oddziału Polskiego Związku Hodowców Gołębi Pocztowych w Jarocinie","https://storage.googleapis.com/poludniowaoficyna-pbem/galleries/a0849d9f-83a1-416a-bafd-dc2cce6ca38a","2026-03-10 13:39:47","Maciej Biegński","a0849d9f-83a1-416a-bafd-dc2cce6ca38a","To moment, na który lokalna społeczność hodowców gołębi pocztowych czekała bardzo długo. Mimo ponad 100-letniej historii, Oddział Polskiego Związku Hodowców Gołębi Pocztowych w Jarocinie nie posiadał własnego sztandaru. W minioną sobotę, 7 marca, uroczyście nadrobiono tę zaległość.",59924,[122],{"id":88,"frequency":88},{"id":2677,"uid":2681,"title":2671,"slug":2682,"type":1639,"image_type":44,"description":91,"origin_portal":88,"created_at":2683,"updated_at":88,"created_by":413,"updated_by":88,"ads":28,"deleted":44,"ads_placement":44,"unauthorizedLikes":44,"main_image":2672,"attachments":2684},"3aAMS1Cz3ZZtofzeNT9D","poswiecenie-sztandaru-oddzialu-polskiego-zwiazku-hodowcow-golebi-pocztowyc
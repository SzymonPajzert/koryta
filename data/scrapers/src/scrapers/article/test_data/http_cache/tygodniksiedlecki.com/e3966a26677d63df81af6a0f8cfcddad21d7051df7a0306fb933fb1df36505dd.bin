<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
    function ShowGC() {
        $('#zaladujRC').load('static/captcha.html');
        $('#kontakt_1_field').css("height", "600px");
    }

    function SendForm() {
        $('#zaladujRC').load('static/captcha.html');
        $('#kontakt_1_field').css("height", "600px");
        if ($('#subject').val() == 11) {
            alert("Wybierz temat zgłoszenia");
            return false;
        }
        if (grecaptcha.getResponse() == "") {
            alert("Zaznacz że nie jesteś robotem");
            return false;
        } else {
            $('#contactform input[type=submit]').click();
        }
    }
</script>

ow_quiz_cover":42,"view_type":1018},{"id":1646,"name":60,"url":1647,"thumbnail":60,"created_at":1648,"tags":60,"author":1649,"type":999,"filename":1650,"description":60,"750x750px":1651,"160x90px":1652,"365x225px":1653,"100x100px":1654,"760xautopx":1655,"1200x675px":1656},[94],{"comments":16},{"size":98,"module":2225},[2226],{"name":986,"config":2227,"type":990,"articles":2228},{"mobile":12,"mobile_full":57,"mobile_intern":57,"type":1146,"query":2218,"limit":66,"skip":66,"category":2218},[2229],{"aid":2230,"attachments":2231,"category":2242,"category_id":62,"featured":16,"id":2243,"is_redirect":16,"lead":2244,"locked":66,"origin_domain":33,"parent_domain":57,"parent_id":57,"premium":16,"priority":392,"published":66,"published_at":2245,"recommended":16,"redirect_url":57,"short_title":2246,"slug":2247,"sponsored":42,"sub_title":2248,"title":2249,"uid":2243,"updated_at":2250,"stats":2251,"is_photostory":16,"is_advertisement":16,"is_pool":16,"show_quiz_cover":42,"view_type":1018},34409,{"id":2232,"name":60,"url":2233,"thumbnail":60,"created_at":2234,"tags":60,"author":1036,"type":999,"filename":2235,"description":60,"750x750px":2236,"160x90px":2237,"365x225px":2238,"100x100px":2239,"760xautopx":2240,"1200x675px":2241},51428,"https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/d17a85c1-663c-484b-abe6-ab7ef9259ef6","2026-03-07 08:49:48","d17a85c1-663c-484b-abe6-ab7ef9259ef6","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/4e7df8a7-5b9b-4362-b6a5-ee1e93a57b1a","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/2f8bd51c-678f-4542-9aa4-f61b9c300834","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/5b545947-f30b-4afa-bdf1-d1df53850d72","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/170b69c3-73d2-4c38-be26-276adcc2c36d","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/65bb2338-d8f9-489a-bdc6-d1f561c0d816","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/164c56ca-8222-47c2-a6bf-829de82f4e27",[94],"FRPmu1vX7ZhiiVRUSo91","Organizatorzy Jarocin Festiwal 2026 odkrywają kolejne karty! Do line-upu dołączają nowi artyści, w tym legendarna formacja, która zapowiedziała reaktywację. Obok weteranów na scenie pojawią się także obiecujące młode talenty.","2026-03-07 08:50:08","Wielki powrót legendy rocka po 30 latach","wielki-powrot-legendy-rocka-po-30-latach-wszystko-z-okazji-jarocin-festiwal","Pojawi się na Jarocin Festiwal","Wielki powrót legendy rocka po 30 latach. Pojawi się na Jarocin Festiwal","2026-03-07 10:11:37",{"comments":16},{"module":2253,"size":98},[2254],{"name":986,"config":2255,"type":990,"articles":2256},{"mobile":12,"mobile_full":57,"mobile_intern":57,"type":1146,"query":2218,"limit":66,"skip":65,"category":2218},[2257],{"aid":2258,"attachments":2259,"category":2270,"category_id":62,"featured":16,"id":2271,"is_redirect":16,"lead":2272,"locked":16,"origin_domain":33,"parent_domain":57,"parent_id":57,"premium":16,"priority":392,"published":66,"published_at":2273,"recommended":16,"redirect_url":57,"short_title":2274,"slug":2275,"sponsored":42,"sub_title":2276,"title":2277,"uid":2271,"updated_at":2278,"stats":2279,"is_photostory":16,"is_advertisement":16,"is_pool":16,"show_quiz_cover":42,"view_type":1018},34337,{"id":2260,"name":60,"url":2261,"thumbnail":60,"created_at":2262,"tags":60,"author":1649,"type":999,"filename":2263,"description":60,"750x750px":2264,"160x90px":2265,"365x225px":2266,"100x100px":2267,"760xautopx":2268,"1200x675px":2269},51350,"https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/08abe8f6-9008-4048-ad30-1e1fc7217cb6","2026-03-05 11:35:12","08abe8f6-9008-4048-ad30-1e1fc7217cb6","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/42fb9c40-5604-4ad8-98ac-07b67ce9ebad","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/7de9da58-f63b-4e4d-b3df-06e6bdd123d9","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/7c9de367-3770-4e43-b7fe-2ebffeee8493","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/c9f4858f-eb01-4cf6-bba7-03d79d51a7b5","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/ac614bc3-4c47-4bd9-82f9-05d8337daaf4","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/bd9929c4-1262-4725-b1e1-9bc6d8fdef62",[94],"2qUfiet5FagaF79k3bUm","Zapomnij o PRL-owskich kliszach. Dzień Kobiet to coś więcej niż goździk w celofanie - to święto zrodzone z determinacji i walki o lepsze jutro. Dowiedz się, dlaczego marzec jest tak wyjątkowy dla kobiet na całym świecie i sprawdź nasze zestawienie prezentów, które w tym roku przełamią schematy.","2026-03-05 15:00:00","Tulipany to dopiero początek","tulipany-to-dopiero-poczatek-zobacz-czego-naprawde-pragna-kobiety-w-2026-roku","Zobacz, jaki prezent chcą dostać kobiety","Tulipany to dopiero początek. Zobacz, jaki prezent chcą dostać kobiety","2026-03-05 15:20:37",{"comments":66},{"module":2281,"size":98},[2282],{"name":986,"config":2283,"type":990,"articles":2284},{"mobile":12,"mobile_full":57,"mobile_intern":57,"type":1146,"query":2218,"limit":66,"skip":98,"category":2218},[2285],{"aid":2286,"attachments":2287,"category":2299,"category_id":62,"featured":16,"id":2300,"is_redirect":16,"lead":2301,"locked":16,"origin_domain":33,"parent_domain":57,"parent_id":57,"premium":16,"priority":392,"published":66,"published_at":2302,"recommended":16,"redirect_url":57,"short_title":2303,"slug":2304,"sponsored":42,"sub_title":2305,"title":2306,"uid":2300,"updated_at":2307,"stats":2308,"is_photostory":16,"is_advertisement":16,"is_pool":16,"show_quiz_cover":42,"view_type":1018},33932,{"id":2288,"name":60,"url":2289,"thumbnail":60,"created_at":2290,"tags":60,"author":2291,"type":999,"filename":2292,"description":60,"750x750px":2293,"160x90px":2294,"365x225px":2295,"100x100px":2296,"760xautopx":2297,"1200x675px":2298},50876,"https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/c17d9fea-8f44-462b-8723-871c5e5cf2eb","2026-02-21 16:01:54","Miasto Poznań","c17d9fea-8f44-462b-8723-871c5e5cf2eb","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/afe8e230-9712-4c7b-9248-3414d59ad2fe","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/2bb5e40d-8329-4d6d-b04c-dbbaf62c6647","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/72a32ad3-f8a1-448e-aafb-85b7ca83a5a5","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/9ccc58e1-7602-407b-8fa1-a705e4c9a092","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/19e48d08-70d7-4e5f-9b51-feb637ece933","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/85b609b4-6b63-4f30-99d8-75f9a031affd",[94],"0sDGn40eD6cxmDmiDCVh","Chcesz zobaczyć Egipt sprzed stu lat? Teraz to możliwe w Poznaniu dzięki wystawie! Gdzie się odbywa? Jakie są ceny biletów?","2026-02-21 19:00:00","Wyjątkowa wystawa w Poznaniu","zobacz-egipt-sprzed-100-lat-w-poznaniu","Zobacz Egipt sprzed wieku","Zobacz Egipt sprzed 100 lat w Poznaniu","2026-02-21 16:02:20",{"comments":16},{"config":2310,"id":289,"variant":2312,"column":2313},{"color":2311,"background":968},"#ff00ff",[160],[2314],{"size":160,"module":2315},[2316],{"name":1708,"config":2317,"type":1710},{"title":2318,"link":231,"alternativeView":42},"Ona w wielkopolsce",{"id":105,"column":2320,"config":2411,"variant":2413},[2321,2355,2386],{"module":2322,"size":141},[2323],{"name":986,"config":2324,"type":990,"articles":2326},{"mobile":12,"mobile_full":42,"type":1146,"category":2325,"query":2325,"skip":16,"limit":66},"category:array-contains:kobieta-i-dziecko",[2327],{"aid":2328,"attachments":2329,"category":2341,"category_id":229,"featured":16,"id":2342,"is_redirect":16,"lead":2343,"locked":16,"origin_domain":2344,"parent_domain":2344,"parent_id":2345,"premium":16,"priority":392,"published":66,"published_at":2346,"recommended":16,"redirect_url":2347,"short_title":2348,"slug":2349,"sponsored":42,"sub_title":2350,"title":2351,"uid":2342,"updated_at":2352,"stats":2353,"is_photostory":16,"is_advertisement":16,"is_pool":16,"show_quiz_cover":42,"view_type":2354},34388,{"id":2330,"name":60,"url":2331,"thumbnail":60,"created_at":2332,"tags":60,"author":1500,"type":999,"filename":2333,"description":2334,"750x750px":2335,"160x90px":2336,"365x225px":2337,"100x100px":2338,"760xautopx":2339,"1200x675px":2340},51407,"https://storage.googleapis.com/poludniowaoficyna-pbem/magazynona/articles/image/950aeabe-0e09-4083-9809-261d8661b89e","2026-03-06 14:17:35","950aeabe-0e09-4083-9809-261d8661b89e","Domowe sposoby na wybielanie są bezpieczne nawet dla najdelikatniejszych firanek z tiulu czy koronki.","https://storage.googleapis.com/poludniowaoficyna-pbem/magazynona/articles/image/b77b7f09-90f7-47cd-8104-34d6b43249cf","https://storage.googleapis.com/poludniowaoficyna-pbem/magazynona/articles/image/d9d067f4-0130-4c66-8604-24f27f37b78b","https://storage.googleapis.com/poludniowaoficyna-pbem/magazynona/articles/image/9e210675-f372-4309-832a-7d9dd912ede8","https://storage.googleapis.com/poludniowaoficyna-pbem/magazynona/articles/image/8eae17df-f029-4b79-8685-bd3c16cff3eb","https://storage.googleapis.com/poludniowaoficyna-pbem/magazynona/articles/image/e71fae02-614a-4126-9b5f-c83c1aa69f44","https://storage.googleapis.com/poludniowaoficyna-pbem/magazynona/articles/image/b89cd068-50a0-42de-bd83-e5af595a81a6",[226],"axFkKlPy0uxGB0gNcYln","Twoje firanki straciły dawny blask i zamiast zdobić okno, straszą szarością? Mamy sposób, by były znowu śnieżno białe. Nie musisz kupować żadnych drogich produktów, najlepsze środki masz w swojej kuchni. Babcia Zosia pierze tak firany od lat.","magazynona.pl","HBVZYwKdUaYVviDiGrbv","2026-03-06 14:25:00","https://magazynona.pl/ona-radzi/jak-wybielic-firanki-domowymi-sposobami-4-tanie-metody-2026/HBVZYwKdUaYVviDiGrbv","Dodaj to do prania firanek, a będą lśniąco białe","jak-wybielic-firanki-domowymi-sposobami-4-tanie-metody-2026","Triki Babci Zosi","Dodaj to do prania firanek, a będą lśniąco białe. Triki Babci Zosi","2026-03-06 14:22:00",{"comments":16},"link",{"size":141,"module":2356},[2357],{"type":990,"config":2358,"name":986,"articles":2359},{"category":2325,"limit":66,"type":1146,"query":2325,"skip":66,"mobile":12},[2360],{"aid":2361,"attachments":2362,"category":2374,"category_id":229,"featured":16,"id":2375,"is_redirect":16,"lead":2376,"locked":16,"origin_domain":2344,"parent_domain":2344,"parent_id":2377,"premium":16,"priority":392,"published":66,"published_at":2378,"recommended":16,"redirect_url":2379,"short_title":2380,"slug":2381,"sponsored":42,"sub_title":2382,"title":2383,"uid":2375,"updated_at":2384,"stats":2385,"is_photostory":16,"is_advertisement":16,"is_pool":16,"show_quiz_cover":42,"view_type":2354},34322,{"id":2363,"name":60,"url":2364,"thumbnail":60,"created_at":2365,"tags":60,"author":1500,"type":999,"filename":2366,"description":2367,"750x750px":2368,"160x90px":2369,"365x225px":2370,"100x100px":2371,"760xautopx":2372,"1200x675px":2373},51335,"https://storage.googleapis.com/poludniowaoficyna-pbem/magazynona/articles/image/09b50782-89f2-4e07-8f4c-741a024b6a68","2026-03-04 19:40:26","09b50782-89f2-4e07-8f4c-741a024b6a68","Teraz Twoje kwiaty \"straszą\" po zimowaniu, ale będą przepiękne, jeśli zastosujesz nasze rady","https://storage.googleapis.com/poludniowaoficyna-pbem/magazynona/articles/image/372cc1a2-220e-4198-bc78-2bc7a8556adb","https://storage.googleapis.com/poludniowaoficyna-pbem/magazynona/articles/image/898ad9db-b453-446d-be4f-985c2ac07041","https://storage.googleapis.com/poludniowaoficyna-pbem/magazynona/articles/image/1d851810-c902-450e-9026-d314b98cc509","https://storage.googleapis.com/poludniowaoficyna-pbem/magazynona/articles/image/414b626e-ff11-45d9-931d-397de25ee0dc","https://storage.googleapis.com/poludniowaoficyna-pbem/magazynona/articles/image/2a89ddca-d340-4814-9bbb-877663709a22","https://storage.googleapis.com/poludniowaoficyna-pbem/magazynona/articles/image/200fdaad-ea4c-4675-93f7-d8aa403102f0",[226],"qy21Ib2uV3GrapLi7V81","Twoje pelargonie lub oleandry po zimie wyglądają jak suche patyki? Nie wyrzucaj ich! Poznaj 3 sprawdzone kroki, które przywrócą życie roślinie wyjętej z ciemnej piwnicy. Sprawdź, jak przeprowadzić domową reanimację kwiatów.","DQ9o7NDC1FXRbHqyKGct","2026-03-04 20:00:00","https://magazynona.pl/blog/ona-w-ogrodzie/jak-uratowac-kwiaty-po-zimowaniu-w-piwnicy-3-proste-kroki/DQ9o7NDC1FXRbHqyKGct","Jak uratować kwiaty po zimowaniu","jak-uratowac-kwiaty-po-zimowaniu-w-piwnicy-3-proste-kroki","3 proste kroki","Jak uratować kwiaty po zimowaniu? 3 proste kroki, które sprawią, że odżyją w oczach","2026-03-04 19:50:48",{"comments":16},{"module":2387,"size":141},[2388],{"type":990,"config":2389,"name":986,"articles":2390},{"mobile":12,"category":2325,"query":2325,"skip":65,"type":1146,"limit":66},[2391],{"aid":2392,"attachments":2393,"category":2404,"category_id":229,"featured":16,"id":2405,"is_redirect":16,"lead":2406,"locked":16,"origin_domain":33,"parent_domain":57,"parent_id":57,"premium":16,"priority":392,"published":66,"published_at":2407,"recommended":16,"redirect_url":57,"short_title":2408,"slug":2409,"sponsored":12,"sub_title":57,"title":2408,"uid":2405,"updated_at":2407,"stats":2410,"is_photostory":16,"is_advertisement":16,"is_pool":16,"show_quiz_cover":42,"view_type":1018},34256,{"id":2394,"name":60,"url":2395,"thumbnail":60,"created_at":2396,"tags":60,"author":1892,"type":999,"filename":2397,"description":60,"750x750px":2398,"160x90px":2399,"365x225px":2400,"100x100px":2401,"760xautopx":2402,"1200x675px":2403},51263,"https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/b5d869a2-8e52-45d4-b76d-e3cd974773e9","2026-03-03 09:31:14","b5d869a2-8e52-45d4-b76d-e3cd974773e9","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/bd160eb1-3f4b-4e60-9ed8-125470ebc2d8","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/c1ceae83-1534-48ae-b1eb-2945c15ba3e5","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/df666220-af99-450c-a992-391cf6a398a2","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/f71fc579-de73-4b74-80f5-fb6338162f6e","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/dfabf30f-8795-4282-ae73-c13cebb1c58a","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/2149fa88-811e-4b39-b65e-dadf2f8677f0",[226],"P8SI4NzT0WKNbXYKE6tc","Nadwrażliwość skóry po powtarzanej depilacji jest częstym problemem, który może dotyczyć zarówno kobiet, jak i mężczyzn. Objawia się zaczerwienieniem, pieczeniem, drobnymi grudkami, nierównościami skóry oraz zwiększoną podatnością na podrażnienia. Choć depilacja jest zabiegiem powszechnym, jej regularne powtarzanie może prowadzić do przewlekłych zmian w strukturze skóry. Zrozumienie mechanizmów, które odpowiadają za nadwrażliwość, pozwala lepiej chronić skórę i wspierać jej regenerację.","2026-03-03 09:37:04","Nadwrażliwość skóry po powtarzanej depilacji – mechanizmy i skutki","nadwrazliwosc-skory-po-powtarzanej-depilacji-mechanizmy-i-skutki",{"comments":16},{"color":969,"background":2412},"#FFE0FF",[141,141,141],{"id":245,"config":2415,"variant":2416,"column":2417},{"background":968,"color":969},[160],[2418],{"size":160,"module":2419},[2420],{"name":1708,"config":2421,"type":1710},{"title":159,"link":161,"alternativeView":42},{"id":132,"config":2423,"variant":2424,"column":2425},{"background":968,"color":969},[141,141,141],[2426,2457,2486],{"size":141,"module":2427},[2428],{"name":986,"config":2429,"type":990,"articles":2431},{"mobile":12,"mobile_full":57,"mobile_intern":57,"type":1146,"query":2430,"limit":66,"skip":16,"category":2430},"category:array-contains:historia",[2432],{"aid":2433,"attachments":2434,"category":2447,"category_id":158,"featured":16,"id":2448,"is_redirect":16,"lead":2449,"locked":66,"origin_domain":33,"parent_domain":57,"parent_id":57,"premium":16,"priority":392,"published":66,"published_at":2450,"recommended":16,"redirect_url":57,"short_title":2451,"slug":2452,"sponsored":42,"sub_title":2453,"title":2454,"uid":2448,"updated_at":2455,"stats":2456,"is_photostory":16,"is_advertisement":16,"is_pool":16,"show_quiz_cover":42,"view_type":1018},34193,{"id":2435,"name":60,"url":2436,"thumbnail":60,"created_at":2437,"tags":60,"author":2438,"type":999,"filename":2439,"description":2440,"750x750px":2441,"160x90px":2442,"365x225px":2443,"100x100px":2444,"760xautopx":2445,"1200x675px":2446},51194,"https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/a146055f-1c5e-47bd-8f62-3cebb12e3267","2026-03-01 10:44:06","Andrzej Waruszewski","a146055f-1c5e-47bd-8f62-3cebb12e3267","W Brudzewku znajdują się dwa schrony bojowe z 1939 roku","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/32946780-acc2-4cf1-ab74-726ddbaa16c2","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/eb2e7913-0653-4630-a57c-896454304ec4","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/66dda18a-7e2d-42f7-95a7-efc3a66a7f26","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/d243363b-ab7f-4c2f-8e76-a082493a1e1b","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/3a9c1548-1d95-4c05-9c5a-f4f3f767f0de","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/b71b9db3-4374-4f3a-a074-9b7ef6a37164",[155],"u0zlhgKxwKzGudLWYmkl","Jeden położony jest w zakolu rzeki Prosny, drugi tuż przy drodze wojewódzkiej 442 - prowadzącej z Kalisza do Wrześni. Wybudowane w 1939 roku schrony bojowe ominął wojenny front. Dzięki temu przetrwały do dziś i stanowią historyczną atrakcję  Wielkopolski.","2026-03-01 19:02:00","Ominął je wojenny front. Stanowią historyczną atrakcję","ominal-je-wojenny-front-stanowia-historyczna-atrakcje","Miały stanowić umocnienie linii obronnej","Ominął je wojenny front. Stanowią atrakcję Wielkopolski","2026-03-01 14:52:57",{"comments":16},{"size":141,"module":2458},[2459],{"name":986,"config":2460,"type":990,"articles":2461},{"mobile":12,"mobile_full":57,"mobile_intern":57,"type":1146,"query":2430,"limit":66,"skip":66,"category":2430},[2462],{"aid":2463,"attachments":2464,"category":2476,"category_id":158,"featured":16,"id":2477,"is_redirect":16,"lead":2478,"locked":16,"origin_domain":33,"parent_domain":57,"parent_id":57,"premium":16,"priority":392,"published":66,"published_at":2479,"recommended":16,"redirect_url":57,"short_title":2480,"slug":2481,"sponsored":42,"sub_title":2482,"title":2483,"uid":2477,"updated_at":2484,"stats":2485,"is_photostory":16,"is_advertisement":16,"is_pool":16,"show_quiz_cover":42,"view_type":1018},32162,{"id":2465,"name":60,"url":2466,"thumbnail":60,"created_at":2467,"tags":60,"author":2468,"type":999,"filename":2469,"description":60,"750x750px":2470,"160x90px":2471,"365x225px":2472,"100x100px":2473,"760xautopx":2474,"1200x675px":2475},48896,"https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/9c51b203-7684-4fda-bcff-49e5d243aee8","2026-01-02 14:01:14","G.Dembiński","9c51b203-7684-4fda-bcff-49e5d243aee8","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/b4e1f1fd-23fa-46b6-b86a-c80761bd034b","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/e6ad9acf-e402-4c9e-8cb1-a9fd4f14a863","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/978ac990-575a-4088-bcd4-73a111f9e7fb","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/47a2746d-8063-4e59-86aa-4349452a1abf","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/4698fc53-8fb6-4aa8-acc3-dbabd83ef764","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/43301f83-b197-49b3-baea-71c62d6beb91",[155],"255BvyNIam6ARWpAb3DQ","Rok 2026 ogłoszono Rokiem Bohaterów Poznańskiego Czerwca 1956 r. Z okazji 70. rocznicy dramatycznych wydarzeń w Poznaniu zaplanowano liczne inicjatywy, których celem jest upamiętnienie bohaterów tamtych dni.","2026-01-04 15:00:00","70. rocznica Poznańskiego Czerwca 1956","70-rocznica-poznanskiego-czerwca-1956-miasto-uczci-swoich-bohaterow","Miasto uczci bohaterów","70. rocznica Poznańskiego Czerwca 1956. Miasto uczci bohaterów","2026-01-04 10:48:33",{"comments":16},{"size":141,"module":2487},[2488],{"name":986,"config":2489,"type":990,"articles":2490},{"mobile":12,"mobile_full":57,"mobile_intern":57,"type":1146,"query":2430,"limit":66,"skip":65,"category":2430},[2491],{"aid":2492,"attachments":2493,"category":2505,"category_id":158,"featured":16,"id":2506,"is_redirect":16,"lead":2507,"locked":66,"origin_domain":33,"parent_domain":57,"parent_id":57,"premium":16,"priority":392,"published":66,"published_at":2508,"recommended":16,"redirect_url":57,"short_title":2509,"slug":2510,"sponsored":42,"sub_title":2511,"title":2512,"uid":2506,"updated_at":2508,"stats":2513,"is_photostory":16,"is_advertisement":16,"is_pool":16,"show_quiz_cover":42,"view_type":1018},31934,{"id":2494,"name":60,"url":2495,"thumbnail":60,"created_at":2496,"tags":60,"author":2497,"type":999,"filename":2498,"description":60,"750x750px":2499,"160x90px":2500,"365x225px":2501,"100x100px":2502,"760xautopx":2503,"1200x675px":2504},48647,"https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/71de1fc9-b79e-47a8-a1a8-dacfd1d4aea9","2025-12-27 16:51:37","Urząd Marszałkowski Województwa Wielkopolskiego","71de1fc9-b79e-47a8-a1a8-dacfd1d4aea9","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/2565ee76-fdc7-4fea-8031-a441d1a5515e","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/80a553d5-0417-47f9-a7df-fd1c168ec454","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/a793a309-5dd6-4cae-9ee1-b2b909e5e4f9","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/e8c6e976-e9d0-4d9e-ab04-7a85a45e39ac","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/0d52049d-33cf-451f-8445-5bc57a5cd3ca","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/afe6c516-6bf0-48ac-b0d4-9b3d7e69e17f",[155],"pxXlKSJgrncRAN7vXP5c","Plac Wolności w Poznaniu na kilka godzin zamienił się w tętniące życiem centrum historii. Z okazji 107. rocznicy wybuchu zwycięskiego zrywu Wielkopolan, otwarto Miasteczko Powstańcze. Mieszkańcy stolicy regionu i turyści mogą przenieść się w czasy powstania, biorąc udział w wydarzeniach łączących edukację historyczną, rozrywkę i wspólne świętowanie.","2025-12-27 16:54:11","Poznaniacy i turyści odwiedzają Miasteczko Powstańcze","poznaniacy-i-turysci-odwiedzaja-miasteczko-powstancze-na-final-marsylianka-wielkopolska","Na finał Marsylianka Wielkopolska","Poznaniacy i turyści odwiedzają Miasteczko Powstańcze. Na finał Marsylianka Wielkopolska",{"comments":16},{"id":311,"config":2515,"variant":2516,"column":2517},{"background":968,"color":969},[160],[2518],{"size":160,"module":2519},[2520],{"name":1022,"config":2521,"type":1025},{"code":2522},"\u003Cp>\u003Cstrong>Wiadomości z Wielkopolski\u003C/strong>\u003C/p>\n\u003Cp>Cieszymy się, że tu jesteś. Z pomocą naszego serwisu dotrą do Ciebie najświeższe wiadomości z \u003Cstrong>Wielkopolski z ostatniej chwili.\u003C/strong>\u003C/p>\n\u003Cp>Chcesz wiedzieć, co dzieje się w stolicy naszego wojew&oacute;dztwa? U nas czekają na Ciebie \u003Cstrong>poznańskie wydarzenia. Dzisiaj\u003C/strong> z pewnością dzieje się coś, o czym warto usłyszeć z pierwszej ręki. Zesp&oacute;ł doświadczonych dziennikarzy zapewni Ci bieżące \u003Cstrong>wiadomości z Poznania \u003C/strong>i okolic.\u003C/p>\n\u003Cp>Czytelnikom proponujemy rzetelne informacje z regionu. Znajdziesz u nas między innymi \u003Cstrong>dzisiejsze aktualności z Konina\u003C/strong>. Dowiesz się, jakie \u003Cstrong>wiadomości z ostatniej chwili z Leszna\u003C/strong> frapują mieszkańc&oacute;w. Opowiemy Ci o kluczowych \u003Cstrong>faktach pilskich\u003C/strong>, czy \u003Cstrong>dzisiejszych wiadomościach z Ostrowa Wielkopolskiego\u003C/strong>. Z kolei \u003Cstrong>najnowsze wiadomości z Gniezna \u003C/strong>pozwolą Ci być na bieżąco z wydarzeniami z pierwszej stolicy Polski.\u003C/p>",["Reactive",2524],{},["Set"],["ShallowReactive",2527],{"staticPageData":57,"dkjP2gpUww":57,"homepage":57},"/",["Reactive",2530],{"main":2531},{"ads":12,"user":57,"latest":2532,"weather":869,"dictionary":394,"referer":42,"settings":7,"variables":57,"commercials":962,"adsInitialized":42,"currentView":542,"placements":436,"categories":83,"staticPages":420,"galleryCount":57,"noImg":2533,"zprInitialized":42,"galleryAdDisplayed":42,"classifiedsCategories":57,"publicFKey":2534,"metaDefaults":2535,"commercialsInView":2592},[],"/noimg.png","",{"title":13,"meta":2536,"htmlAttrs":2568,"link":2570,"script":2587},[2537,2539,2541,2543,2545,2547,2549,2551,2553,2556,2559,2561,2564,2566],{"name":2538,"content":13},"author",{"name":2540,"content":13},"name",{"name":2542,"content":47},"description",{"name":2544,"content":23},"keywords",{"name":2546,"content":13},"og:title",{"name":2548,"content":47},"og:description",{"name":2550,"content":13},"og:site_name",{"name":2552,"content":8},"og:image",{"name":2554,"content":2555},"og:type","website",{"name":2557,"content":2558},"og:url","https://zwielkopolski24.pl",{"name":2560,"content":13},"twitter:title",{"name":2562,"content":2563},"twitter:card","summary_large_image",{"name":2565,"content":47},"twitter:description",{"name":2567,"content":8},"twitter:image",{"lang":2569},"pl",[2571,2574,2577,2582,2585],{"rel":2572,"href":8,"as":2573},"preload","image",{"rel":2575,"type":2576,"href":10},"icon","image/png",{"rel":2578,"type":2579,"title":2580,"href":2581},"alternate","application/rss+xml","Kanał RSS - zWielkopolski24: Wiadomości z Wielkopolski. Z ostatniej chwili, dzisiaj w Wielkopolsce","https://zwielkopolski24.pl/rss.xml",{"rel":2583,"href":2584},"stylesheet","/fonts/OpenSans.css?v3",{"rel":2572,"as":2586,"href":2584},"style",[2588],{"key":2589,"type":2590,"innerHTML":2591},"schema-organization","application/ld+json","\n              {\n                \"@context\": \"https://schema.org\",\n                \"@type\": \"Organization\",\n                \"url\": \"https://zwielkopolski24.pl\",\n                \"logo\": \"https://static.zpleszewa.pl/attachments/b8018545-ce46-428e-8cb8-31b9e8c50296\"\n              }        \n            ",[]]</script>

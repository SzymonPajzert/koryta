ogleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/e7f7d61b-acd7-4f0f-bce2-74288f79a7cf",[178],"X6XASauqJycYCdsNH2zz","Dyrektor Okręgowy Służby Więziennej w Poznaniu ogłosił szeroko zakrojoną rekrutację na stanowiska medyczne. Praca czeka w pięciu jednostkach na terenie Wielkopolski i Lubuskiego. Na kandydatów czekają nie tylko stabilne zarobki przekraczające 5 900 zł netto na start, ale także potężny pakiet socjalny, w tym dopłaty do mieszkania oraz przywileje emerytalne.","2026-03-01 12:00:00","Praca w Służbie Więziennej","na-starcie-oferuja-prawie-6-tys-zl-na-reke-szukaja-pracownikow-w-wielkopolsce-i-lubuskiem","Nabór dla medyków w Wielkopolsce i Lubuskiem","Na starcie oferują prawie 6 tys. zł na rękę. Szukają pracowników w Wielkopolsce i Lubuskiem","2026-03-01 09:52:20",{"comments":16},{"module":1849,"size":98},[1850],{"name":975,"config":1851,"type":977},{"slot_id":577,"slot_view":542},{"size":98,"module":1853},[1854],{"config":1855,"name":986,"type":990,"articles":1856},{"type":1146,"skip":66,"mobile":12,"limit":66,"category":1822,"query":1822},[1857],{"aid":1858,"attachments":1859,"category":1871,"category_id":181,"featured":16,"id":1872,"is_redirect":16,"lead":1873,"locked":66,"origin_domain":33,"parent_domain":57,"parent_id":57,"premium":16,"priority":392,"published":66,"published_at":1874,"recommended":16,"redirect_url":57,"short_title":1875,"slug":1876,"sponsored":42,"sub_title":1877,"title":1878,"uid":1872,"updated_at":1879,"stats":1880,"is_photostory":16,"is_advertisement":16,"is_pool":16,"show_quiz_cover":42,"view_type":1018},34094,{"id":1860,"name":60,"url":1861,"thumbnail":60,"created_at":1862,"tags":60,"author":1500,"type":999,"filename":1863,"description":1864,"750x750px":1865,"160x90px":1866,"365x225px":1867,"100x100px":1868,"760xautopx":1869,"1200x675px":1870},51062,"https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/a8a7edef-c80d-4be1-b637-7a2d1e7cd6bf","2026-02-26 12:49:59","a8a7edef-c80d-4be1-b637-7a2d1e7cd6bf","Od 1 marca 2026 roku wzrosną limity dodatkowego przychodu dla wcześniejszych emerytów i rencistów.","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/8055b7b7-3e55-40ff-a1f8-54c215fed507","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/25caa1ba-1e6c-49cd-afc8-e8e44da605fa","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/d65363c7-6252-41ae-bf76-c8c5109c40f2","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/c3d186fc-8271-464e-b637-4a4151bf0868","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/455f717f-d9c0-4e58-a545-d4d374163698","https://storage.googleapis.com/poludniowaoficyna-pbem/zwielkopolski24/articles/image/989f1ff5-ffb9-4400-807c-eeb2adfeb465",[178],"HRVa5JhWDo9ZtdMfOByh","Dorabianie do emerytury to dla wielu osób sposób na aktywność i podreperowanie budżetu, ale od 1 marca warto trzymać rękę na pulsie. Zaczną obowiązywać nowe limity, których przekroczenie będzie skutkować zmniejszeniem lub nawet zawieszeniem wypłaty emerytury i renty.","2026-02-27 09:00:00","Ważne zmiany dla dorabiających emerytów i rencistów","wazne-zmiany-dla-dorabiajacych-emerytow-i-rencistow-od-1-marca-nowe-limity","Od 1 marca zaczną obowiązywać nowe limity","Ważne zmiany dla dorabiających emerytów i rencistów. Od 1 marca nowe limity","2026-02-27 16:25:48",{"comments":16},{"module":1882,"size":98},[1883],{"name":986,"type":990,"config":1884,"articles":1885},{"query":1822,"mobile":12,"type":1146,"category":1822,"limit":66,"skip":65},[1886],{"aid":1887,"attachments":1888,"category":1900,"category_id":181,"featured":16,"id":1901,"is_redirect":16,"lead":1902,"locked":16,"origin_domain":33,"parent_domain":57,"parent_id":57,"premium":16,"priority":392,"published":66,"published_at":1903,"recommended":16,"redirect_url":57,"short_title":1904,"slug":1905,"sponsored":42,"sub_title":57,"title":1904,
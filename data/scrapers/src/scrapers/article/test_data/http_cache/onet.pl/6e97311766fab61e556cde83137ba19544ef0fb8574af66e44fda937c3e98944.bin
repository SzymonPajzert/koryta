ęki takim produkcjom jak \"Miasteczko Twin Peaks\" i \"Z archiwum X\". Te seriale były śledzone przez widownie na całym świecie, dziś uznawane są za kultowe. Najpopularniejsze produkcje telewizyjne gromadzą miliony widzów, a jakością produkcji i dbałością o szczegóły w niczym nie ustępują filmom kinowym."},"title":{"text":"Seriale"},"pinned":false,"namespaceId":"TfsuA1562566747336","share_uuid":"55d759b5-c313-48df-ae8f-9acbf1487b34","uuid":"f8edf4e1-d9e7-4fab-ae24-094645d78107","serviceUuid":"bf78661f-61f7-40de-becc-94f65255b9ae","published":"2022-01-25T12:08:35.525Z","modified":"2022-01-25T12:08:37.313Z"},{"content-type":"default","image":{},"type":{"code":"article"},"link":{"href":"https://kultura.onet.pl/"},"title":{"text":"Kultura"},"pinned":false,"namespaceId":"TfsuA1562566747336","share_uuid":"08535340-4b2e-4ac7-b0a4-34a784876aa2","serviceUuid":"bf78661f-61f7-40de-becc-94f65255b9ae","published":"2018-07-10T09:49:37.237632Z","modified":"2018-07-10T12:01:24.255Z"}],"title":"Więcej","uuid":"1dec06f4-036b-4c04-ae5f-4d858413cb6f","version":1643112593114,"last_modification":"2022-01-25T12:09:53.927Z"},"hotLinks":{"entries":[],"title":"Gorące","uuid":"aadfb945-8ac4-4839-89d7-040367b42372","version":18081597,"last_modification":"2019-08-30T09:33:37.384Z"},"submenu":{"entries":[],"title":"Lifestyle - kategorie","uuid":"bae96fb3-7c56-4b6e-ae06-e0b8a64d25b9","version":1745486828372,"last_modification":"2025-04-24T09:27:08.000Z"}},"importantMultisourceRequest":false},null,null,{"isLoading":false,"isError":false,"title":"O tym się mówi","entries":[{"pinned":false,"sources":[{"uuid":"13f2a8f0-421e-4c00-b7c4-8c7174f6d322","name":"Onet"}],"link":{"href":"https://wiadomosci.onet.pl/kraj/ireneusz-ras-komentuje-spor-o-safe-karkolomna-debata/h2wdtpd"},"flags":["exclude_from_author_page","mediamatch_ai_assistant","newsroom24","story_ai_assistant_semantic_taxonomies","story_ai_assistant_text_improvement","story_intext_assistant","ai_supported"],"variants":[{"name":"teaser_superaure
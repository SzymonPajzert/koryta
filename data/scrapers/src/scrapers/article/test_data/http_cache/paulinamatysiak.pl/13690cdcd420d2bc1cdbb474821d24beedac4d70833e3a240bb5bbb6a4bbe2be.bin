<link rel="stylesheet" id="ea11y-widget-fonts-css" href="https://paulinamatysiak.pl/wp-content/plugins/pojo-accessibility/assets/build/fonts.css?ver=4.1.0" media="all">
<link rel="stylesheet" id="ea11y-skip-link-css" href="https://paulinamatysiak.pl/wp-content/plugins/pojo-accessibility/assets/build/skip-link.css?ver=4.1.0" media="all">
<link rel="stylesheet" id="parent-style-css" href="https://paulinamatysiak.pl/wp-content/themes/kadence/style.css" media="all">
<link rel="stylesheet" id="kadence-global-css" href="https://paulinamatysiak.pl/wp-content/themes/kadence/assets/css/global.min.css?ver=1.4.5" media="all">
<style id="kadence-global-inline-css">
/* Kadence Base CSS */
:root{--global-palette1:#B82105;--global-palette2:#8F1A04;--global-palette3:#D24A2E;--global-palette4:#2B1E1A;--global-palette5:#4A342E;--global-palette6:#6B5A54;--global-palette7:#9A8C87;--global-palette8:#EDE6E3;--global-palette9:#F9F7F6;--global-palette10:#FFFFFF;--global-palette11:#2F6F5A;--global-palette12:#2E5E8A;--global-palette13:#B82105;--global-palette14:#C84A2C;--global-palette15:#E2A03A;--global-palette9rgb:249, 247, 246;--global-palette-highlight:var(--global-palette13);--global-palette-highlight-alt:var(--global-palette13);--global-palette-highlight-alt2:var(--global-palette9);--global-palette-btn-bg:var(--global-palette13);--global-palette-btn-bg-hover:var(--global-palette9);--global-palette-btn:var(--global-palette9);--global-palette-btn-hover:var(--global-palette9);--global-palette-btn-sec-bg:var(--global-palette7);--global-palette-btn-sec-bg-hover:var(--global-palette2);--global-palette-btn-sec:var(--global-palette3);--global-palette-btn-sec-hover:var(--global-palette9);--global-body-font-family:Poppins, sans-serif;--global-heading-font-family:Poppins, var(--global-fallback-font);--global-primary-nav-font-family:Poppins, var(--global-fallback-font);--global-fallback-font:sans-serif;--global-display-fallback-font:sans-serif;--global-content-width:1290px;--global-content-wide-width:calc(1290px + 230px);--global-content-narrow-width:842px;--global-content-edge-padding:1.5rem;--global-content-boxed-padding:2rem;--global-calc-content-width:calc(1290px - var(--global-content-edge-padding) - var(--global-content-edge-padding) );--wp--style--global--content-size:var(--global-calc-content-width);}.wp-site-blocks{--global-vw:calc( 100vw - ( 0.5 * var(--scrollbar-offset)));}body{background:var(--global-palette9);-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;}body, input, select, optgroup, textarea{font-style:normal;font-weight:normal;font-size:16px;line-height:1.6;font-family:var(--global-body-font-family);color:#000000;}.content-bg, body.content-style-unboxed .site{background:var(--global-palette9);}h1,h2,h3,h4,h5,h6{font-family:var(--global-heading-font-family);}h1{font-style:normal;font-weight:800;font-size:55px;line-height:1.5;color:var(--global-palette13);}h2{font-style:normal;font-weight:700;font-size:35px;line-height:1.1;color:var(--global-palette5);}h3{font-style:normal;font-weight:normal;font-size:35px;line-height:1.3;color:var(--global-palette4);}h4{font-style:normal;font-weight:normal;font-size:25px;line-height:1.5;color:var(--global-palette5);}h5{font-style:normal;font-weight:600;font-size:20px;line-height:1.5;color:var(--global-palette5);}h6{font-style:normal;font-weight:200;font-size:18px;line-height:1.5;color:var(--global-palette5);}.entry-hero h1{font-style:normal;}@media all and (max-width: 1024px){h1{font-size:45px;}h2{font-size:40px;}h3{font-size:25px;}}@media all and (max-width: 767px){h1{font-size:35px;}h2{font-size:40px;}}.entry-hero .kadence-breadcrumbs{max-width:1290px;}.site-container, .site-header-row-layout-contained, .site-footer-row-layout-contained, .entry-hero-layout-contained, .comments-area, .alignfull > .wp-block-cover__inner-container, .alignwide > .wp-block-cover__inner-container{max-width:var(--global-content-width);}.content-width-narrow .content-container.site-container, .content-width-narrow .hero-container.site-container{max-width:var(--global-content-narrow-width);}@media all and (min-width: 1520px){.wp-site-blocks .content-container  .alignwide{margin-left:-115px;margin-right:-115px;width:unset;max-width:unset;}}@media all and (min-width: 1102px){.content-width-narrow .wp-site-blocks .content-container .alignwide{margin-left:-130px;margin-right:-130px;width:unset;max-width:unset;}}.content-style-boxed .wp-site-blocks .entry-content .alignwide{margin-left:calc( -1 * var( --global-content-boxed-padding ) );margin-right:calc( -1 * var( --global-content-boxed-padding ) );}.content-area{margin-top:3rem;margin-bottom:3rem;}@media all and (max-width: 1024px){.co
":1962,"updated_at":1989},75199,[1949],{"id":1950,"name":83,"url":1951,"thumbnail":83,"created_at":1952,"tags":83,"author":1220,"type":980,"filename":1953,"description":1274,"750x750px":1954,"160x90px":1955,"365x225px":1956,"100x100px":1957,"760xautopx":1958,"1200x675px":1959,"article_id":1947},300211,"https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/3721918b-779e-46f9-b955-c70ee680fee7","2026-03-11 12:48:10","3721918b-779e-46f9-b955-c70ee680fee7","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/0da6e7f4-0812-4846-958e-96f903659038","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/e155b73b-d71f-40a4-91ca-46083aeb37ee","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/161b6b7c-b459-480e-a5d4-f75f8a3f49d1","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/b3d1b946-c38d-4fb8-9bf2-7b4b6ebd390d","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/b4f3ca61-e6a2-49e6-934d-8875ad202224","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/c5c76214-f199-40fd-a3b0-bb736ecedc2b",[112],{"id":54,"frequency":54},"mBdJhxkimmxsd9wLyfbn",[1964,1965,1966,1967,1051,1055,1108,1968,1969,1288,1970,1971,1742,1972,1973],"codzienni","bohaterowie","poszukiwani","takze","i","jak","zostac","jednym","nich","rozmowa","Potrzebujących dzieci coraz więcej, a kandydatów na rodziców zastępczych zaczyna brakować. - Niestety ta sfera życia społecznego jest kompletnie zapomniana przez media i ludzi mogących pomóc w rozpowszechnianiu idei - mówi nam pani Katarzyna, od lat związana z Ośrodkiem Rodzinnej Pieczy Zastępczej w Płocku. Porozmawialiśmy więc o tym, jak stworzyć najmłodszym bezpieczną oazę, jakie wymagania należy spełnić i jaką pomoc można otrzymać, gdy zdecydujemy się otworzyć swoje serca i zostać rodzicem zastępczym.",{"title":1976,"description":1974,"keywords":1977,"fb_cover":1978,"fb_title":54,"fb_description":54},"Codzienni bohaterowie poszukiwani także w Płocku. Kto i jak może zostać jednym z nich? [ROZMOWA]","Piecza zastępcza, rozmowa",{"value":1979},{"filename":54,"name":54,"tags":54,"thumbnail":54,"type":54,"url":54},"2026-03-11 12:51:08","https://portalplock.pl/wiadomosci/codzienni-bohaterowie-poszukiwani-takze-w-plocku-kto-i-jak-moze-zostac-jednym-z-nich-rozmowa/mBdJhxkimmxsd9wLyfbn","codzienni-bohaterowie-poszukiwani-takze-w-plocku-kto-i-jak-moze-zostac-jednym-z-nich-rozmowa",[1973,1984],"Piecza zastępcza",[1986,1987],{"tag":1973,"slug":1973},{"tag":1984,"slug":1988},"piecza-zastepcza","2026-03-11 13:26:55",["Reactive",1991],{"ads":22,"aid":1992,"alternative_gallery_style":22,"attachments":1993,"author":1041,"author_info":37,"category":2005,"comments":22,"comments_auth":22,"content":83,"created_by":1044,"created_by_name":83,"custom_html":54,"featured":29,"gallery_ads":2006,"gallery_picked":23,"id":2007,"is_advertisement":29,"is_photostory":29,"is_pool":29,"multiportal":54,"view_type":54,"is_redirect":29,"keywords":2008,"lead":2015,"locked":29,"meta":2016,"parent_domain":54,"parent_id":54,"photostory_added":23,"pool_picked":54,"pool_under_photostory":23,"premium":29,"published":37,"published_at":2021,"quiz_picked":54,"recommended":29,"redirect_url":54,"self_url":2022,"show_quiz_cover":23,"slug":2023,"sponsored":23,"short_title":2017,"tags":2024,"tagsRaw":2025,"title":2017,"type":1018,"uid":2007,"updated_at":2021},75196,[1994],{"id":1995,"name":83,"url":1996,"thumbnail":83,"created_at":1997,"tags":83,"author":80,"type":980,"filename":1998,"description":83,"750x750px":1999,"160x90px":2000,"365x225px":2001,"100x100px":2002,"760xautopx":2003,"1200x675px":2004,"article_id":1992},300208,"https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/f6b4a485-ba93-47b5-9b44-cec63593bcad","2026-03-11 09:19:36","f6b4a485-ba93-47b5-9b44-cec63593bcad","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/aa460d7b-1b58-4244-861b-712c77bb9d69","https://storage.googleapis.com/patrykslezak-pbem/p
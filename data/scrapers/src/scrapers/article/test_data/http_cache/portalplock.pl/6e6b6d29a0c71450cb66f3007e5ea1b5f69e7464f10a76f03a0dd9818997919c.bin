927,934,940,946,951,956],{"caption":83,"uniqueId":928,"campaignId":929,"img":930,"mobileUrl":931,"url":932,"id":933,"commercialType":793,"display":794},"ov4JnygBYb3wKPVVUFJW",109,"https://storage.googleapis.com/patrykslezak-pbem/attachments/9c510dd8-a0d3-4c9b-82c6-50020cb0308c","https://storage.googleapis.com/patrykslezak-pbem/attachments/76a8d459-849b-47d7-993d-08fc149f2c02","https://autoforum.hyundai.pl/",916,{"caption":83,"uniqueId":935,"campaignId":929,"img":936,"mobileUrl":937,"url":938,"id":939,"commercialType":793,"display":794},"EThf6rGFmDVXMItyXS5w","https://storage.googleapis.com/patrykslezak-pbem/attachments/00059574-a4cf-4f90-bb03-7ec0b3c9dd52","https://storage.googleapis.com/patrykslezak-pbem/attachments/0f9cf263-dca0-4631-af57-58f568f77d98","https://bilety.wisla-plock.pl/",5754,{"caption":83,"uniqueId":941,"campaignId":929,"img":942,"mobileUrl":943,"url":944,"id":945,"commercialType":793,"display":794},"WBM1lIiSiD1km1BcY1Ry","https://storage.googleapis.com/patrykslezak-pbem/attachments/cc71b5eb-e1b1-441c-a48d-2a7e5df362ad","https://storage.googleapis.com/patrykslezak-pbem/attachments/1e9b56ec-67c0-4689-aa88-7f6a62b5b0f4","https://www.kia.com/pl/modele/nowy-stonic/poznaj/",6066,{"caption":83,"uniqueId":947,"campaignId":929,"img":948,"mobileUrl":949,"url":791,"id":950,"commercialType":793,"display":794},"UJJnGCxSWE7yg3dsePUb","https://storage.googleapis.com/patrykslezak-pbem/attachments/24b8904c-267c-4b20-bde3-a3dc5002eacd","https://storage.googleapis.com/patrykslezak-pbem/attachments/dc09beb4-9894-4e95-814a-6b031b20e243",6393,{"caption":83,"uniqueId":952,"campaignId":929,"img":953,"mobileUrl":954,"url":798,"id":955,"commercialType":793,"display":794},"GBesR4lWRUQ3cKjCqs1G","https://storage.googleapis.com/patrykslezak-pbem/attachments/af62993c-fcc8-49d2-bf1b-04d85302f495","https://storage.googleapis.com/patrykslezak-pbem/attachments/ad5ff26e-1ac2-4d56-b7cc-84a8c704b792",8587,{"caption":83,"uniqueId":957,"campaignId":929,"img":958,"mobileUrl":959,"url":803,"id":960,"commercialType":793,"display":794},"DlQXAYejtg4SHXqtalp8","https://storage.googleapis.com/patrykslezak-pbem/attachments/4fc82c30-41ed-481f-8ed9-2a00f24fd8d0","https://storage.googleapis.com/patrykslezak-pbem/attachments/da70188d-6dd3-4dd3-bc67-75521f6b8976",9877,[962],[963],{"caption":83,"uniqueId":964,"campaignId":965,"img":966,"mobileUrl":967,"url":968,"id":969,"commercialType":793,"display":794},"h3s7o9gwUHvfhL4mcVGe",68,"https://storage.googleapis.com/patrykslezak-pbem/attachments/45d266f1-24da-41c5-becb-bafd0b7f35f1","https://storage.googleapis.com/patrykslezak-pbem/attachments/76993f6a-8c06-41c0-9f1d-81c203dc335c","https://www.enkra.pl/",9259,200,{"article":972,"recommended":1026,"intertextual":1260,"status":970},{"ads":22,"aid":973,"alternative_gallery_style":22,"attachments":974,"author":979,"author_info":29,"category":989,"comments":22,"comments_auth":22,"content":990,"created_by":991,"created_by_name":992,"custom_html":54,"featured":29,"gallery_ads":993,"gallery_picked":23,"id":994,"is_advertisement":29,"is_photostory":29,"is_pool":29,"multiportal":29,"view_type":995,"is_redirect":29,"keywords":996,"lead":1005,"locked":29,"meta":1006,"parent_domain":54,"parent_id":54,"photostory_added":23,"pool_picked":54,"pool_under_photostory":23,"premium":29,"published":37,"published_at":1011,"quiz_picked":54,"recommended":29,"redirect_url":54,"self_url":1012,"show_quiz_cover":23,"slug":1013,"sponsored":23,"short_title":1007,"tags":1014,"tagsRaw":1015,"title":1007,"type":1018,"uid":994,"updated_at":1019,"selected_author":1020,"meta_image_data":1021},63954,[975],{"id":976,"name":83,"url":977,"thumbnail":83,"created_at":978,"tags":83,"author":979,"type":980,"filename":981,"description":982,"750x750px":983,"160x90px":984,"365x225px":985,"100x100px":986,"760xautopx":987,"1200x675px":988},289692,"https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/9f230ceb-8b91-4999-ac11-ebb20d58358b","2025-06-01 21:04:52","mars","image/webp","9f230ceb-8b91-4999-ac11-ebb20d58358b","Wybory 2025","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/a03e4693-a4a8-419c-8b7c-94c7d34c7e21","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/622f483d-600c-4551-94c2-0b5f8ba59762","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/af820cb3-38a0-44b5-b574-117c4bf04e05","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/1a68d71d-8518-4e6d-aff9-c48820faa2e2","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/ceaf2263-315b-410c-afe3-d2d86c823b54","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/48e7cb7e-4878-4a2c-a60b-79e558c672f7",[112],"\u003Cp style=\"text-align: justify;\">W pierwszej turze o poparcie walczyło 13 kandydat&oacute;w. Nikt nie zdobył większości głos&oacute;w, więc w drugiej turze zmierzyli się Rafał Trzaskowski i Karol Nawrocki.\u003C/p>\n\u003Cp style=\"text-align: justify;\">W niedzielę 1 czerwca mobilizacja wyborc&oacute;w obu stron była duża, frekwencja już od rana była wyższa, niż podcza pierwszej tury w maju. Ostatecznie wyniosła 72,8 proc.\u003C/p>\n\u003Cp style=\"text-align: justify;\">O godz. 21 zakończyło się głosowanie, zamknięte zostały lokale wyborcze. Poznaliśmy wyniki sondaży exit poll (błąd powinien wynieść &nbsp;maksymalnie 2 pkt proc.). Wynika z nich, że Rafał Trzaskowski z PO zdobył 50,3 proc., a a Karol Nawrocki, popierany przez PiS - 49,7 proc. Błąd powinien wynieść &nbsp;maksymalnie 2 pkt proc.&nbsp;\u003C/p>\n\u003Cp style=\"text-align: justify;\">To oznacza, że jeszcze nic nie wiadomo. Około p&oacute;łnocy spodziewany jest sondaż late poll, w kt&oacute;rym zakres błędu to już tylko 0,5 pkt proc.\u003C/p>\n\u003Ch2 id=\"t3_1748803125635\" data-start=\"4519\" data-end=\"4546\">Jak głosowano w I turze?\u003C/h2>\n\u003Cp data-start=\"4548\" data-end=\"5018\">Wybory rozpoczęły się \u003Cstrong data-start=\"4570\" data-end=\"4591\">18 maja 2025 roku\u003C/strong>, kiedy odbyła się pierwsza tura. W&oacute;wczas najwięcej głos&oacute;w zdobył \u003Cstrong data-start=\"4657\" data-end=\"4678\">Rafał Trzaskowski\u003C/strong> &ndash; \u003Cstrong data-start=\"4681\" data-end=\"4696\">31,36 proc.\u003C/strong>, przed \u003Cstrong data-start=\"4704\" data-end=\"4725\">Karolem Nawrockim\u003C/strong> &ndash; \u003Cstrong data-start=\"4728\" data-end=\"4743\">29,54 proc.\u003C/strong> Trzeci był \u003Cstrong data-start=\"4755\" data-end=\"4775\">Sławomir Mentzen\u003C/strong> &ndash; \u003Cstrong data-start=\"4778\" data-end=\"4793\">14,81 proc.\u003C/strong>, a kolejne miejsca zajęli Grzegorz Braun (\u003Cstrong data-start=\"4836\" data-end=\"4850\">6,34 proc.\u003C/strong>), Adrian Zandberg (\u003Cstrong data-start=\"4870\" data-end=\"4884\">4,86 proc.\u003C/strong>) i Magdalena Biejat (\u003Cstrong data-start=\"4906\" data-end=\"4920\">4,23 proc.\u003C/strong>). \u003Cstrong data-start=\"4923\" data-end=\"4942\">Szymon Hołownia\u003C/strong> osiągnął \u003Cstrong data-start=\"4952\" data-end=\"4966\">4,99 proc.\u003C/strong>, a reszta kandydat&oacute;w nie przekroczyła progu 2 proc.\u003C/p>\n\u003Ch2 id=\"t4_1748803125635\" data-start=\"5020\" data-end=\"5045\">Kampania między turami\u003C/h2>\n\u003Cp data-start=\"5047\" data-end=\"5330\">Po I turze rozpoczęła się walka o każdy głos. Sztaby obu kandydat&oacute;w skupiły się na elektoracie centrowym oraz osobach, kt&oacute;re wcześniej nie głosowały. Kandydaci prezentowali nowe obietnice, spotykali się z wyborcami w całym kraju i brali udział w debatach transmitowanych przez media.\u003C/p>\n\u003Cp data-start=\"5332\" data-end=\"5527\">Zar&oacute;wno Trzaskowski, jak i Nawrocki stawiali na wyrazistą komunikację. Ten pierwszy podkreślał potrzebę demokratycznej stabilizacji, ten drugi &ndash; silnego państwa i ciągłości konserwatywnego kursu.\u003C/p>\n\u003Cp data-start=\"5564\" data-end=\"5831\">Jeśli oficjalne wyniki potwierdzą przewagę Rafała Trzaskowskiego, obejmie on urząd prezydenta w czasach pełnych wyzwań. Przed nim m.in. relacje z parlamentem, polityka zagraniczna w obliczu wojny w Ukrainie, kryzysu migracyjnego oraz konieczność reform klimatycznych.\u003C/p>\n\u003Cp data-start=\"5833\" data-end=\"5966\">Zwycięzca zapowiedział, że jego prezydentura ma być mostem, a nie barykadą. Czy spełni te oczekiwania? Odpowiedź poznamy już wkr&oacute;tce.\u003C/p>\n\u003Cp style=\"text-align: justify;\">&nbsp;\u003C/p>","40","Mariusz Sobczak",{"id":54,"frequency":54},"jhaNHjJ2wuJrBAY0JuJk","full_view",[997,998,999,1000,1001,1002,1003,1004],"wybory","prezydenckie","juz","za","nami","jaki","jest","wynik","W niedzielę 1 czerwca w godz. 7:00 - 21:00 Polacy wybierali prezydenta. Była to druga tura wyborów.",{"title":1007,"description":1005,"keywords":1008,"fb_cover":1009,"fb_title":54,"fb_description":54},"Wybory prezydenckie już za nami! Jaki jest wynik?","wybory prezydenckie 2025",{"value":1010},{"filename":54,"name":54,"tags":54,"thumbnail":54,"type":54,"url":54},"2025-06-01 21:08:23","https://portalplock.pl/wiadomosci/wybory-prezydenckie-juz-za-nami-jaki-jest-wynik/jhaNHjJ2wuJrBAY0JuJk","wybory-prezydenckie-juz-za-nami-jaki-jest-wynik",[1008],[1016],{"tag":1008,"slug":1017},"wybory-prezydenckie-2025","default","2025-08-13 09:28:18",[],{"url":1022,"width":1023,"height":1024,"type":1025},"https://static.ddbelchatow.pl/plock/articles/image/48e7cb7e-4878-4a2c-a60b-79e558c672f7",1200,675,"webp",[1027,1082,1126,1165,1213],{"ads":22,"adsProviders":1028,"aid":1029,"alternative_gallery_style":22,"attachments":1030,"author":1041,"author_info":29,"blocked_by":54,"category":1042,"category_id":55,"category_name":111,"comments":22,"comments_auth":22,"comments_show":23,"content":1043,"created_by":1044,"created_by_name":83,"custom_html":54,"featured":29,"gallery_ads":1045,"id":1046,"is_redirect":29,"keywords":1047,"lead":1056,"locked":29,"meta":1057,"multiportal":23,"multiportal_published_at":54,"multiportal_v2":23,"multiportal_view_types":83,"origin_domain":19,"parent_domain":54,"parent_id":54,"portals":1062,"premium":29,"previous_id":54,"previous_route":54,"priority":1063,"published":37,"published_at":1064,"recommended":29,"redirect_url":54,"revoke_at":54,"revoked":23,"scheduled":23,"shared_article_id":54,"shared_by":54,"short_title":1065,"slug":1066,"sponsored":23,"style":1067,"sub_title":54,"tags":1068,"tagsRaw":1072,"title":1058,"type":1018,"uid":1046,"updated_at":1019,"view_type":995,"stats":1079,"is_photostory":23,"photostory_added":23,"gallery_picked":23,"quiz_picked":54,"self_url":1081,"is_quiz":23,"is_advertisement":23,"pool_picked":54,"is_pool":23,"pool_under_photostory":23,"show_quiz_cover":23},{"adrino":22,"questpass":22},65479,{"id":1031,"name":83,"url":1032,"thumbnail":83,"created_at":1033,"tags":83,"author":80,"type":980,"filename":1034,"description":83,"750x750px":1035,"160x90px":1036,"365x225px":1037,"100x100px":1038,"760xautopx":1039,"1200x675px":1040},291202,"https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/bd56cbab-10e4-4de5-a746-e656e7ccd1dd","2025-07-16 09:45:52","bd56cbab-10e4-4de5-a746-e656e7ccd1dd","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/ff65d649-1673-4267-a40a-b31bdb1f09fe","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/c2b99410-9513-4f3a-96e6-afbe6f757d38","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/c39e16d0-9fb1-4581-bfa6-f7100812dd74","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/fc0dbc46-52f3-4c12-9dcf-7a8e38745b05","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/d1c8bbb9-1605-4582-a5f5-2b21a0027246","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/afff7e30-3cec-4176-8015-170d856570f8","Gabriela Bieńkowska",[108],"\u003Cp style=\"text-align: justify;\">\u003Cstrong>Płocki klub PiS\u003C/strong> sygnalizował problem z reklamami wyborczymi jeszcze przed I turą wybor&oacute;w prezydenckich. W&oacute;wczas szczeg&oacute;lną uwagę zwr&oacute;cili na reklamy kandydata \u003Cstrong>Rafała Trzaskowskiego\u003C/strong>.\u003C/p>\n\u003Cp style=\"text-align: justify;\">Wątpliwości poseł na sejm RP Wioletty Kulpy budziła rzekoma \u003Cstrong>zniżka\u003C/strong>, kt&oacute;rą zarząd KM Płock miał udzielić jednej z agencji reklamowych.\u003C/p>\n\u003Cblockquote>\n\u003Cp>- Istnieje jedno zarządzenie, kt&oacute;re 14 stycznia 2025 r. wydała Komunikacja Miejska, gdzie mamy podaną cenę 1000 zł netto za możliwość wyklejenia tyłu autobusu przez miesiąc. Inna jest natomiast umowa, do kt&oacute;rej miałam wgląd, podpisana z agencją 15 stycznia 2025 r., gdzie widnieje&nbsp;\u003Cstrong>stawka 500 zł netto\u003C/strong> za miesiąc, plus oczywiście koszty pracy agencji oraz materiał&oacute;w, kt&oacute;rymi zostanie wyklejony autobus - informowała podczas majowej konferencji prasowej.&nbsp;\u003C/p>\n\u003C/blockquote>\n\u003Cp style=\"text-align: justify;\">Poseł podkreśliła, że nie była to jednorazowa sytuacja. Nieprawidłowości miała obserwować już od 2023 r.\u003C/p>\n\u003Cp style=\"text-align: justify;\">\u003Ca class=\"btn btn-outline-dark text-uppercase\" href=\"https://portalplock.pl/wiadomosci/jeden-z-kandydatow-na-prezydenta-mial-znizki-na-reklame-w-plocku-to-jest-sprawa-dla-prokuratury/4PXCjLUJ6oF6vzaAZsSi\">CZYTAJ TEŻ: Zniżki dla wybranych? Kontrowersja wok&oacute;ł reklam wyborczych w Płocku. \"To jest sprawa dla prokuratury\"\u003C/a>\u003C/p>\n\u003Ch2 id=\"t4_1752481432778\" style=\"text-align: justify;\">Prokuratura wszczyna śledztwo\u003C/h2>\n\u003Cblockquote>\n\u003Cp>- Po zawiadomieniu pani poseł, 3 lipca prokuratura wszczęła postępowanie z art. 296 paragraf 1 KK. Chodzi o zbadanie sprawy wynajmowania powierzchni reklamowej na autobusach Komunikacji Miejskiej w Płocku radnym, kandydatom do parlamentu, europarlamentu oraz kandydatowi na prezydenta w okresie od 2023 do maja 2025 r. Prowadzone są czynności, wkr&oacute;tce zostaną przesłuchane pierwsze osoby - przekazała nam prok. Sylwia Stapińska-Litkowska.\u003C/p>\n\u003C/blockquote>\n\u003Cp style=\"text-align: justify;\">\u003Cstrong>Artykuł 296 \u003C/strong>odnosi się do \u003Cstrong>nadużycia uprawnień lub niedopełnienia obowiązku,\u003C/strong> co skutkuje \u003Cstrong>znaczną szkodą materialną.\u003C/strong>&nbsp;\u003C/p>\n\u003Cp style=\"text-align: justify;\">Zgodnie z Kodeksem Karnym, grozi za to \u003Cstrong>kara od 3 miesięcy do 5 lat pozbawienia wolności.&nbsp;\u003C/strong>\u003C/p>\n\u003Ch2 id=\"t7_1752481836254\" style=\"text-align: justify;\">Co na to sp&oacute;łka?\u003C/h2>\n\u003Cp style=\"text-align: justify;\">O odniesienie się do sprawy poprosiliśmy także \u003Cstrong>zarząd Komunikacji Miejskiej w Płocku.&nbsp;\u003C/strong>\u003C/p>\n\u003Cblockquote>\n\u003Cp>- W związku z informacją o wszczęciu przez Prokuraturę Rejonową w Płocku postępowania wyjaśniającego dotyczącego Zarządu KM-Płock Sp. z o.o., oświadczamy, że traktujemy je jako standardową procedurę mającą na celu wyjaśnienie stanu faktycznego. Stanowczo podkreślamy, że wszelkie działania Sp&oacute;łki były i są podejmowane zgodnie z obowiązującymi przepisami prawa oraz zasadami transparentności i odpowiedzialnego gospodarowania majątkiem publicznym. Z ubolewaniem odnotowujemy, że niekt&oacute;rzy przedstawiciele Sejmu, zamiast skoncentrować swoją uwagę na istotnych dla mieszkańc&oacute;w problemach społecznych, podejmują działania noszące znamiona politycznej autopromocji - czytamy w oświadczeniu.&nbsp;\u003C/p>\n\u003C/blockquote>\n\u003Cp style=\"text-align: justify;\">Zarząd zadeklarował r&oacute;wnież pełną wsp&oacute;łpracę z organami ścigania, w tym przekazanie wszelkiej niezbędnej dokumentacji. Dodał jednak, że na obecnym etapie postępowania w interesie rzetelności powstrzymuje się od szczeg&oacute;łowego komentowania sprawy.\u003C/p>","165",{"id":54,"frequency":54},"VKGCRDM7jbWlwGO3AP9H",[1048,1049,1050,1051,1052,1053,1054,1051,1055],"prokuratura","wszczela","sledztwo","w","sprawie","komunikacji","miejskiej","plocku","- Mamy do czynienia z niepowtarzalną patologią i skandalem - opisywał działania zarządu Komunikacji Miejskiej w Płocku, radny Szymon Stachowiak. Płocki klub PiS jeszcze przed I turą wyborów prezydenckich zapowiadał wniosek do prokuratury. Na początku lipca wszczęto postępowanie.",{"title":1058,"description":1059,"keywords":83,"fb_cover":1060,"fb_title":54,"fb_description":54},"Prokuratura wszczęła śledztwo w sprawie Komunikacji Miejskiej w Płocku","- Mamy do czynienia z niepowtarzalną patologią i skandalem - opisywał działania zarządu Komunikacji Miejskiej w Płocku, radny Szymon Stachowiak. Płocki klub PiS jeszcze przed I turą wyborów prezydenckich zapowiadał działania. Dziś widzimy pierwszy efekt - prokuratura wszczęła śledztwo.",{"value":1061},{"filename":54,"name":54,"tags":54,"thumbnail":54,"type":54,"url":54},[],99,"2025-07-16 12:17:20","Prokuratura wszczęła śledztwo ws. KM Płock","prokuratura-wszczela-sledztwo-w-sprawie-komunikacji-miejskiej-w-plocku","ImageTile",[1069,1070,1071,1008],"km plock","śledztwo","prokuratura Płock",[1073,1075,1076,1078],{"tag":1069,"slug":1074},"km-plock",{"tag":1070,"slug":1050},{"tag":1071,"slug":1077},"prokuratura-plock",{"tag":1008,"slug":1017},{"views":1080,"clicks":29},10877,"https://portalplock.pl/wiadomosci/prokuratura-wszczela-sledztwo-w-sprawie-komunikacji-miejskiej-w-plocku/VKGCRDM7jbWlwGO3AP9H",{"ads":22,"adsProviders":1083,"aid":1084,"alternative_gallery_style":22,"attachments":1085,"author":1097,"author_info":29,"blocked_by":54,"category":1098,"category_id":55,"category_name":111,"comments":22,"comments_auth":22,"comments_show":23,"content":1099,"created_by":1100,"created_by_name":83,"custom_html":54,"featured":29,"gallery_ads":1101,"id":1102,"is_redirect":29,"keywords":1103,"lead":1111,"locked":29,"meta":1112,"multiportal":23,"multiportal_published_at":54,"multiportal_v2":23,"multiportal_view_types":83,"origin_domain":19,"parent_domain":54,"parent_id":54,"portals":1116,"premium":29,"previous_id":54,"previous_route":54,"priority":1063,"published":37,"published_at":1117,"recommended":29,"redirect_url":54,"revoke_at":54,"revoked":23,"scheduled":23,"shared_article_id":54,"shared_by":54,"short_title":1113,"slug":1118,"sponsored":23,"style":1119,"sub_title":54,"tags":1120,"tagsRaw":1121,"title":1113,"type":1018,"uid":1102,"updated_at":1019,"view_type":995,"stats":1123,"is_photostory":23,"photostory_added":23,"gallery_picked":23,"quiz_picked":54,"self_url":1125,"is_quiz":23,"is_advertisement":23,"pool_picked":54,"is_pool":23,"pool_under_photostory":23,"show_quiz_cover":23},{"adrino":22,"questpass":22},64744,{"id":1086,"name":83,"url":1087,"thumbnail":83,"created_at":1088,"tags":83,"author":1089,"type":980,"filename":1090,"description":83,"750x750px":1091,"160x90px":1092,"365x225px":1093,"100x100px":1094,"760xautopx":1095,"1200x675px":1096},290416,"https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/9765d844-d2fe-4008-b1c4-2ecc5803cbc4","2025-06-24 18:45:09","Sm/Michał Wiśniewski","9765d844-d2fe-4008-b1c4-2ecc5803cbc4","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/6ccbe7c1-d003-400a-a03e-ba000919738d","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/8337e27d-a8a3-4b0f-87f2-5d20f137f674","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/2f93cac7-57b2-4281-a903-76a1b9a67c69","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/3b11f336-f298-4a25-8665-8e1d84c8ea51","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/623a12c3-754c-4411-8586-29102dbdcbf0","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/05ad64c0-62f3-404a-83ba-c2ca2be1277a","Michał Wiśniewski",[108],"\u003Cp style=\"text-align: justify;\">Wybory prezydenckie za nami, Karol Nawrocki odebrał zaświadczenie od Państwowej Komisji Wyborczej o wybraniu na urząd Prezydenta Rzeczypospolitej Polskiej. Echa wybor&oacute;w jednak nie milkną - politycy opozycji przekonują, że w niekt&oacute;rych komisjach dochodziło do nieprawidłowości.&nbsp;\u003C/p>\n\u003Cp style=\"text-align: justify;\">Polacy zasypali Sąd Najwyższy protestami wyborczymi. Jak przyznała Małgorzata Manowska, prezes Sądu Najwyższego, protest&oacute;w jest ponad 50 tysięcy, a 9 na 10 ma być powielanych według instrukcji zamieszczanych przez posła Romana Giertycha z Koalicji Obywatelskiej.\u003C/p>\n\u003Cp style=\"text-align: justify;\">P&oacute;ki co Sąd Najwyższy nakazał ponownie przeliczyć głosy w 13 obwodowych komisjach i rzeczywiście, dopatrzono się błęd&oacute;w. W niekt&oacute;rych z nich głosy oddana na Rafała Trzaskowskiego zostały przypisane Karolowi Nawrockiemu. Kandydat Koalicji Obywatelskiej zyskał nieco ponad 2600 głos&oacute;w. Wybory przegrał r&oacute;żnicą ok. 370 tysięcy głos&oacute;w.&nbsp;\u003C/p>\n\u003Ch2 id=\"t2_1750780929663\" style=\"text-align: justify;\">Kto pilnował wybor&oacute;w?\u003C/h2>\n\u003Cp style=\"text-align: justify;\">Analiza głos&oacute;w oddawanych w I i II turze wybor&oacute;w prezydenckich w Płocku nie wskazuje na to, by w mieście dochodziło do pomyłek na dużą skalę.\u003C/p>\n\u003Cblockquote>\n\u003Cp>- Ludzie siedzą w komisji po kilkanaście godzin, od rana do nocy. Pojawia się zmęczenie. Pewne małe błędy mogą się pojawić, ale w fałszerstwa na większą skalę trudno mi uwierzyć. Każdy każdemu tu patrzy na ręce, poza tym każdy chce dobrze wykonać swoją pracę\u003C/p>\n\u003C/blockquote>\n\u003Cp style=\"text-align: justify;\">- m&oacute;wi nam jeden z członk&oacute;w obdowowej komisji wyborczej, kt&oacute;ry już kolejny raz zasiadał w komisji wyborczej.\u003C/p>\n\u003Cp style=\"text-align: justify;\">W wyborach prezydenckich w Płocku głosowanie odbywało się w 71 komisjach - 68 stałych obwodowych komisjach wyborczych i 3 specjalnych - po jednej w szpitalach i jedna w więzieniu. Warto zaznaczyć, że postanowienie Komisarza Wyborczego w Płocku o powołaniu członk&oacute;w obwodowych komisji wyborczych jest jawnym dokumentem. Można go znaleźć \u003Cstrong>\u003Ca href=\"https://plock.kbw.gov.pl/uploaded_files/1745899187_1745836096146201-136-miasto-plock-obwody-postanowienie.pdf\" target=\"_blank\" rel=\"noopener\">tutaj\u003C/a>\u003C/strong>.&nbsp;\u003C/p>\n\u003Cp style=\"text-align: justify;\">Zgodnie z prawem w skład każdej komisji wyborczej wchodzi od 7 do 13 os&oacute;b - w zależności od liczby wyborc&oacute;w przypisanych do obwodu.\u003C/p>\n\u003Cul style=\"text-align: justify;\">\n\u003Cli>7 os&oacute;b w obwodach głosowania do 1000 mieszkańc&oacute;w;\u003C/li>\n\u003Cli>9 os&oacute;b w obwodach głosowania od 1001 do 2000 mieszkańc&oacute;w;\u003C/li>\n\u003Cli>11 os&oacute;b w obwodach głosowania od 2001 do 3000 mieszkańc&oacute;w;\u003C/li>\n\u003Cli>13 os&oacute;b w obwodach głosowania powyżej 3000 mieszkańc&oacute;w.\u003C/li>\n\u003C/ul>\n\u003Cp style=\"text-align: justify;\">W Płocku w obdowowych komisjach wyborczych pracowały 653 osoby.&nbsp; Muszą to być mieszkańcy wojew&oacute;dztwa mazowieckiego - 555 os&oacute;b jako adres zamieszkania wskazało Płock.&nbsp;\u003C/p>\n\u003Cp style=\"text-align: justify;\">Członk&oacute;w obwodowych komisji wyborczych mają prawo wskazać komitety wyborcze kandydat&oacute;w - nie tylko tych, kt&oacute;rzy zebrali 100 tysięcy podpis&oacute;w, ale także tych, kt&oacute;rzy zarejestrowali komitet. Dlatego w Płocku 15 os&oacute;b wskazał komitet wyborczy Romualda Starosielca, a 50 os&oacute;b komitet wyborczy Wiesława Lewickiego. Państwowa Komisja Wyborcza odrzuciła zebrane przez kandydat&oacute;w podpisy, ale mimo to mieli prawo desygnować ludzi do obwodowych komisji wyborczych.\u003C/p>\n\u003Cp style=\"text-align: justify;\">Znacznie więcej os&oacute;b desygnowały jednak gł&oacute;wne siły polityczne. Najwięcej członk&oacute;w obwodowych komisji wyborczych w Płocku wskazały komitety Rafała Trzaskowskiego i Karol Nawrocki. Kto \"ilu ludzi\" miał w komisjach w Płocku?&nbsp;\u003C/p>\n\u003Cul style=\"text-align: justify;\">\n\u003Cli>Rafał Trzaskowski - 86\u003C/li>\n\u003Cli>Karol Nawrocki - 86\u003C/li>\n\u003Cli>Magdalena Biejat - 78\u003C/li>\n\u003Cli>Marek Jakubiak - 68\u003C/li>\n\u003Cli>Sławomir Mentzen - 65\u003C/li>\n\u003Cli>Szymon Hołownia - 63\u003C/li>\n\u003Cli>Wiesław Lewicki -50\u003C/li>\n\u003Cli>Marek Woch - 39\u003C/li>\n\u003Cli>Grzegorz Braun - 27\u003C/li>\n\u003Cli>Adrian Zandberg - 20\u003C/li>\n\u003Cli>Katarzyna Cichos - 17&nbsp;\u003C/li>\n\u003Cli>Romuald Starosielec - 15\u003C/li>\n\u003Cli>Sebastian Ross - 13&nbsp;\u003C/li>\n\u003Cli>Artur Bartoszewicz - 5\u003C/li>\n\u003C/ul>\n\u003Cp style=\"text-align: justify;\">Joanna Senyszyn i Krzysztof Stanowski nie mieli w Płocku swoich przedstawicieli w komisjach w Płocku.\u003C/p>\n\u003Cp style=\"text-align: justify;\">W Płocku tylko w jednej komisji komitet Rafała Trzaskowskiego nie miał swojego przedstawiciela - w specjalnej komisji nr 69 w szpitalu św. Tr&oacute;jcy. W 7-osobowej komisji znaleźli się za to przedstawiciele wskazani przez komitety Magdaleny Biejat i Szymona Hołowni\u003C/p>\n\u003Cp style=\"text-align: justify;\">Łatwo policzyć, że w kilkunastu komisjach komitet Rafała Trzaskowskiego miał po 2 przedstawicieli. Podobnie było w przypadku Karola Nawrockiego.&nbsp;\u003C/p>\n\u003Ch2 id=\"t10_1750782768095\" style=\"text-align: justify;\">Jak głosował Płock?\u003C/h2>\n\u003Cp style=\"text-align: justify;\">W pierwszej turze wybor&oacute;w prezydenckich Rafał Trzaskowski zdobył w Płocku 20 777 głos&oacute;w. Poparcia kandydatowi Koalicji Obywatelskiej udzielili Szymon Hołownia (2587 głos&oacute;w), Magdalena Biejat (2639) i Joanna Senyszyn (521). Prezydent Warszawy m&oacute;gł też z pewnością liczyć przynajmniej na część głos&oacute;w Adriana Zandberga (2260).&nbsp;\u003C/p>\n\u003Cp style=\"text-align: justify;\">Karol Nawrocki zdobył zaś 17 783 głosy, a kandydat PiS według wszelkich sondaży m&oacute;gł liczyć przynajmniej na dużą część wyborc&oacute;w Sławomira Mentzena (6386), Grzegorza Brauna (2869) i Marka Jakubiaka (379).&nbsp;\u003C/p>\n\u003Cp style=\"text-align: justify;\">\u003Cstrong>W II turze głosy rozłożyły się następująco:\u003C/strong>\u003C/p>\n\u003Cul style=\"text-align: justify;\">\n\u003Cli>31 428 Rafał Trzaskowski\u003C/li>\n\u003Cli>29 023 Karol Nawrocki\u003C/li>\n\u003C/ul>\n\u003Cp style=\"text-align: justify;\">Zsumowane głosy wszystkich kandydat&oacute;w koalicyjnych z I tury, Andriana Zandberga i Joanny Senyszyn to 28 784.&nbsp;\u003C/p>\n\u003Cp style=\"text-align: justify;\">Z kolei suma głos&oacute;w Karola Nawrockiego i kandydat&oacute;w prawicy I tury to 27 417.\u003C/p>\n\u003Cp style=\"text-align: justify;\">To oczywiście ogromne uproszczenie, ale na tej podstawie można założyć, że w Płocku do większych nieprawidłowości raczej nie doszło. Przykładowo w obwodowej komisji nr 23, gdzie Karol Nawrocki w II turze uzyskał ponad 71% poparcie, w I turze Rafałowi Trzaskowskiemu zaliczono 22 głosy, a w II turze 40. Podobnie jest w innych komisjach, gdzie kandydat PiS uzyskał największe poparcie. Nie znaleźliśmy komisji w Płocku, w kt&oacute;rej Rafał Trzaskowski nie dostałby więcej głos&oacute;w w II, niż w I turze.&nbsp;\u003C/p>","1",{"id":54,"frequency":54},"a8dCtVtvAJmw3sHzBbdw",[1104,1105,1106,1107,1108,1109,1110,1051,1055],"kontrowersje","wokol","wyborow","prezydenckich","kto","pilnowal","glosowania","Do Sądu Najwyższego wpłynęło ponad 50 tysięcy protestów wyborczych. Część polityków koalicji rządzącej przekonuje, że głosy powinni zostać przeliczone przynajmniej w niektórych komisjach, a ci najdalej idący postulują przeliczenie wszystkich głosów. Póki co Sąd Najwyższy nakazał ponowne przeliczenie głosów w 13 komisjach, nieprawidłowości pojawiły się w 11. Sprawdzamy, kto zasiadał w komisjach wyborczych w Płocku i czy doszło tu do jakichś anomalii.",{"title":1113,"description":1111,"keywords":1008,"fb_cover":1114,"fb_title":54,"fb_description":54},"Kontrowersje wokół wyborów prezydenckich. Kto pilnował głosowania w Płocku?",{"value":1115},{"filename":54,"name":54,"tags":54,"thumbnail":54,"type":54,"url":54},[],"2025-06-24 18:45:58","kontrowersje-wokol-wyborow-prezydenckich-kto-pilnowal-glosowania-w-plocku","ImageTileOverlay",[1008],[1122],{"tag":1008,"slug":1017},{"views":1124,"clicks":29},6584,"https://portalplock.pl/wiadomosci/kontrowersje-wokol-wyborow-prezydenckich-kto-pilnowal-glosowania-w-plocku/a8dCtVtvAJmw3sHzBbdw",{"ads":22,"adsProviders":1127,"aid":1128,"alternative_gallery_style":22,"attachments":1129,"author":1097,"author_info":29,"blocked_by":54,"category":1140,"category_id":55,"category_name":111,"comments":22,"comments_auth":22,"comments_show":23,"content":1141,"created_by":1100,"created_by_name":83,"custom_html":54,"featured":29,"gallery_ads":1142,"id":1143,"is_redirect":29,"keywords":1144,"lead":1151,"locked":29,"meta":1152,"multiportal":23,"multiportal_published_at":54,"multiportal_v2":23,"multiportal_view_types":83,"origin_domain":19,"parent_domain":54,"parent_id":54,"portals":1156,"premium":29,"previous_id":54,"previous_route":54,"priority":1063,"published":37,"published_at":1157,"recommended":29,"redirect_url":54,"revoke_at":54,"revoked":23,"scheduled":23,"shared_article_id":54,"shared_by":54,"short_title":1153,"slug":1158,"sponsored":23,"style":1119,"sub_title":54,"tags":1159,"tagsRaw":1160,"title":1153,"type":1018,"uid":1143,"updated_at":1019,"view_type":995,"stats":1162,"is_photostory":23,"photostory_added":23,"gallery_picked":23,"quiz_picked":54,"self_url":1164,"is_quiz":23,"is_advertisement":23,"pool_picked":54,"is_pool":23,"pool_under_photostory":23,"show_quiz_cover":23},{"adrino":22,"questpass":22},64237,{"id":1130,"name":83,"url":1131,"thumbnail":83,"created_at":1132,"tags":83,"author":1097,"type":980,"filename":1133,"description":83,"750x750px":1134,"160x90px":1135,"365x225px":1136,"100x100px":1137,"760xautopx":1138,"1200x675px":1139},289966,"https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/2a40650b-c03f-40fd-9873-c0c8feca0fdd","2025-06-09 15:26:04","2a40650b-c03f-40fd-9873-c0c8feca0fdd","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/c7b6f3b1-8f2c-43e7-9d1c-cd5bc75de9f9","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/2fcec318-5ddb-4747-b224-14b42450e6f4","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/a5eea614-0b47-4c80-9345-8da8098cc6c6","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/1a5e97ea-9315-4210-b2e2-b3330c4723e2","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/8802b0de-1a1b-47a3-8dac-d3a84d1462f3","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/09d0cf40-4ca0-425e-bebf-eb5c4af36b4d",[108],"\u003Cp style=\"text-align: justify;\">Od II tury wybor&oacute;w prezydenckich minął już ponad tydzień, ale wracamy do niej ze względu na informacje, jakie przekazał nam czytelnik. Wiadomość na naszą skrzynkę wpłynęła już dzień po wyborach.&nbsp;\u003C/p>\n\u003Cblockquote>\n\u003Cp style=\"text-align: justify;\">- Komisja odm&oacute;wiła wydania karty do głosowania, ponieważ w rubryce widniał już podpis - nieczytelny, nie tego wyborcy, kt&oacute;rego dotyczyła rubryka. Sprawa została zgłoszona na policję, przyjechał patrol. Komisja tłumaczyła się pomyłką - policja nie przyjęła tej wersji za coś pewnego, ponieważ bezpośrednio nad i pod rubryką były podpisy innych wyborc&oacute;w. Chciałbym podkreślić r&oacute;wnież niestosowne komentarze ze strony komisji&nbsp;\u003C/p>\n\u003C/blockquote>\n\u003Cp style=\"text-align: justify;\">- napisał.&nbsp;\u003C/p>\n\u003Cp style=\"text-align: justify;\">Jak relacjonował, interwencja w Obwodowej Komisji nr 49 trwała 1,5 godziny, ale nie przyniosła rezultatu.&nbsp;\u003C/p>\n\u003Cblockquote>\n\u003Cp style=\"text-align: justify;\">- Interwencja była bardzo profesjonalna. Policjanci zasugerowali, by złożyć zawiadomienie na komendzie przy al. Kilińskiego&nbsp;\u003C/p>\n\u003C/blockquote>\n\u003Cp style=\"text-align: justify;\">- tłumaczy czytelnik.\u003C/p>\n\u003Cp style=\"text-align: justify;\">Rzeczywiście, takie zawiadomienie zostało zgłoszone.\u003C/p>\n\u003Cblockquote>\n\u003Cp style=\"text-align: justify;\">- 1 czerwca płoccy policjanci przyjęli zawiadomienie od jednego z mieszkańc&oacute;w naszego miasta, z kt&oacute;rego wynikało, że podczas II tury wybor&oacute;w prezydenckich osoba nieuprawniona złożyła podpis na liście do gśosowania w rubryce zgłaszającego. Policjanci prowadzą czynności w tej sprawie&nbsp;\u003C/p>\n\u003C/blockquote>\n\u003Cp style=\"text-align: justify;\">- przekazała nam podkom. Monika Jakubowska, oficer prasowy Komendanta Miejskiego Policji w Płocku.\u003C/p>\n\u003Cp style=\"text-align: justify;\">Zgodnie z art. 248 kodeksu karnego za naruszenie przebiegu wybor&oacute;w grozi kara pozbawienia wolności do 3 lat.\u003C/p>",{"id":54,"frequency":54},"OewBWm26siCb9jC14NGL",[1145,1146,1051,1055,1147,1148,1149,1150],"incydent","wyborczy","mieszkaniec","nie","mogl","zaglosowac","W trakcie II tury wyborów prezydenckich w Płocku doszło do incydentu wyborczego. Czytelnik poinformował nas o sytuacji w jednej z komisji na Podolszycach. Kiedy próbował zagłosować okazało się, że w jego rubryce ktoś już się podpisał, a komisja odmówiła wydania karty do głosowania. Policja prowadzi postępowanie w tej sprawie.",{"title":1153,"description":1151,"keywords":1008,"fb_cover":1154,"fb_title":54,"fb_description":54},"Incydent wyborczy w Płocku. Mieszkaniec nie mógł zagłosować",{"value":1155},{"filename":54,"name":54,"tags":54,"thumbnail":54,"type":54,"url":54},[],"2025-06-09 15:26:14","incydent-wyborczy-w-plocku-mieszkaniec-nie-mogl-zaglosowac",[1008],[1161],{"tag":1008,"slug":1017},{"views":1163,"clicks":29},6985,"https://portalplock.pl/wiadomosci/incydent-wyborczy-w-plocku-mieszkaniec-nie-mogl-zaglosowac/OewBWm26siCb9jC14NGL",{"ads":22,"adsProviders":1166,"aid":1167,"alternative_gallery_style":22,"attachments":1168,"author":1097,"author_info":29,"blocked_by":54,"category":1180,"category_id":55,"category_name":111,"comments":22,"comments_auth":22,"comments_show":23,"content":1181,"created_by":1100,"created_by_name":83,"custom_html":54,"featured":29,"gallery_ads":1182,"id":1183,"is_redirect":29,"keywords":1184,"lead":1198,"locked":29,"meta":1199,"multiportal":23,"multiportal_published_at":54,"multiportal_v2":23,"multiportal_view_types":83,"origin_domain":19,"parent_domain":54,"parent_id":54,"portals":1203,"premium":29,"previous_id":54,"previous_route":54,"priority":1063,"published":37,"published_at":1204,"recommended":29,"redirect_url":54,"revoke_at":54,"revoked":23,"scheduled":23,"shared_article_id":54,"shared_by":54,"short_title":1205,"slug":1206,"sponsored":23,"style":1119,"sub_title":54,"tags":1207,"tagsRaw":1208,"title":1200,"type":1018,"uid":1183,"updated_at":1019,"view_type":995,"stats":1210,"is_photostory":23,"photostory_added":23,"gallery_picked":23,"quiz_picked":54,"self_url":1212,"is_quiz":23,"is_advertisement":23,"pool_picked":54,"is_pool":23,"pool_under_photostory":23,"show_quiz_cover":23},{"adrino":22,"questpass":22},64029,{"id":1169,"name":83,"url":1170,"thumbnail":83,"created_at":1171,"tags":83,"author":1172,"type":980,"filename":1173,"description":83,"750x750px":1174,"160x90px":1175,"365x225px":1176,"100x100px":1177,"760xautopx":1178,"1200x675px":1179},289767,"https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/82304f10-043f-417d-89ef-e021f28e97a9","2025-06-03 19:10:28","SM/Mw","82304f10-043f-417d-89ef-e021f28e97a9","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/d880ac09-f3e6-4bd4-a325-507d5b73b912","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/4dae77e3-21b2-4545-8cec-2cc892be569f","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/b665fdbd-2445-4cf4-b51d-642814e57bb5","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/955380ba-123a-4f5f-97c0-6093417eacaf","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/0e95daf0-04e3-4c7c-a8ff-e4d28cb5a8f4","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/70538f6f-3794-46be-9144-a52fd4f013f9",[108],"\u003Cp>W niedzielę 1 czerwca rozstrzygnęły się wybory prezydenckie. W II turze rywalizowali Karol Nawrocki, kandydat Prawa i Sprawiedliwości, oraz Rafał Trzaskowski - kandydat Koalicji Obywatelskiej. Wygrał Karol Nawrocki, na kt&oacute;rego zagłosowało ponad 10,6 mln Polak&oacute;w.&nbsp;\u003C/p>\n\u003Cp>W Płocku do urn poszło blisko 61 tys. os&oacute;b, to 72,24% uprawnionych. Jak w poszczeg&oacute;lnych komisjach głosowali płocczanie?\u003C/p>\n\u003Ch2 id=\"t2_1748969109283\">Trzaskowski wygrywa w więzieniu\u003C/h2>\n\u003Cp>Niespodzianki nie ma. Po raz kolejny w Zakładzie Karnym w Płocku wygrał Rafał Trzaskowski - tu zagłosowało na niego 418 os&oacute;b, co dało 84,1% poparcie. Drugi najlepszy procentowy wynik kandydat Koalicji Obywatelskiej odnotował w obwodowej komisji nr 52 (Podolszyce P&oacute;łnoc), gdzie dostał 1102 głosy (65,13%). Mieszkańcy Podolszyc chętniej głosowali na prezydenta Warszawy - jeszcze w 4 komisjach zlokalizowanych na tych osiedlach (w Miejskim Przedszkolu nr 8, Szkole Podstawowej nr 23, drugiej komisji w Zespole Szk&oacute;ł nr 5 i Szkole Podstawowej nr 22) dostał 60 lub więcej procent głos&oacute;w. Tylko w 1 komisji na Podolszycach Trzaskowski spadł poniżej 50%.&nbsp;\u003C/p>\n\u003Cp>Kandydat Koalicji Obywatelskiej lepiej poradził sobie łącznie w 40 komisjach. Powyżej 55% poparcie miał m.in. w komisji nr 31 (ul. Bielska), u mieszkańc&oacute;w star&oacute;wki (komisja w Małachowiance), w komisji nr 44 na Międzytorzu czy u mieszkańc&oacute;w placu Romana Lutyńskiego i ul. Orońc&oacute;w Westerplatte.\u003C/p>\n\u003Cp>Najbliżej remisu w Płocku było w komisji nr 30, gdzie głosowali mieszkańcy ulic Dojazd, Gradowskiego, Padlewskiego, Sienkiewicza i Stommy - Rafała Trzaskowskiego poparło tu 539 wyborc&oacute;w (50,09%), a Karola Nawrockiego 537 (49,91%).\u003C/p>\n\u003Ch2 id=\"t4_1748969991107\">Karol Nawrocki g&oacute;rą w 31 komisjach\u003C/h2>\n\u003Cp>Największe zwycięstwo w Płocku kandydat PiS odni&oacute;sł na Trzepowie - zgarnął tu 71,43% głos&oacute;w. Sporym poparciem Karol Nawrocki cieszy się na Radziwiu i Ciechomicach - w komisji w Szkole Podstawowej nr 5 dostał 66,84%, w Centrum Integracji Społecznej \"Sputnik\" blisko 61% głos&oacute;w, a w Ciechomicach od 55 do 57%.&nbsp;\u003C/p>\n\u003Cp>Kandydat PiS wygrał też w jednej komisji na Podolszycach - otrzymał 53,14% głos&oacute;w głos&oacute;w od mieszkańc&oacute;w nieparzystych blok&oacute;w przy ul. Szarych Szereg&oacute;w. Kilkuprocentową przewagę wygrywał przeważnie w zachodnich dzielnicach miasta, choć to też nie jest reguła.\u003C/p>\n\u003Cp>Wszystkie wyniki można znaleźć \u003Cstrong>\u003Ca href=\"https://www.wybory.gov.pl/prezydent2025/pl/2/wynik/pow/146200?initscroll=3627\" target=\"_blank\" rel=\"noopener\">tutaj\u003C/a>\u003C/strong>.&nbsp;\u003C/p>\n\u003Cp>&nbsp;\u003C/p>",{"id":54,"frequency":54},"TPwQhEcerXeqi1ry8qlc",[1185,1186,1187,1051,1055,1188,1189,1190,1191,1192,1193,1051,1194,1195,1196,1197],"tu","najwiecej","glosow","dostal","rafal","trzaskowski","karol","nawrocki","wygral","mniej","niz","polowie","komisji","W Zakładzie Karnym w Płocku zdecydowanie wygrał Rafał Trzaskowski, z kolei największa przewaga w Karola Nawrockiego była w komisji w Trzepowie. W 31 komisjach w Płocku wygrał kandydat PiS, w pozostałych 40 Rafał Trzaskowski.",{"title":1200,"description":1198,"keywords":1008,"fb_cover":1201,"fb_title":54,"fb_description":54},"Tu najwięcej głosów w Płocku dostał Rafał Trzaskowski. Karol Nawrocki wygrał w mniej niż połowie komisji",{"value":1202},{"filename":54,"name":54,"tags":54,"thumbnail":54,"type":54,"url":54},[],"2025-06-03 19:10:53","Tu najwięcej głosów w Płocku dostał Rafał Trzaskowski","tu-najwiecej-glosow-w-plocku-dostal-rafal-trzaskowski-karol-nawrocki-wygral-w-mniej-niz-polowie-komisji",[1008],[1209],{"tag":1008,"slug":1017},{"views":1211,"clicks":29},8544,"https://portalplock.pl/wiadomosci/tu-najwiecej-glosow-w-plocku-dostal-rafal-trzaskowski-karol-nawrocki-wygral-w-mniej-niz-polowie-komisji/TPwQhEcerXeqi1ry8qlc",{"ads":22,"adsProviders":1214,"aid":1215,"alternative_gallery_style":22,"attachments":1216,"author":1041,"author_info":29,"blocked_by":54,"category":1228,"category_id":55,"category_name":111,"comments":22,"comments_auth":22,"comments_show":23,"content":1229,"created_by":1044,"created_by_name":83,"custom_html":54,"featured":29,"gallery_ads":1230,"id":1231,"is_redirect":29,"keywords":1232,"lead":1245,"locked":29,"meta":1246,"multiportal":23,"multiportal_published_at":54,"multiportal_v2":23,"multiportal_view_types":83,"origin_domain":19,"parent_domain":54,"parent_id":54,"portals":1250,"premium":29,"previous_id":54,"previous_route":54,"priority":1063,"published":37,"published_at":1251,"recommended":29,"redirect_url":54,"revoke_at":54,"revoked":23,"scheduled":23,"shared_article_id":54,"shared_by":54,"short_title":1252,"slug":1253,"sponsored":23,"style":1067,"sub_title":54,"tags":1254,"tagsRaw":1255,"title":1247,"type":1018,"uid":1231,"updated_at":1019,"view_type":995,"stats":1257,"is_photostory":23,"photostory_added":23,"gallery_picked":23,"quiz_picked":54,"self_url":1259,"is_quiz":23,"is_advertisement":23,"pool_picked":54,"is_pool":23,"pool_under_photostory":23,"show_quiz_cover":23},{"adrino":22,"questpass":22},63966,{"id":1217,"name":83,"url":1218,"thumbnail":83,"created_at":1219,"tags":83,"author":1220,"type":980,"filename":1221,"description":83,"750x750px":1222,"160x90px":1223,"365x225px":1224,"100x100px":1225,"760xautopx":1226,"1200x675px":1227},289707,"https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/0c070dcd-430f-4a14-9a22-efbe9801b624","2025-06-02 12:52:50","pixabay","0c070dcd-430f-4a14-9a22-efbe9801b624","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/11dfe0f0-c7ea-4d18-8464-e6f1de43ce9a","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/9ccd8531-4764-4811-974f-f6d693862299","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/99fe8d60-bd44-446f-abf6-05590c5ec7c7","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/5eebd414-d8ed-45b3-9988-e86645a98e2f","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/cc8b99b7-2f20-45a6-9926-fcdebe7ab0d9","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/dd19450b-a741-45cf-a342-33ecb4ef580b",[108],"\u003Cp style=\"text-align: justify;\">Przed 2. turą dwa mazowieckie miasta - \u003Cstrong>Płock i Ciechan&oacute;w\u003C/strong>- dołączyły do profrekwencyjnej akcji.&nbsp;\u003C/p>\n\u003Cp style=\"text-align: justify;\">Zasada była prosta. Wygrywa miasto, kt&oacute;rego mieszkańcy liczniej p&oacute;jdą na wybory.&nbsp;\u003C/p>\n\u003Cblockquote>\n\u003Cp>- Jeśli wygramy, to prezydent Ciechanowa Krzysztof Kosiński przed naszym ratuszem będzie częstował płocczanki i płocczan upieczonym przez siebie ciastem. Jak mieszkańcy Ciechanowa będą od nas pod tym względem lepsi, to ja pojadę z ciastem do ich miasta&nbsp; - pisał prezydent Andrzej Nowakowski.\u003C/p>\n\u003C/blockquote>\n\u003Cp style=\"text-align: justify;\">18 maja Płock wygrał ten pojedynek. Frekwencja wyniosła 67,93%, podczas gdy w Ciechanowie - 67,18%.\u003C/p>\n\u003Cp style=\"text-align: justify;\">R&oacute;żnica w drugiej turze była jeszcze mniejsza, lecz... zmienił się wygrany.\u003C/p>\n\u003Cp style=\"text-align: justify;\">W Płocku głos oddało \u003Cstrong>72,24%\u003C/strong> uprawnionych os&oacute;b, a w Ciechanowie \u003Cstrong>72,55%\u003C/strong>.&nbsp;\u003C/p>\n\u003Cp style=\"text-align: justify;\">Wynika z tego, że płocczanie będą musieli obejść się smakiem, a ciasto do Ciechanowa już niebawem zawiezie prezydent Andrzej Nowakowski.\u003C/p>",{"id":54,"frequency":54},"MBMoFe1kjUYosftt1Qrs",[1233,1234,1235,1236,1237,1238,1239,1240,1241,1242,1243,1244],"wiemy","ktory","prezydent","bedzie","piekl","ciasto","zalozyli","sie","jeszcze","przed","druga","tura","Za nami 2. tura wyborów prezydenckich. Jedna strona triumfuje, druga wręcz przeciwnie. Tym, co może jednak ucieszyć wszystkich, niezależnie od politycznych barw, jest niezwykle wysoka frekwencja. To właśnie o nią założono się jeszcze przed głosowaniem.",{"title":1247,"description":1245,"keywords":1008,"fb_cover":1248,"fb_title":54,"fb_description":54},"Wiemy, który prezydent będzie... piekł ciasto. Założyli się jeszcze przed drugą turą",{"value":1249},{"filename":54,"name":54,"tags":54,"thumbnail":54,"type":54,"url":54},[],"2025-06-02 12:53:49","Wiemy, który prezydent będzie piekł ciasto. Założyli się jeszcze przed drugą turą","wiemy-ktory-prezydent-bedzie-piekl-ciasto-zalozyli-sie-jeszcze-przed-druga-tura",[1008],[1256],{"tag":1008,"slug":1017},{"views":1258,"clicks":29},1869,"https://portalplock.pl/wiadomosci/wiemy-ktory-prezydent-bedzie-piekl-ciasto-zalozyli-sie-jeszcze-przed-druga-tura/MBMoFe1kjUYosftt1Qrs",{"view":284,"active":37,"body":377,"body_mobile":377,"slot_id":376,"show_mobile":37,"show_desktop":37,"min_height_desktop":282,"min_height_mobile":282},{"comments":1262,"status":970},[],{"articles":1264,"status":970},[1265,1305,1347,1388,1762,1809,1855,1904,1945,1990,2028,2063,2107,2149,2211,2252,2293,2335,2377,2421,2465,2505,2555,2604,2646,2683,3040,3083,3124,3165],["Reactive",1266],{"ads":22,"aid":1267,"alternative_gallery_style":22,"attachments":1268,"author":979,"author_info":29,"category":1281,"comments":22,"comments_auth":22,"content":83,"created_by":991,"created_by_name":83,"custom_html":54,"featured":29,"gallery_ads":1282,"gallery_picked":23,"id":1283,"is_advertisement":29,"is_photostory":29,"is_pool":29,"multiportal":54,"view_type":54,"is_redirect":29,"keywords":1284,"lead":1294,"locked":29,"meta":1295,"parent_domain":54,"parent_id":54,"photostory_added":23,"pool_picked":54,"pool_under_photostory":23,"premium":29,"published":37,"published_at":1299,"quiz_picked":54,"recommended":29,"redirect_url":54,"self_url":1300,"show_quiz_cover":23,"slug":1301,"sponsored":23,"short_title":1296,"tags":1302,"tagsRaw":1303,"title":1296,"type":1018,"uid":1283,"updated_at":1299},75226,[1269],{"id":1270,"name":83,"url":1271,"thumbnail":83,"created_at":1272,"tags":83,"author":1220,"type":980,"filename":1273,"description":1274,"750x750px":1275,"160x90px":1276,"365x225px":1277,"100x100px":1278,"760xautopx":1279,"1200x675px":1280,"article_id":1267},300235,"https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/cd4ff4a1-28fd-486e-8239-2155003e1f4b","2026-03-11 22:30:15","cd4ff4a1-28fd-486e-8239-2155003e1f4b","zdjęcie poglądowe","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/74257c06-5185-4b33-9b17-17e345858d84","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/ef5b0b1d-8fb5-4319-8abf-3ec5ce00923d","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/31088f61-8dca-48f3-a954-5dcb96489f98","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/13f700a7-c5c2-41fc-a7e2-7d97d80ab61e","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/55c811e2-dc6f-4d37-b945-268deb8516a5","https://storage.googleapis.com/patrykslezak-pbem/plock/articles/image/9e6d3e2e-9c84-4025-b2aa-5c7dd0180fa8",[112],{"id":54,"frequency":54},"QbZA3gLS1sWDhhT7IH0s",[1285,1286,1287,1288,1289,1290,1291,1292,1293],"kawa","rak","a","moze","dluzsze","zycie","zaskakujace","wyniki","badan","Kawa to popularny na całym świecie napój sporządzany z palonych, a następnie mielonych lub parzonych ziaren kawowca. Duża część osób nie wyobraża sobie dnia bez skosztowania tego napoju, ale są też tacy, którzy unikają kawy.",{"title":1296,"description":1294,"keywords":1285,"fb_cover":1297,"fb_title":54,"fb_description":54},"Kawa, rak, a może dłuższe życie? Zaskakujące wyniki badań",{"value":1298},{"filename":54,"name":54,"tags":54,"thumbnail":54,"type":54,"url":54},"2026-03-11 22:31:30","https://portalplock.pl/wiadomosci/kawa-rak-a-moze-dluzsze-zycie-zaskakuja
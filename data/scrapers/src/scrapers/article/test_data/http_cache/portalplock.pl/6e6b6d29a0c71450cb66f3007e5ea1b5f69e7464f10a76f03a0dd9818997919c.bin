plock/articles/image/32bd007d-2467-497b-8c45-911f8b9c109a",[112],{"id":54,"frequency":54},"evmmshk7RnKlkFQbcxBD",[1325,1326,1327,1051,1328,1329,1330,1331,1332,1333],"dwa","stopnie","alarmowe","wojewodztwie","mazowieckim","wazny","apel","do","mieszkancow","Premier Polski odpowiednim zarządzeniem przedłużył obowiązywanie stopni alarmowych. 2. stopień BRAVO i 2. stopień BRAVO-CRP obowiązują na terenie całej Polski, a więc i Mazowsza.",{"title":1336,"description":1334,"keywords":1337,"fb_cover":1338,"fb_title":54,"fb_description":54},"Dwa stopnie alarmowe w województwie mazowieckim. Ważny apel do mieszkańców","stopnie alarmowe",{"value":1339},{"filename":54,"name":54,"tags":54,"thumbnail":54,"type":54,"url":54},"2026-03-11 21:54:19","https://portalplock.pl/wiadomosci/dwa-stopnie-alarmowe-w-wojewodztwie-mazowieckim-wazny-apel-do-mieszkancow/evmmshk7RnKlkFQbcxBD","dwa-stopnie-alarmowe-w-wojewodztwie-mazowieckim-wazny-apel-do-mieszkancow",[1337],[1345],{"tag":1337,"slug":1346},"stopnie-alarmowe",["Reactive",1348],{"ads":22,"aid":1349,"alternative_gallery_style":22,"attachments":1350,"author":1362,"author_info":29,"category":1363,"comments":22,"comments_auth":22,"content":83,"created_by":1044,"created_by_name":83,"custom_html":54,"featured":29,"gallery_ads":1364,"gallery_picked":23,"id":1365,"is_advertisement":29,"is_photostory":29,"is_pool":29,"multiportal":54,"view_type":54,"is_redirect":29,"keywords":1366,"lead":1378,"locked":29,"meta":1379,"parent_domain":54,"parent_id":54,"photostory_added":23,"pool_picked":54,"pool_under_photostory":23,"premium":29,"published":37,"published_at":1383,"quiz_picked":54,"recommended":29,"redirect_url":54,"self_url":1384,"show_quiz_cover":23,"slug":1385,"sponsored":23,"short_title":1380,"tags":1386,"tagsRaw":1387,"title":1380,"type":1018,"uid":1365,"updated_at":1383},75220,[1351],{"id":1352,"name":83,"url":1353,"thumbnail":83,"created_at":1354,"tags":83,"author":1313,"type":980,"filename":1355,"description":83,"750x750px":1356,"160x90px":1
widnica24.pl\/wp-content\/uploads\/2026\/03\/curling-harmonogram-212x300.jpg 212w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/03\/curling-harmonogram-725x1024.jpg 725w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/03\/curling-harmonogram-768x1085.jpg 768w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/03\/curling-harmonogram-1088x1536.jpg 1088w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/03\/curling-harmonogram-297x420.jpg 297w\" sizes=\"(max-width: 1450px) 100vw, 1450px\" \/><\/p>\n","hash":"65829dbe1fb7ec7e59bb9e9acef6db11","visible":true,"timestamp":1773993600,"last":false,"start":"2026-03-20T08:00:00+00:00","end":"2026-03-22T17:00:00+00:00","future":true,"finished":false,"permalink":"https:\/\/swidnica24.pl\/class\/5-swidnicki-turniej-curlingowy\/?wcs_timestamp=1773993600","buttons":[],"meta":[]},{"title":"M\u0142odzie\u017cowy Turniej Jednego Wiersza w ramach \u015awiatowego Dnia Poezji","id":794511,"thumbnail":false,"thumbnail_size":false,"multiday":false,"ending":"","duration":"1h","terms":{"wcs_type":[{"slug":"co-gdzie-kiedy","id":16187,"url":null,"desc":false,"name":"Co? Gdzie? Kiedy?"}]},"period":60,"excerpt":"<p>Miejska Biblioteka Publiczna w \u015awidnicy w ramach\u00a0\u015awiatowego Dnia Poezji\u00a0zaprasza m\u0142odzie\u017c ucz\u0119szczaj\u0105c\u0105 do \u015bwidnickich szk\u00f3\u0142 ponadpodstawowych do udzia\u0142u w\u00a0autorskim konkursie poetyckim \u2013\u00a0M\u0142odzie\u017cowy Turniej Jednego Wiersza inspirowanym tw\u00f3rczo\u015bci\u0105 poet\u00f3w dwudziestolecia mi\u0119dzywojennego.<\/p>\n<p><strong>Liryczne zmagania odb\u0119d\u0105 si\u0119 20 marca o godz. 10.00 w Miejskiej Bibliotece Publicznej &#8230;<\/p>\n","hash":"483809f554fbd95b8c03441739f9cf8e","visible":true,"timestamp":1774000800,"last":false,"start":"2026-03-20T10:00:00+00:00","end":"2026-03-20T11:00:00+00:00","future":true,"finished":false,"permalink":"https:\/\/swidnica24.pl\/class\/mlodziezowy-turniej-jednego-wiersza-w-ramach-swiatowego-dnia-poezji\/?wcs_timestamp=1774000800","buttons":[],"meta":[]},{"title":"Charytatywny Turniej Pi\u0142ki Siatkowej w Strzegomiu","id":796188,"thumbnail":false,"thumbnail_size":false,"multiday":false,"ending":"","duration":"2h 20'","terms":{"wcs_type":[{"slug":"co-gdzie-kiedy","id":16187,"url":null,"desc":false,"name":"Co? Gdzie? Kiedy?"}]},"period":140,"excerpt":"<p><img decoding=\"async\" loading=\"lazy\" class=\"aligncenter size-full wp-image-796189\" src=\"https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/03\/Charytatywny-turniej-dla-Anny-Dudek.jpg\" alt=\"\" width=\"1024\" height=\"1536\" srcset=\"https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/03\/Charytatywny-turniej-dla-Anny-Dudek.jpg 1024w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/03\/Charytatywny-turniej-dla-Anny-Dudek-200x300.jpg 200w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/03\/Charytatywny-turniej-dla-Anny-Dudek-683x1024.jpg 683w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/03\/Charytatywny-turniej-dla-Anny-Dudek-768x1152.jpg 768w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/03\/Charytatywny-turniej-dla-Anny-Dudek-280x420.jpg 280w\" sizes=\"(max-width: 1024px) 100vw, 1024px\" \/><\/p>\n","hash":"8cf1cd7c3814c818a0e03db4526520ec","visible":true,"timestamp":1774087200,"last":false,"start":"2026-03-21T10:00:00+00:00","end":"2026-03-21T12:20:00+00:00","future":true,"finished":false,"permalink":"https:\/\/swidnica24.pl\/class\/charytatywny-turniej-pilki-siatkowej-w-strzegomiu\/?wcs_timestamp=1774087200","buttons":[],"meta":[]},{"title":"\u201ePrzeb\u00f3j z jajem\u201d 2026. Konkurs piosenki z humorem MDK w \u015awidnicy","id":791697,"thumbnail":false,"thumbnail_size":false,"multiday":false,"ending":"","duration":"1h","terms":{"wcs_type":[{"slug":"co-gdzie-kiedy","id":16187,"url":null,"desc":false,"name":"Co? Gdzie? Kiedy?"}]},"period":60,"excerpt":"<p>Wi\u0119cej informacji &#8211; <a href=\"https:\/\/mdk.swidnica.pl\/konkurs-dla-dzieci-i-mlodziezy-przeboj-z-jajem\/\">TUTAJ<\/a>.<\/p>\n<p><img decoding=\"async\" loading=\"lazy\" class=\"size-full wp-image-791698 aligncenter\" src=\"https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/02\/Przeboj-z-jajem-2026-plakat.jpg\" alt=\"\" width=\"416\" height=\"586\" srcset=\"https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/02\/Przeboj-z-jajem-2026-plakat.jpg 416w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/02\/Przeboj-z-jajem-2026-plakat-213x300.jpg 213w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/02\/Przeboj-z-jajem-2026-plakat-298x420.jpg 298w\" sizes=\"(max-width: 416px) 100vw, 416px\" \/><\/p>\n","hash":"a2561102fd219271e4ff6a6d645bce8f","visible":true,"timestamp":1774346400,"last":false,"start":"2026-03-24T10:00:00+00:00","end":"2026-03-24T11:00:00+00:00","future":true,"finished":false,"permalink":"https:\/\/swidnica24.pl\/class\/przeboj-z-jajem-2026-konkurs-piosenki-z-humorem-mdk-w-swidnicy\/?wcs_timestamp=1774346400","buttons":[],"meta":[]},{"title":"\"Dzie\u0144 dobry Panie Janie Marcinie!\". Fina\u0142 XXII konkursu czytelniczego w \u015awidnicy","id":794506,"thumbnail":false,"thumbnail_size":false,"multiday":false,"ending":"","duration":"1h","terms":{"wcs_type":[{"slug":"co-gdzie-kiedy","id":16187,"url":null,"desc":false,"name":"Co? Gdzie? Kiedy?"}]},"period":60,"excerpt":"<p>Miejska Biblioteka Publiczna im. Cypriana Kamila Norwida w \u015awidnicy oraz Miejskie Przedszkole Integracyjne nr 16 \u201eS\u0142oneczko\u201d zapraszaj\u0105 wszystkie \u015bwidnickie przedszkola do udzia\u0142u w wyj\u0105tkowym konkursie czytelniczym, w tym roku inspirowanym ksi\u0105\u017ck\u0105 Jana Marcina Szancera \u201ePrawdziwa historia o kocie w butach\u201d.<\/p>\n<p>Szczeg\u00f3\u0142y konkursu dost\u0119pne m.in. <a href=\"https:\/\/mbp.swidnica....\n<\/p>\n","hash":"02959fe58384b0c9be03ee4e05166cda","visible":true,"timestamp":1774519200,"last":false,"start":"2026-03-26T10:00:00+00:00","end":"2026-03-26T11:00:00+00:00","future":true,"finished":false,"permalink":"https:\/\/swidnica24.pl\/class\/dzien-dobry-panie-janie-marcinie-final-xxii-konkursu-czytelniczego-w-swidnicy\/?wcs_timestamp=1774519200","buttons":[],"meta":[]},{"title":"Wernisa\u017c pokonkursowej wystawy palm wielkanocnych w \u015awidnicy","id":794517,"thumbnail":false,"thumbnail_size":false,"multiday":false,"ending":"","duration":"1h","terms":{"wcs_type":[{"slug":"co-gdzie-kiedy","id":16187,"url":null,"desc":false,"name":"Co? Gdzie? Kiedy?"}]},"period":60,"excerpt":"<p><strong>Rozstrzygni\u0119cie konkursu oraz wernisa\u017c wystawy palm odb\u0119d\u0105 si\u0119 26 marca o godz. 11.00 w Galerii Fotografii.<\/strong> Palmy b\u0119dzie mo\u017cna jeszcze podziwia\u0107 podczas uroczystego korowodu z Galerii Fotografii do \u015awidnickiej Katedry w Niedziel\u0119 Palmow\u0105 29 marca o godz. 12.00.<\/p>\n<p>Szczeg\u00f3\u0142y konkursu &#8211; <a href=\"https:\/\/swidnica24.pl\/2026\/02\/kto-tym-razem-przygotuje-najpiekniejsza-palme-wielkanocna\/\">TUTAJ<\/a>.<\/p>\n<p><img class=\"size-full ...\n<\/p>\n","hash":"ff4627c13687a5e9b636dd979606ab5d","visible":true,"timestamp":1774522800,"last":false,"start":"2026-03-26T11:00:00+00:00","end":"2026-03-26T12:00:00+00:00","future":true,"finished":false,"permalink":"https:\/\/swidnica24.pl\/class\/wernisaz-pokonkursowej-wystawy-palm-wielkanocnych-w-swidnicy\/?wcs_timestamp=1774522800","buttons":[],"meta":[]},{"title":"I \u015awidnickie Mistrzostwa Szk\u00f3\u0142 w Rummikub","id":794514,"thumbnail":false,"thumbnail_size":false,"multiday":false,"ending":"","duration":"1h","terms":{"wcs_type":[{"slug":"co-gdzie-kiedy","id":16187,"url":null,"desc":false,"name":"Co? Gdzie? Kiedy?"}]},"period":60,"excerpt":"<p>Wi\u0119cej informacji na stronie organizatora \u2013 <a href=\"https:\/\/mbp.swidnica.pl\/2026\/02\/19\/i-swidnickie-mistrzostwa-szkol-w-rummikub\/\">TUTAJ<\/a>.<\/p>\n<p><img decoding=\"async\" loading=\"lazy\" class=\"size-full wp-image-794516 aligncenter\" src=\"https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/02\/Swidnica-Rummikub-plakat-marzec-2026.jpg\" alt=\"\" width=\"800\" height=\"419\" srcset=\"https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/02\/Swidnica-Rummikub-plakat-marzec-2026.jpg 800w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/02\/Swidnica-Rummikub-plakat-marzec-2026-300x157.jpg 300w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/02\/Swidnica-Rummikub-plakat-marzec-2026-768x402.jpg 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" \/><\/p>\n","hash":"eddafff0d23f1d0c4dedc0a87db8d9ec","visible":true,"timestamp":1774609200,"last":false,"start":"2026-03-27T11:00:00+00:00","end":"2026-03-27T12:00:00+00:00","future":true,"finished":false,"permalink":"https:\/\/swidnica24.pl\/class\/i-swidnickie-mistrzostwa-szkol-w-rummikub\/?wcs_timestamp=1774609200","buttons":[],"meta":[]},{"title":"Gminny Jarmark Wielkanocny w Pszennie","id":796190,"thumbnail":false,"thumbnail_size":false,"multiday":false,"ending":"","duration":"4h","terms":{"wcs_type":[{"slug":"co-gdzie-kiedy","id":16187,"url":null,"desc":false,"name":"Co? Gdzie? Kiedy?"}]},"period":240,"excerpt":"<p><img decoding=\"async\" loading=\"lazy\" class=\"aligncenter size-full wp-image-796163\" src=\"https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/03\/Pszenno-jarmark-wielkanocny-2026-plakat.jpg\" alt=\"\" width=\"1136\" height=\"1600\" srcset=\"https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/03\/Pszenno-jarmark-wielkanocny-2026-plakat.jpg 1136w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/03\/Pszenno-jarmark-wielkanocny-2026-plakat-213x300.jpg 213w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/03\/Pszenno-jarmark-wielkanocny-2026-plakat-727x1024.jpg 727w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/03\/Pszenno-jarmark-wielkanocny-2026-plakat-768x1082.jpg 768w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/03\/Pszenno-jarmark-wielkanocny-2026-plakat-1091x1536.jpg 1091w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/03\/Pszenno-jarmark-wielkanocny-2026-plakat-298x420.jpg 298w\" sizes=\"(max-width: 1136px) 100vw, 1136px\" \/><\/p>\n","hash":"1d0dd14a09cddf8cebd11284d9a16826","visible":true,"timestamp":1774702800,"last":false,"start":"2026-03-28T13:00:00+00:00","end":"2026-03-28T17:00:00+00:00","future":true,"finished":false,"permalink":"https:\/\/swidnica24.pl\/class\/gminny-jarmark-wielkanocny-w-pszennie\/?wcs_timestamp=1774702800","buttons":[],"meta":[]},{"title":"Korow\u00f3d z palmami wielkanocnymi w \u015awidnicy","id":794523,"thumbnail":false,"thumbnail_size":false,"multiday":false,"ending":"","duration":"30'","terms":{"wcs_type":[{"slug":"co-gdzie-kiedy","id":16187,"url":null,"desc":false,"name":"Co? Gdzie? Kiedy?"}]},"period":30,"excerpt":"<p>Tradycyjnie ze \u015bwidnickiego Rynku najpi\u0119kniejsze palmy wielkanocne w uroczystym korowodzie do katedry nios\u0105 tancerze z Zespo\u0142u Ta\u0144ca Narodowego i Estradowego \u201eKr\u0105g\u201d.<\/p>\n<p>Jeden z najwa\u017cniejszych symboli \u015bwi\u0105t wielkanocnych w wielu wyj\u0105tkowych i barwnych ods\u0142onach tworz\u0105 dzieci, m\u0142odzie\u017c i doro\u015bli na coroczny konkurs, organizowany przez \u015awidnicki O\u015b&#8230;<\/p>\n","hash":"7679c84e7f0f1613b725698a808d3798","visible":true,"timestamp":1774785600,"last":false,"start":"2026-03-29T12:00:00+00:00","end":"2026-03-29T12:30:00+00:00","future":true,"finished":false,"permalink":"https:\/\/swidnica24.pl\/class\/korowod-z-palmami-wielkanocnymi-w-swidnicy\/?wcs_timestamp=1774785600","buttons":[],"meta":[]},{"title":"Gie\u0142da Staroci, Numizmat\u00f3w i Osobliwo\u015bci w \u015awidnicy","id":794923,"thumbnail":"https:\/\/swidnica24.pl\/wp-content\/uploads\/2024\/07\/gielda-07-07-2024-9.jpg","thumbnail_size":false,"multiday":false,"ending":"","duration":"7h","terms":{"wcs_type":[{"slug":"co-gdzie-kiedy","id":16187,"url":null,"desc":false,"name":"Co? Gdzie? Kiedy?"}]},"period":420,"excerpt":"<p>Gie\u0142da Staroci, Numizmat\u00f3w i Osobliwo\u015bci odb\u0119dzie si\u0119 w niedziel\u0119, 12 kwietnia na \u015bwidnickim Rynku i okolicznych uliczkach zn\u00f3w pojawi\u0105 si\u0119 stoiska z kolekcjonerskimi monetami, starymi poczt\u00f3wkami, bi\u017cuteri\u0105, meblami, porcelanowymi i szklanymi naczyniami, a tak\u017ce innymi r\u00f3\u017cno\u015bciami. Organizatorem gie\u0142dy jest \u015awidnicki O\u015brodek Kultury.<\/p>\n<p><img class=\"...\n<\/p>\n","hash":"6c628afeff177216a050ff77562b18c0","visible":true,"timestamp":1775979000,"last":false,"start":"2026-04-12T07:30:00+00:00","end":"2026-04-12T14:30:00+00:00","future":true,"finished":false,"permalink":"https:\/\/swidnica24.pl\/class\/gielda-staroci-numizmatow-i-osobliwosci-w-swidnicy-20-2-2-2-2-2-2-2-2-2-2-2-2-2-2-2-2-2-2\/?wcs_timestamp=1775979000","buttons":[],"meta":[]},{"title":"Strzegomska zbi\u00f3rka krwi","id":786309,"thumbnail":false,"thumbnail_size":false,"multiday":false,"ending":"","duration":"4h","terms":{"wcs_type":[{"slug":"co-gdzie-kiedy","id":16187,"url":null,"desc":false,"name":"Co? Gdzie? Kiedy?"}]},"period":240,"excerpt":"<p><img decoding=\"async\" loading=\"lazy\" class=\"size-full wp-image-786307 aligncenter\" src=\"https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/01\/plakat-strzegomskie-zbiorki-krwi-2026.jpg\" alt=\"\" width=\"1000\" height=\"1414\" srcset=\"https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/01\/plakat-strzegomskie-zbiorki-krwi-2026.jpg 1000w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/01\/plakat-strzegomskie-zbiorki-krwi-2026-212x300.jpg 212w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/01\/plakat-strzegomskie-zbiorki-krwi-2026-724x1024.jpg 724w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/01\/plakat-strzegomskie-zbiorki-krwi-2026-768x1086.jpg 768w, https:\/\/swidnica24.pl\/wp-content\/uploads\/2026\/01\/plakat-strzegomskie-zbiorki-krwi-2026-297x420.jpg 297w\" sizes=\"(max-width: 1000px) 100vw, 1000px\" \/><\/p>\n","hash":"8f23f89ceb7da9c87b6b1f2341f68d19","visible":true,"timestamp":1776157200,"last":false,"start":"2026-04-1
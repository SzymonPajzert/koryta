560762f5a","parent":null,"seo_fields":{"__typename":"seo_fields","slug":"temat/sadownictwo"}},"taxonomy:9c1d59ee-73f7-4dc5-acd8-0a9298ce452c":{"__typename":"taxonomy","name":"Świat","type":"topic","id":"9c1d59ee-73f7-4dc5-acd8-0a9298ce452c","parent":null,"seo_fields":{"__typename":"seo_fields","slug":"temat/polityka-zagraniczna"}},"taxonomy:cb064e22-8e58-4667-8c41-33f36dde287f":{"__typename":"taxonomy","name":"Uchodźcy i migranci","type":"topic","id":"cb064e22-8e58-4667-8c41-33f36dde287f","parent":null,"seo_fields":{"__typename":"seo_fields","slug":"temat/uchodzcy-imigranci"}},"taxonomy:b04f5c58-8a67-470f-adb1-76df4bc14de0":{"__typename":"taxonomy","name":"Ukraina","type":"topic","id":"b04f5c58-8a67-470f-adb1-76df4bc14de0","parent":null,"seo_fields":{"__typename":"seo_fields","slug":"temat/ukraina"}},"taxonomy:b52ac18b-c839-4bf0-8613-f481da71ac6b":{"__typename":"taxonomy","name":"USA","type":"topic","id":"b52ac18b-c839-4bf0-8613-f481da71ac6b","parent":null,"seo_fields":{"__typename":"seo_fields","slug":"temat/usa"}},"taxonomy:3e2bc2bc-93df-4f25-88fd-16fce1faefb8":{"__typename":"taxonomy","name":"Wybory","type":"topic","id":"3e2bc2bc-93df-4f25-88fd-16fce1faefb8","parent":null,"seo_fields":{"__typename":"seo_fields","slug":"temat/wybory"}},"taxonomy:ee5abb5e-99a7-4eaf-9180-ffd29794b4bd":{"__typename":"taxonomy","name":"Zdrowie","type":"topic","id":"ee5abb5e-99a7-4eaf-9180-ffd29794b4bd","parent":null,"seo_fields":{"__typename":"seo_fields","slug":"temat/zdrowie"}},"content:288b487b-09f1-4b91-94dc-b2fbd11d7bc2":{"__typename":"content","id":"288b487b-09f1-4b91-94dc-b2fbd11d7bc2","title":"Premier „rozmawia z mediami”. To była PR-owa szopka z użyciem zawodowych klakierów","type":"post","publish_at":"2023-10-03T06:30:37","content":{"blocks":[{"key":"e8b3v","data":{},"text":"25 września premier Mateusz Morawiecki zamieścił na Twitterze wpis z fotografią, na której siedzi na którejś ze stacji Orlenu w gronie grupy osób. To krótka przerwa w trasie jego kampanijnego autobusu. Podpis „Kawka i sękacz z mediami :) nie ma trudnych pytań! Jedziemy dalej”.  ","type":"unstyled","depth":0,"entityRanges":[{"key":0,"length":68,"offset":209}],"inlineStyleRanges":[]},{"key":"6lqb8","data":{},"text":"Pod tweetem ironiczne wpisy. „A gdzie media?” albo „Doradcy nie są od zadawania pytań”, docinki o tym, że to „obdzwonieni” i o „wazelinie” na spotkaniu. Zaciekawiło nas, co to za media premier zaprasza na takie spotkania. Jacy to dziennikarze mogą mu zadawać pytania, a on – w domyśle – na nie odpowiada? Bo „nie ma trudnych pytań”. Tymczasem na konferencjach z udziałem dziennikarzy patrzących rządowi na ręce, Morawiecki wyślizguje się od niewygodnych pytań, ignoruje je albo wręcz jego pracownicy wyłączają pytającym mikrofony. ","type":"unstyled","depth":0,"entityRanges":[{"key":1,"length":13,"offset":459}],"inlineStyleRanges":[]},{"key":"52vv4","data":{},"text":"Sprawdziliśmy, jak bardzo „niezależne” są media, których dziennikarze mają tak dobry dostęp do premiera, że mogą z nim przegryzać ciastka na Orlenie. Dla ułatwienia ponumerowaliśmy osoby widoczne na zdjęciu opublikowanym przez Morawieckiego.","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"dmecn","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":2,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"94aio","data":{},"text":"Numer 5. Pracownica KPRM pyta premiera, czy woli „taniec czy różaniec?” ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":71,"offset":0}]},{"key":"borsv","data":{},"text":"Najbliżej premiera siedzi Paula Jakubik – jeszcze niedawno licealistka, 2 lata temu rozpoczęła studia – prawo na Uniwersytecie Kardynała Stefana Wyszyńskiego, jednej z głównych katolicko-teologicznych kuźni młodych kadr PiS. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"2fhcc","data":{},"text":"Z jej profilu na LinkedIn można wywnioskować, że ma już spore doświadczenie. Tyle tylko, że to doświadczenie związane wyłącznie z PiS i kontrolowanymi przez tę partię instytucjami i spółkami skarbu państwa. Zaczęła w Kancelarii Premiera Rady Ministrów (3 miesiące.) i NASK (2 miesiące). Potem pracowała w Totalizatorze Sportowym (pół roku). Tuż po liceum już zasiadła w zarządzie Stowarzyszenia „Dla Polski – Ruch\" Adama Andruszkiewicza. To stowarzyszenie nacjonalisty, któremu PiS dał funkcję sekretarza stanu w Ministerstwie Cyfryzacji, by przeciągnąć na swoją stronę prawicowych radykałów. Jego organizacje garściami czerpią z publicznych pieniędzy. Zaskakujące jest, że na stronach Fundacji Jakubik nie jest wymieniona jako członek zarządu. ","type":"unstyled","depth":0,"entityRanges":[{"key":3,"length":8,"offset":17},{"key":4,"length":17,"offset":438},{"key":5,"length":59,"offset":593}],"inlineStyleRanges":[]},{"key":"arloe","data":{},"text":"I najlepsze – według LinkedIn obecnie Paula Jakubik pracuje w Biurze Pełnomocnika Rządu ds. Cyberbezpieczeństwa… w Kancelarii Prezesa Rady Ministrów. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"3i8ht","data":{},"text":" A zatem jest podwładną premiera.  ","type":"blockquote","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"io6b","data":{},"text":"Jakubik PiS wciągnął już w I klasie liceum, do Parlamentu Młodych partia transferowała ją w II klasie. Czym sobie na to zasłużyła? Lokalny portal ze Szczecinka – stamtąd pochodzi – pisał, że dostała się do Sejmu Dzieci i Młodzieży po tym, jak „wykonała zadanie konkursowe, które następnie było szczegółowo oceniane”. Co ciekawe, już wtedy serwis Szczecinek.com – zaskakująco chętnie piszący o tej nastolatce – zastanawiał się, „czy będziemy mieli premier ze Szczecinka?”. Całkiem na serio. ","type":"unstyled","depth":0,"entityRanges":[{"key":6,"length":123,"offset":346}],"inlineStyleRanges":[]},{"key":"4u5f0","data":{},"text":"Znajdujemy sporo zdjęć Jakubik w sieci. Na wielu z nich jest w towarzystwie… premiera Morawieckiego. Zawsze uśmiechnięta, on także. Typowe sweet focie. Także z Andrzejem Dudą, Jarosławem Kaczyńskim, Dominikiem Tarczyńskim, Andruszkiewiczem.  ","type":"unstyled","depth":0,"entityRanges":[{"key":7,"length":22,"offset":17}],"inlineStyleRanges":[]},{"key":"cbd7j","data":{},"text":"O tym, że jest pracownikiem mediów nie ma słowa w jej LinkedIn. Ale znajdujemy ją w kampanijnych materiałach z mikrofonem w dłoni – zadającą pytania premierowi. W kampanijnym autobusie pyta na przykład o jego „największe marzenie”. Gdy Morawiecki w wielkich słowach odpowiada, wywiad zamienia się w propagandowy spot wyborczy w formie udawanego wywiadu. Z głównymi tezami PiS-u: Polska silna, bezpieczna, z niskim wiekiem emerytalnym i bez głodowych stawek wynagrodzenia oraz niebezpiecznych imigrantów. ","type":"unstyled","depth":0,"entityRanges":[{"key":8,"length":13,"offset":312}],"inlineStyleRanges":[]},{"key":"5s6er","data":{},"text":"Nieco wcześniej, w innej scenerii, ale w trakcie tego samego wyjazdu, Jakubik zadała premierowi kilka pytań, które innym przedstawicielom IV władzy nie przyszłyby do głowy: „Buty eleganckie czy sportowe?”, „Taniec czy różaniec?”, „Śniadanie w domu czy w pracy?”. Wywiad opublikowano na twitterowym profilu premiera jako materiał kampanijny. ","type":"unstyled","depth":0,"entityRanges":[{"key":9,"length":108,"offset":0}],"inlineStyleRanges":[]},{"key":"6sjj","data":{},"text":"W styczniu – gdy już według jej LinkedIn była w KPRM – pytała premiera, czy był kiedyś na pielgrzymce. Widać ją też na zdjęciach z relacji tego wydarzenia w TVP Info. ","type":"unstyled","depth":0,"entityRanges":[{"key":10,"length":29,"offset":72},{"key":11,"length":63,"offset":103}],"inlineStyleRanges":[]},{"key":"7avmo","data":{},"text":"W mediach również zdarzało jej się występować:  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"8vret","data":{},"text":"w „Wiadomościach\" TVP jako „niezależna ekspertka” krytykowała TVN i panią Joannę z Krakowa, którą po zażyciu pigułki antykoncepcyjnej policja potraktowała jak groźnego przestępcę („To wszystko nie jest oparte na faktach, to jest oparte na manipulacjach”) ","type":"unordered-list-item","depth":0,"entityRanges":[{"key":12,"length":74,"offset":180}],"inlineStyleRanges":[]},{"key":"8tgt2","data":{},"text":"Na TikToku prowadziła wielkopostne rekolekcje – co opisały m.in. portale Wiara.pl czy Misyjne.pl. ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"d3tvn","data":{},"text":"W DEM TV (834 abonentów na YT) – projekcie Fundacji Edukacji i Mediów Andruszkiewicza (też obsypywanej funduszami publicznymi) – zobaczymy ją w 6 filmikach. ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"amqvf","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":13,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"2l9ge","data":{},"text":"Numer 4. Dermokonsultantka z karierą w mediach PiS ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":50,"offset":0}]},{"key":"6tu7n","data":{},"text":"Lidia Lemaniak jeszcze w 2015 roku – jak pisał Super Express – była dermokonsultantką w aptece. I fascynowała się piłkarzem Kubą Błaszczykowskim. Wystartowała w konkursie na najładniejszą dziewczynę plaż warszawskich. I tak znalazła się pierwszy raz w mediach – na ostatniej stronie Super Expressu. Gdy partia Kaczyńskiego przejęła władzę, Lemaniak – już jesienią/ zimą 2016 roku – trafiła do mediów kontrolowanych przez rządzących. Najpierw TV Republika, potem Niezalezna.pl i „Gazeta Polska Codziennie”. Została – jak sama pisze – „dziennikarką polityczną”.  ","type":"unstyled","depth":0,"entityRanges":[{"key":14,"length":72,"offset":225}],"inlineStyleRanges":[]},{"key":"3thna","data":{},"text":"Wszystkie te tytuły uprawiają tak siermiężną propagandę, że ich zasięgi kurczyły się, aż stały się wręcz marginalne. Oglądalność TV Republika wyrażano w promilach, a obecnie wynosi ona 0,11 proc.; GPC mimo wielomilionowych zastrzyków finansowych ze spółek skarbu państwa i instytucji rządowych 2022 rok zakończyła stratą ponad 2 mln zł. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"fseg1","data":{},"text":" Nie dziwi więc transfer Lemaniak do tytułów Grupa Polska Press przejętych przez PKN Orlen w 2020 roku.  ","type":"blockquote","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"d6a1k","data":{},"text":"Tutaj też robi to, co robiła wcześniej w tytułach kontrolowanych przez PiS – uprawia propagandę rządową. Przeglądając jej twórczość na stronach PolskaTimes.pl (obecnie i.pl) można mieć wrażenie, że to biuletyn PiS. Rozmówcami Lemaniak są prawie wyłącznie politycy partii rządzącej (np. od 19 lipca 2022 do 6 sierpnia: Janusz Kowalski, Wojciech Skurkiewicz, Artur Soboń, Anna Moskwa, Magdalena Rzeczkowska, Mariusz Błaszczak, Jarosław Kaczyński). Jak mówi jeden z byłych pracowników Polski The Times – „to wywiady przeprowadzane na kolanach”. Rozmowy Lemaniak są zazwyczaj ripostą na krytykę płynącą z innych mediów lub suflują aktualny przekaz Nowogrodzkiej – w zdecydowanie nieskalanej jakimikolwiek trudnymi pytaniami formie. Dla przykładu – od 24 do 25 września 2023 Lemaniak opublikowała na portalu i.pl aż 3 teksty z ministrem Piotrem Glińskim w roli głównej, z krytycznymi wypowiedziami wobec opozycji. Próżno szukać próby uzyskania odpowiedzi na te zarzuty ze strony oskarżanych. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"9emov","data":{},"text":"W portalowej twórczości Lemaniak Politycy PiS są pokazywani w dobrym świetle, zaś ci z PO – dokładnie odwrotnie. Tusk to „polityk skompromitowany, symbol języka nienawiści”, który „zrobi to, co każą mu Niemcy”, a Trzaskowski nie radzi sobie z inwestycjami w stolicy. Film Holland jest „antypolski”, to „ojkofobiczna produkcja”, która „zdobyłaby nagrodę w Mińsku” – to powtarzane przekazy dnia, jakie dostają do rozpowszechniania posłowie, senatorowie i media PiSu. Jota w jotę.","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"4eupq","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":15,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"5mudp","data":{},"text":"Numer 3. Polsat News – stacja, w której premierowi nie spadnie włos z głowy ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":75,"offset":0}]},{"key":"7vg1s","data":{},"text":"Nr 3 to Piotr Witkowski – reporter z Polsat News. Pytamy go, czy na tym spotkaniu z premierem padły jakieś trudne pytania. Waha się, co uznać za trudne. „Były pytania dotyczące kontroli granicy polsko-niemieckiej, która została przez Niemców zapowiedziana. Ale to był bardzo krótki przystanek, przerwa techniczna na kilka minut, więc tylko small talk – trudno nawet mówić o atmosferze do zadawania trudnych pytań – tłumaczy reporter. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"b5l9h","data":{},"text":"Witkowski jest od dawna oddelegowany do relacjonowania tego, co robi i mówi premier. „Przyspawany do premiera” – tak mi mówią byli pracownicy tej stacji. Czy zadaje premierowi trudne pytania? „Chyba pan żartuje?” prycha jego kolega. I uzupełnia, że Witkowski nawet nie może ich zadawać. Stacje Grupy Polsat Plus, należące do jednego z najbogatszych Polaków Zygmunta Solorza, od co najmniej 5 lat – czyli od przejęcia sterów informacji przez Dorotę Gawryluk – sprzyjają rządzącym. Pisał o tym branżowy magazyn PRESS. Dwa lata temu polityczne naciski na dziennikarzy spowodowały odpływ rasowych reporterów z Polsatu. ","type":"unstyled","depth":0,"entityRanges":[{"key":16,"length":22,"offset":492}],"inlineStyleRanges":[]},{"key":"6rmo9","data":{},"text":"Jakie naciski? Gdy tematem był Polski Ład, reporterka „Wydarzeń” – głównego dziennika Polsatu – dostała „prikaz”, by każdą wypowiedź opozycji kontrować setką Morawieckiego. Gdy stwierdziła, że w takim razie w materiale znajdzie się aż 8 setek premiera, wydawca stwierdził, że „tak ma być” – opisywał PRESS. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"cj1se","data":{},"text":"„Gdy próbowałem zadać trudne pytanie premierowi na temat kryzysu na granicy, pani z KPRM powiedziała, że nie ma już pytań. Uparłem się. Za chwilę miałem telefon od zastępcy Gawryluk, że nie ma pytań i mam się wycofać z kolejki” – opisuje nasz rozmówca z Polsatu. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"cbu3","data":{},"text":"„Na spotkaniach z premierem tylko dwie stacje – jak mówi nam stały bywalec takich meetingów – dają sobie ustawiać kadry przez pracowników KPRM, aby premier dobrze w nich wypadł. To TVP i… Polsat właśnie. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"dp0bi","data":{},"text":"Współpraca Polsatu z rządem PiS w uprawianiu „miękkiej propagandy” (określenie Romana Imielskiego, wicenaczelnego „Gazety Wyborczej”), przeszczepiana do innych mediów uchodzących za „wolne”, zyskała wśród medioznawców swoje określenie – polsatyzacji. To przemilczanie lub prześlizgiwanie się po niewygodnych dla władzy tematach. Korzystna prezentacja rządzących i łagodne traktowanie nawet najbardziej oczywistych ich przewin. W zamian za ogromne wpływy i zasięgi. Z budżetów reklamowych spółek skarbu państwa stacje Polsatu dostają więcej pieniędzy niż nawet TVP. A redaktorzy i pracownicy Grupy Polsat Plus prawie w ogóle nie biorą udziału w protestach mediów i dziennikarzy. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"f3grs","data":{},"text":"Kiedy 1,5 roku temu pytałem rzecznika Polsatu o 5 afer rządu, jakie wykryli dziennikarze Polsatu, nie wymienił ani jednej. Teraz zapytałem, czy reporterzy Polsat News zadają trudne pytania premierowi Morawieckiemu, a jeśli tak, to prosiłem o przykłady z ostatniego tygodnia lub dwóch. „Pan tak na poważnie?” odpisał Tomasz Matwiejczuk. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"4eshk","data":{},"text":"Numer 1. PAP – Polska Agencja PiSowa ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":36,"offset":0}]},{"key":"5a53b","data":{},"text":"Pod nr 1 jest Grzegorz Bruszewski z Polskiej Agencji Prasowej. Nie chce rozmawiać z OKO.press. „Nie jestem upoważniony” tłumaczy. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"dfa2","data":{},"text":"PAP to w pełni kontrolowane przez PiS medium – w radzie programowej i nadzorczej są byli posłowie i fanatycznie wierni ludzie PiS (jak Maciej Świrski). PAP uprawia propagandę na rzecz partii, tylko w sposób nieco subtelniejszy niż TVP. Kilkanaścioro obecnych i byłych pracowników PAP opowiedziało mi o upolitycznieniu tej instytucji w czasach „dobrej zmiany”. ","type":"unstyled","depth":0,"entityRanges":[{"key":17,"length":96,"offset":236}],"inlineStyleRanges":[]},{"key":"1t0ga","data":{},"text":"Co robi PAP? Depesze, które nie spodobają się komuś w PiS, są wycofywane, albo cenzurowane, zanim się ukażą, lub ich publikacja jest przewlekana. Tematy niewygodne dla rządzących są blokowane albo mocno marginalizowane. Wygumkowuje się nawet nieprawomyślne zdjęcia. Na fotkach PAP-u ze słynnego Marszu Równości w Białymstoku w 2019 roku nie zobaczysz wściekłych nacjonalistów, którzy kopali uczestników i rzucali w nich kamieniami i fekaliami. Uczestnicy natomiast są radośni i uśmiechnięci – a nie przerażeni. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"cd3dh","data":{},"text":"Ludzie PiS także mają być przez fotoreporterów PAP ładnie przedstawiani. Każda konferencja posłów, wojewodów, a nawet radnych PiS musi być w PAP opisana, zwłaszcza jeśli jest poświęcona „sukcesom” partii. Powstaje więc nawet po kilka depesz z jednej konferencji. Łamana jest kluczowa zasada dziennikarstwa – miejsce na opinię drugiej strony. W depeszach PAP albo brak opinii opozycji, albo to zdanie członków PiS ma dominować.  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"bv1gq","data":{},"text":"W PAP nie przeczytasz zbyt wiele o mailach ze skrzynki min. Dworczyka ujawnianych regularnie przez Poufną Rozmowę. Są ignorowane. To o tyle zrozumiałe, że kilka z tych maili ujawniło, jak usłużny wobec partii jest prezes PAP Wojciech Surmacz. Na prośbę z KPRM wysłał „sprytnego dziennikarza” na wywiad – ustawkę z Andrzejem Dudą. Doradzał premierowi przy pozycjonowaniu go w mediach zagranicznych, chwalił się wynikami w tym zakresie. Politycy PIS pisali o wspólnych, propagandowych działaniach z Surmaczem… ","type":"unstyled","depth":0,"entityRanges":[{"key":18,"length":72,"offset":435}],"inlineStyleRanges":[]},{"key":"5c80q","data":{},"text":"Nieprawomyślni dziennikarze są wyrzucani z PAP lub sami odchodzą. Niektórzy dostają do podpisania zakaz mówienia o tym, co dzieje się w agencji. Za jego złamanie grozi 10 tys. zł kary. Ich miejsca zajmują ludzie z propagandowych mediów PiS, szkoły Rydzyka, czy z brukowców – bez zasad, za to z giętkimi kręgosłupami. Jeden z pracowników PAP powiedział mi: „ja się czuję jakbym pracował w jaczejce, albo szulerni”. Inny: „PAP nie jest już agencją prasową. To patologiczne skrzyżowanie systemu dystrybucji informacji prasowych rządu z tłumaczeniami z zagranicy”. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"ban12","data":{},"text":"Numer 2. „Może to jakiś polityk?” ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":33,"offset":0}]},{"key":"5p3ob","data":{},"text":"Jednego z widocznych ludzi „mediów” – nr 2 – nie udało nam się zidentyfikować z imienia i nazwiska. Jeszcze. Nie zna go żaden z uczestników spotkania, z którymi rozmawialiśmy ani dziennikarze polityczni (i nie tylko), do których się zwracaliśmy. „Może to jakiś polityk?” – zastanawiał się Grzegorz Bruszkowski. Nie rozpoznali go też internauci, mimo ponad 35 tys. wyświetleń tweeta i posta w tej sprawie. Jego twarz przewija się w mediach kontrolowanych przez PiS: TV Republika, „Gazetę Polską”, Radio Opole, Radio Lublin czy Fundacji Służba Niepodległej i Wojskach Ochrony Terytorialnej. Postaramy się ustalić personalia i tego człowieka „mediów” o jakże uprzywilejowanej pozycji.","type":"unstyled","depth":0,"entityRanges":[{"key":19,"length":17,"offset":364}],"inlineStyleRanges":[]},{"key":"a65h6","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":20,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"85jtc","data":{},"text":"„To tylko grzanie się w świetle reflektorów i dziennikarzy. Nic innego\" ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":71,"offset":0}]},{"key":"7gde2","data":{},"text":"Na takie przejażdżki kampanijnym autobusem, jak ta, z której tweetował premier, nie są zapraszani dziennikarze z mediów, które zadają przedstawicielom trudne pytania. Zapytaliśmy o to troje reporterów politycznych z różnych redakcji – żadne z nich nie zostało uhonorowane możliwością zadawania pytań premierowi w podobnych okolicznościach. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"7hn27","data":{},"text":"Maciej Knapik – reporter Faktów „TVN” – dziwi się i nie wie, czemu go nie zaproszono. „A chciałbym tam siedzieć z innymi. Zapytałbym premiera o aferę wizową, nasze stosunki z EU, brak pieniędzy z KPO, majątek pani Morawieckiej – mówi. Wielokrotnie wyłączano mu mikrofon na konferencjach PiS czy premiera, odbierano mu głos. Tylko ostatnio wydarzyło się to 2 razy. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"2qvrm","data":{},"text":"Justyna Dobrosz-Oracz z „Gazety Wyborczej” też żałuje: „Codziennie mam setki pytań do premiera, których zadać nie mogę”. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"916nj","data":{},"text":"Roch Kowalski z RMF FM już nie ma złudzeń. „Chodzenie na tego typu eventy ma średni sens. Po to są właśnie robione, by była taka sweet focia i hasło, że nie boimy się trudnych pytań. To tylko grzanie się w świetle reflektorów i dziennikarzy. Nic innego”. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"31rov","data":{},"text":"Dziennikarka polityczna OKO.press Agata Szczęśniak całkiem niedawno odwiedziła konwencję Prawa i Sprawiedliwości w Końskich. Razem z innymi reporterami niezależnych mediów trafiła tam do przygotowanego przez organizatorów... kojca.","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"dnj4q","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":21,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"lgmj","data":{},"text":"Kawy ani sękacza w kojcu nie podawano. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"dtt62","data":{},"text":"PS. Jeśli znasz personalia osoby nr 2, proszę o maila na adres redakcja@oko.press","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"ITALIC","length":81,"offset":0}]}],"entityMap":{"0":{"data":{"url":"https://twitter.com/MorawieckiM/status/1706237088759193848","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"1":{"data":{"url":"https://twitter.com/tvn24/status/1706605801471709289","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"2":{"data":{"id":"339b3d8c-d74e-4eb2-9f48-6c4b0a3d2463","layout":"column","caption":"Spotkanie premiera Mateusza Morawieckiego z mediami (źródło: Twitter)"},"type":"IMAGE","mutability":"IMMUTABLE"},"3":{"data":{"url":"https://www.linkedin.com/in/paula-jakubik-57b7bb20b/","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"4":{"data":{"slug":"na-prawo-od-pis-ale-blisko-pis-andruszkiewicz-zaklada-nowa-sile-polityczna-antyunijna-i-anty-tuskowa","type":"LEGACY_INTERNAL"},"type":"LINK","mutability":"MUTABLE"},"5":{"data":{"slug":"niw-11-mln-zl-ngo-nacjonalistyczne-katolickie","type":"LEGACY_INTERNAL"},"type":"LINK","mutability":"MUTABLE"},"6":{"data":{"url":"https://szczecinek.com/artykul/bedziemy-mieli-premier/868111","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"7":{"data":{"url":"https://pimeyes.com/en/results/Kg9_230925ogADoBUWsIkOaRM77fa4732?query=f0ffb1b03030d0fedc9c9c1c3c1c1c1e98f8b1d3c86472d6","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"8":{"data":{"url":"https://www.facebook.com/100063717782114/videos/1407103286910371/","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"9":{"data":{"url":"https://twitter.com/MorawieckiM/status/1706367566459883726","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"10":{"data":{"url":"https://twitter.com/jakubik_paula?fbclid=IwAR3tncxaqkGOQ0O4esbSbOGe-CkZCZve8XpXXkrUGT3ZBTF-o71tuXaJHJo","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"11":{"data":{"url":"https://twitter.com/tvp_info/status/1616152123762147356?ref_src=twsrc%5Etfw%7Ctwcamp%5Etweetembed%7Ctwterm%5E1616152123762147356%7Ctwgr%5E347af92e0562960adffc8c5f8a23904a828dacc5%7Ctwcon%5Es1_\u0026ref_url=https%3A%2F%2Fszczecinek.com%2Fartykul%2Fpaula-jakubik-mateusz%2F1395748","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"12":{"data":{"url":"https://www.press.pl/tresc/77583,wedlug-tvp-opozycja_-donald-tusk-i-tvn_-dzialajac-wspolnie_-skrzywdzili-pania-joanne-z-krakowa","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"13":{"data":{"nodes":["9ef5988b-8db6-4561-8c8c-db5ba18a3fe3"]},"type":"RELATED_CONTENTS","mutability":"IMMUTABLE"},"14":{"data":{"url":"https://www.se.pl/warszawa/wakacyjna-miss-super-expressu-lidia-fanka-blaszczykowskiego-aa-7Mhz-Vp6c-8SVH.html","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"15":{"data":{"nodes":["049ed805-9161-4b7e-971c-648b2a8f2376"]},"type":"RELATED_CONTENTS","mutability":"IMMUTABLE"},"16":{"data":{"url":"https://www.press.pl/magazyn-press/artykul/68766,stacja-do-wysiadania","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"17":{"data":{"url":"https://www.press.pl/magazyn-press/artykul/67844,polska-agencja-pisowa","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"18":{"data":{"url":"https://www.wirtualnemedia.pl/artykul/michal-dworczyk-wyciekly-maile-prezes-pap-wojciech-surmacz","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"19":{"data":{"url":"https://twitter.com/Bacon227/status/1706305918072164728","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"20":{"data":{"nodes":["5f480c5d-c8d1-4d33-a0c0-da534e19aa1a"]},"type":"RELATED_CONTENTS","mutability":"IMMUTABLE"},"21":{"data":{"value":"https://twitter.com/oko_press/status/1700454795125940587"},"type":"EMBED_TWITTER","mutability":"IMMUTABLE"}}},"member_only_for_x_day":14,"display_at_homepage":true,"additional_label":"Morawiecki pochwalił się spotkaniem z ludźmi „mediów”, na którym „nie było trudnych pytań”. Sprawdziliśmy. To dlatego, że na spotkaniu nie było ani jednego dziennikarza, który mógłby zadać trudne pytania, tylko sami propagandziści albo pracownicy mediów pokornych wobec władzy","featured_image":{"__typename":"assets","original_url":"https://oko.press/images/2023/09/20230929-klakierzy.png","sizes":{},"credit":"źródło: Twitter","caption":"grupa osób siedząca przy stole z kawą i ciastkami","alt":"grupa osób siedząca przy stole z kawą i ciastkami"},"gallery_images_aggregate({\"limit\":3})":{"__typename":"gallery_images_aggregate","aggregate":{"__typename":"gallery_images_aggregate_fields","count":0},"nodes":[]},"live_updates({\"order_by\":{\"timestamp\":\"desc\"}})":[],"seo_fields":{"__typename":"seo_fields","slug":"premier-rozmawia-z-mediami-pr-owa-szopka","meta_title":"Premier rozmawia z mediami? To PR-owa szopka udziałem klakierów","meta_description":"Morawiecki pochwalił się spotkaniem z ludźmi „mediów” na którym „nie było trudnych pytań”. Dlatego, że na spotkaniu byli sami propagandziści","meta_keyword":"autobus morawieckiego","meta_image":{"__typename":"assets","original_url":"https://oko.press/images/2023/09/20230929-klakierzy.png","sizes":{},"credit":"źródło: Twitter","caption":"grupa osób siedząca przy stole z kawą i ciastkami","alt":"grupa osób siedząca przy stole z kawą i ciastkami"},"facebook_title":"Premier \"rozmawia z mediami\". To była PR-owa szopka z użyciem zawodowych klakierów","facebook_description":"","facebook_image":{"__typename":"assets","original_url":"https://oko.press/images/2023/09/20230929-klakierzy.png","sizes":{},"credit":"źródło: Twitter","caption":"grupa osób siedząca przy stole z kawą i ciastkami","alt":"grupa osób siedząca przy stole z kawą i ciastkami"},"twitter_title":"Premier „rozmawia z mediami”. To była PR-owa szopka z użyciem zawodowych klakierów","twitter_description":"","twitter_image":{"__typename":"assets","original_url":"https://oko.press/images/2023/09/20230929-klakierzy.png","sizes":{},"credit":"źródło: Twitter","caption":"grupa osób siedząca przy stole z kawą i ciastkami","alt":"grupa osób siedząca przy stole z kawą i ciastkami"},"meta_robots_index":true,"meta_robots_follow":true},"metadata_authors":[{"__typename":"metadata_authors","author":{"__typename":"authors","name":"Boczek","first_name":"Krzysztof"}}],"metadata_taxonomy({\"where\":{\"_or\":[{\"taxonomy\":{\"type\":{\"_eq\":\"topic\"}}},{\"taxonomy\":{\"type\":{\"_eq\":\"category\"}}}]}})":[{"__typename":"metadata_taxonomy","taxonomy":{"__ref":"taxonomy:0fefbac4-bb51-4eaa-996b-549c80fb09f3"}},{"__typename":"metadata_taxonomy","taxonomy":{"__ref":"taxonomy:3e2bc2bc-93df-4f25-88fd-16fce1faefb8"}},{"__typename":"metadata_taxonomy","taxonomy":{"__ref":"taxonomy:9c4602e5-4996-41af-a931-890a3f186cef"}}],"podcast_fields":null,"audio_reportage_fields":null,"text_to_speech":"disabled","voice":null,"status":"published"},"taxonomy:1a5e95bd-4b62-41e5-be2f-f9ee1cdbb65a":{"__typename":"taxonomy","name":"Sukcesy OKO.press","type":"category","id":"1a5e95bd-4b62-41e5-be2f-f9ee1cdbb65a"},"taxonomy:75a6024a-4d96-4df1-b621-8d8f552f137f":{"__typename":"taxonomy","name":"Prześwietlamy","type":"category","id":"75a6024a-4d96-4df1-b621-8d8f552f137f"},"content:d0f27def-2941-445a-850c-54375a75e0d7":{"__typename":"content","id":"d0f27def-2941-445a-850c-54375a75e0d7","title":"Instytut Glińskiego rozdał 11 mln zł organizacjom nacjonalistycznym, katolickim i PiS-owskim","type":"post","publish_at":"2021-05-03T08:27:38","content":{"blocks":[{"key":"1sso9","data":{},"text":"W piątek 30 kwietnia Narodowy Instytut Wolności ogłosił wyniki trzech konkursów grantowych. Instytucja podlegająca ministrowi kultury Piotrowi Glińskiemu rozdała w nich organizacjom pozarządowym 11 milionów złotych.  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"5ffhb","data":{},"text":"Wszystkie trzy konkursy mieszczą się w Programie Rozwoju Organizacji Obywatelskich NIW (PROO):  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"2k3v2","data":{},"text":"PROO 2a wspiera budowanie przez NGO’sy tzw. kapitałów żelaznych,  ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"b66hj","data":{},"text":"PROO 3 finansuje “organizacje strażnicze i media obywatelskie”,  ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"bama4","data":{},"text":"a PROO 4a rozwój “think tanków obywatelskich”.  ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"fu13j","data":{},"text":"W pierwszym konkursie sześć NGO’sów dostało po 480-500 tys. zł. W dwóch kolejnych po 4 miliony złotych podzielono pomiędzy odpowiednio 21 i 15 organizacji. Maksymalna dotacja wynosiła 200 tys. zł rozłożone na lata 2021-2022.  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"pkjc","data":{},"text":"Przyjrzeliśmy się dofinansowanym projektom i władzom zwycięskich NGO’sów. Okazało się, że podobnie jak w poprzednich rozdaniach w znacznej części pieniądze trafiły do NGO’sów powiązanym z władzą i realizujących jej cele. Najlepsze wnioski według NIW składały organizacje nacjonalistyczne, kościelne oraz kierowane przez polityków PiS i członków ich rodzin.  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"9nnn","data":{},"text":"Zastrzyk pieniędzy dostały m.in. organizacje:  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"erjvn","data":{},"text":"organizatorów Marszu Niepodległości na stworzenie warszawskiego portalu; ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"fst8m","data":{},"text":"żony współpracownika Adama Andruszkiewicza na \"portal dla młodych\"; ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"8rn21","data":{},"text":"liderów Ordo Iuris na fundację zajmującą się edukacją; ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"6nhsk","data":{},"text":"Archidiecezji Warszawsko-Praskiej na media relacjonujące życie diecezji; ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"3jvs1","data":{},"text":"Józefa Orła, współzałożyciela Porozumienia Centrum, pierwszej partii Kaczyńskich; ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"1239m","data":{},"text":"Anny Bieleckiej, do której Jarosław Kaczyński chadza na niedzielne obiady.  ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"ama7p","data":{},"text":"Dla przyjaciółki Kaczyńskiego ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":29,"offset":0}]},{"key":"621bj","data":{},"text":"W pierwszym konkursie (PROO 2a) NIW finansuje budowanie tzw. kapitałów żelaznych. Są to nienaruszalne środki, które zapewniają stabilność organizacji pozarządowej i pozwalają na czerpanie dochodu z ich inwestowania. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"61mkl","data":{},"text":"W poprzednim rozdaniu w tym konkursie, jak pisaliśmy, wygrała m.in. Fundacja Republikańska, think-tank, będący zapleczem kadrowym PiS oraz Muza Dei, powiązane z Markiem Jurkiem stowarzyszenie promujące kulturę katolicką. Wśród beneficjentów były jednak także uznane NGO’sy, takie jak Fundacja ePaństwo i Fundacja Dajemy Dzieciom Siłę. ","type":"unstyled","depth":0,"entityRanges":[{"key":0,"length":21,"offset":0},{"key":1,"length":22,"offset":68},{"key":2,"length":8,"offset":139}],"inlineStyleRanges":[]},{"key":"22vva","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":3,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"9d0v7","data":{},"text":"W tym rozdaniu co najmniej dwie z sześciu wygranych organizacji są powiązane z władzą, a dwie kolejne promują katolicyzm. ","type":"unstyled","depth":0,"entityRanges":[{"key":4,"length":14,"offset":0}],"inlineStyleRanges":[]},{"key":"f33cv","data":{},"text":"500 tys. zł. dostała m.in. Fundacja Polska Wielki Projekt. Jej prezeską jest architektka Anna Bielecka, pierwsza żona Czesława Bieleckiego, kandydata PiS na prezydenta Warszawy w wyborach w 2010 roku. W jej domu odbywają się słynne niedzielne z udziałem Jarosława Kaczyńskiego. Jak pisała “Wyborcza”, “tam mają wykuwać się takie pomysły jak prezesura Trybunału Konstytucyjnego dla Julii Przyłębskiej”.  ","type":"unstyled","depth":0,"entityRanges":[{"key":5,"length":6,"offset":282}],"inlineStyleRanges":[{"style":"BOLD","length":12,"offset":0},{"style":"BOLD","length":30,"offset":27}]},{"key":"1v5dj","data":{},"text":"W radzie programowej fundacji zasiadają politycy PiS. Między innymi Minister Gliński, który nadzoruje NIW, Wanda Zwinogrodzka, podsekretarz stanu w jego ministerstwie, Jacek Czaputowicz, były szef MSZ, europosłowie PiS Zdzisław Krasnodębski i Ryszard Legutko. ","type":"unstyled","depth":0,"entityRanges":[{"key":6,"length":27,"offset":2}],"inlineStyleRanges":[]},{"key":"e5jsv","data":{},"text":"Fundacja od 10 lat organizuje kongres “Polska Wielki Projekt”. W 2020 przemawiał na nim m.in. Mateusz Morawiecki. W trakcie kongresu przyznawana jest nagroda im. Lecha Kaczyńskiego dla „twórców prawych i sprawiedliwych”, którzy są „dumnymi Polakami” i jednocześnie wybitnymi artystami. Ostatnio otrzymał ją Bronisław Wildstein, prawicowy dziennikarz i pisarz. ","type":"unstyled","depth":0,"entityRanges":[{"key":7,"length":24,"offset":88},{"key":8,"length":40,"offset":286}],"inlineStyleRanges":[]},{"key":"ei4hq","data":{},"text":"Fundacja Polska Wielki Projekt jednocześnie w tym samym rozdaniu otrzymała 291.722,5 zł z NIW w programie PROO 4a na rozbudowę działalności think-tankowej. Razem: 791.721,5 zł. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":12,"offset":163}]},{"key":"14q9u","data":{},"text":"Dla druhów Morawieckiego i Ordo Iuris ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":37,"offset":0}]},{"key":"afb38","data":{},"text":"500 tys. zł dostała też Fundacja Pomorska Inicjatywa Historyczna, zajmująca się upamiętnianiem działań opozycji na Pomorzu. Jej wiceprezesem jest Roman Zwiercan, mąż Małgorzaty Zwiercan. Oboje byli członkami Solidarności Walczącej, kierowanej przez Kornela Morawieckiego, zmarłego ojca premiera. Małgorzata była posłanką w jego kole “Wolni i Solidarni”. Zasłynęła głosowaniem w Sejmie “na cztery ręce” za siebie i starszego Morawieckiego pod jego nieobecność. W wyborach parlamentarnych w 2019 roku nie odniosła sukcesu. Za to już w 2019 roku znalazła pracę jako ekspertka w Kancelarii Prezesa Rady Ministrów. ","type":"unstyled","depth":0,"entityRanges":[{"key":9,"length":40,"offset":24},{"key":10,"length":37,"offset":364},{"key":11,"length":14,"offset":543}],"inlineStyleRanges":[{"style":"BOLD","length":11,"offset":0},{"style":"BOLD","length":40,"offset":24}]},{"key":"qvlq","data":{},"text":"Kolejne pół miliona złotych powędrowało do Fundacji Edukacja do Wartości. W jej zarządzie zasiadają Tymoteusz Zych i Jerzy Kwaśniewski. Ci sami, którzy kierują Instytutem na rzecz Kultury Prawnej Ordo Iuris. Edukację do Wartości zarejestrowali w KRS-ie w marcu 2020 roku. Nie ma jeszcze swojej strony ani żadnych osiągnięć. Wśród jej deklarowanych zadań jest m.in. “działalność na rzecz nauki oraz szkolnictwa wyższego” oraz “wspieranie inicjatyw społecznych, w tym zakorzenionych w myśli organicznej i nauce społecznej kościoła katolickiego”. ","type":"unstyled","depth":0,"entityRanges":[{"key":12,"length":29,"offset":43}],"inlineStyleRanges":[{"style":"BOLD","length":29,"offset":43}]},{"key":"598r","data":{},"text":"Promowaniem katolicyzmu zajmuje się też Stowarzyszenie “Sanctus Paulus”, które też dostało 500 tys. zł. Wydaje ono portal katolicka.bydgoszcz.pl, wspiera bydgoskich misjonarzy oraz “pielęgnuje polskość”. ","type":"unstyled","depth":0,"entityRanges":[{"key":13,"length":16,"offset":55}],"inlineStyleRanges":[{"style":"BOLD","length":16,"offset":55},{"style":"BOLD","length":11,"offset":91}]},{"key":"52eb2","data":{},"text":"480 tys. zł powędrowało do Fundacji Instytut im. Kazimierza Promyka, skupiającej młodych ekspertów ze środowiska Niezależnego Zrzeszenia Studentów. Jej prezeska Maria Cholewińska kieruje też Fundacją Alumni NZS. A jak pisała “Rzeczpospolita” w styczniu 2021 roku, Niezależne Zrzeszenie Studentów nie jest takie niezależne. Wspierało ustawy Gowina, a ostatnio zapowiedziało “owocną współpracę” po spotkaniu z min. Przemysławem Czarnkiem. Jest wspierane przez spółki Skarbu Państwa, a jej byli liderzy znajdują pracę w partii. Michał Moskal, były przewodniczący zarządu krajowego, w 2020 roku jako 26-latek został Dyrektorem Biura Prezydialnego PiS. ","type":"unstyled","depth":0,"entityRanges":[{"key":14,"length":40,"offset":27},{"key":15,"length":23,"offset":218},{"key":16,"length":6,"offset":605}],"inlineStyleRanges":[{"style":"BOLD","length":11,"offset":0},{"style":"BOLD","length":40,"offset":27}]},{"key":"cavp9","data":{},"text":"Instytut Promyka podobnie jak Polska Wielki Projekt w tym rozdaniu dostał też grant z NIW w konkursie na rozbudowę działalności think-tankowej. Razem: 748.239,39 zł. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":13,"offset":151}]},{"key":"4o5hp","data":{},"text":"Strażnicze media nacjonalistyczne ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":33,"offset":0}]},{"key":"c47ms","data":{},"text":"Konkurs PROO 4a dofinansować miał media obywatelskie oraz organizacje strażnicze. Jak czytamy w poradniku NIW-u media obywatelskie to takie, które publikują treści ważne z punktu widzenia społeczności lokalnej lub regionalnej o tematyce lokalnej lub branżowej. ","type":"unstyled","depth":0,"entityRanges":[{"key":17,"length":15,"offset":96}],"inlineStyleRanges":[]},{"key":"54v2d","data":{},"text":"Natomiast organizacje strażnicze kontrolują działania władz publicznych lub instytucji prywatnych, monitorują procesy legislacyjne i lobbują za pozytywnymi zmianami w sferze publicznej. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"375nl","data":{},"text":"W tym rozdaniu wyjątkowo dużo znakomitych wniosków napisały media nacjonalistyczne oraz katolickie. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"13tck","data":{},"text":"196.811,59 zł na lata 2021-2022 dostała Fundacja Edukacji i Mediów na portaldlamlodych.pl (jeszcze nieaktywny). Prezeską zarejestrowanej w listopadzie 2020 r. fundacji jest Marta Tenerowicz. To żona Krzysztofa Tenerowicza, bliskiego współpracownika Adama Andruszkiewicza, obecnie sekretarza stanu w kancelarii premiera, a wcześniej wiceministra cyfryzacji. ","type":"unstyled","depth":0,"entityRanges":[{"key":18,"length":26,"offset":40}],"inlineStyleRanges":[{"style":"BOLD","length":13,"offset":0},{"style":"BOLD","length":26,"offset":40}]},{"key":"34g8m","data":{},"text":"Tenerowicz i Andruszkiewicz ściśle współpracują co najmniej od 2015 roku, kiedy obaj zasiadali we władzach Ruchu Narodowego. W 2018 roku wspólnie zakładali Stowarzyszenie Dla Polski - Ruch Adama Andruszkiewicza. Dziś Tenerowicz kieruje kilkoma fundacjami, otrzymującymi rządowe dotacje i zasiada w radzie nadzorczej Dalmoru, spółki z udziałem Skarbu Państwa. ","type":"unstyled","depth":0,"entityRanges":[{"key":19,"length":11,"offset":48},{"key":20,"length":7,"offset":316}],"inlineStyleRanges":[]},{"key":"39ome","data":{},"text":"Jak pisaliśmy, Tenerowicz kierował endeckim portalem prostozmostu.net, który w 2018 roku intensywnie promował Andruszkiewicza. Korzystał przy tym ze wsparcia siatki fanpage’y używanej do szerzenia fake newsów i rosyjskiej propagandy, którą Facebook rozwiązał w po śledztwie OKO.press i aktywistów Avaaz. ","type":"unstyled","depth":0,"entityRanges":[{"key":21,"length":50,"offset":158},{"key":22,"length":34,"offset":249}],"inlineStyleRanges":[]},{"key":"cvlhd","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":23,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"6mcll","data":{},"text":"Warszawski portal Marszu Niepodległości ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":39,"offset":0}]},{"key":"2h7vn","data":{},"text":"Kolejnym nacjonalistycznym medium wspartym przez NIW jest portal medianarodowe.com. Na rozwinięcie warszawskiego “obywatelskiego portalu lokalnego” 198.172,30 zł dostało wydające Media Narodowe Stowarzyszenie Marszu Niepodległości. To samo, które co roku 11 listopada organizuje przemarsz nacjonalistów przez centrum Warszawy. W październiku 2020 jego prezes Robert Bąkiewicz w odpowiedzi na apel Jarosława Kaczyńskiego o obronę kościołów przed strajkującymi kobietami powołał Straż Narodową.","type":"unstyled","depth":0,"entityRanges":[{"key":24,"length":22,"offset":469}],"inlineStyleRanges":[{"style":"BOLD","length":13,"offset":148},{"style":"BOLD","length":36,"offset":194}]},{"key":"3cd5i","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":25,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"7taaq","data":{},"text":"Nacjonalistyczna jest także linia programowa portalu nowylad.pl, na który Narodowy Instytut Społeczny dostał z NIW 198.891,40 zł. W swoim manifeście piszą: “Jako świadkowie przybierającego na sile konfliktu, wierzymy, że naród, silne państwo, religia czy ład, atakowane dziś z pozycji liberalnych i nowolewicowych, nie są przeżytkami”. ","type":"unstyled","depth":0,"entityRanges":[{"key":26,"length":27,"offset":74},{"key":27,"length":10,"offset":138}],"inlineStyleRanges":[{"style":"BOLD","length":27,"offset":74},{"style":"BOLD","length":13,"offset":115}]},{"key":"291jo","data":{},"text":"Kolejne 200 tys. zł dostanie portal scenakultury.pl, której jednym z działów jest “Encyklopedia dziejów Narodowej Demokracji w Polsce”. Wydawcą jest Stowarzyszenie Scena Kultury. Jego prezes to Arkadiusz Gołębiewski, reżyser i dyrektor Festiwalu Filmowego Niepokorni Niezłomni Wyklęci. Wiceprezesem jest Paweł Nowacki – dziennikarz, publicysta, współautor (wraz z Krzysztofem Nowakiem) filmu „Media III RP” i współautor (wraz z Janem Pospieszalskim) programu „Warto rozmawiać”. Kieruje też Fundacją Smoleńsk 2010, założoną, by wspierać powstawanie i rozpowszechnianie filmu “Smoleńsk” Antoniego Krauzego. ","type":"unstyled","depth":0,"entityRanges":[{"key":28,"length":29,"offset":574}],"inlineStyleRanges":[{"style":"BOLD","length":11,"offset":8},{"style":"BOLD","length":28,"offset":149}]},{"key":"e57n5","data":{},"text":"To kolejna dotacja z NIW dla scenykultury.pl. W poprzednim rozdaniu dla mediów obywatelskich stowarzyszenie Gołębiewskiego i Nowackiego dostało 102.500 zł. ","type":"unstyled","depth":0,"entityRanges":[{"key":29,"length":18,"offset":136}],"inlineStyleRanges":[]},{"key":"6o4kv","data":{},"text":"Obywatelskie media katolickie ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":29,"offset":0}]},{"key":"a82cm","data":{},"text":"Medium obywatelskim okazał się być także youtubowy katolicki kanał Salve Net. Na jego prowadzenie prawie 200 tys. zł dostała Fundacja im. błogosławionego księdza Ignacego Kłopotowskiego. Powstała ona na początku 2019 roku z inicjatywy biskupa warszawsko-praskiego Romualda Kamińskiego. Jak czytamy na stronie fundacji,  na kanale Salve Net “można znaleźć serie filmików m.in. pogłębiających życie duchowe, przybliżających sprawy anielskie, dotykających tajemnic życia kapłańskiego, a także aktualności z życia diecezji warszawsko-praskiej”. ","type":"unstyled","depth":0,"entityRanges":[{"key":30,"length":19,"offset":298}],"inlineStyleRanges":[{"style":"BOLD","length":11,"offset":105},{"style":"BOLD","length":60,"offset":125}]},{"key":"44io1","data":{},"text":"Dofinansowanie dostała też katolicka Fundacja im. św. Cyryla i Metodego, której jednym z fundatorów był emerytowany biskup położonej po lewej stronie Wisły archidiecezji warszawskiej. Prawie 200 tys. zł może przeznaczyć na rozwój portalu tato.net, edukującego ojców w duchu katolickiej nauki o rodzinie. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":34,"offset":37},{"style":"BOLD","length":11,"offset":191}]},{"key":"7ahih","data":{},"text":"Okrągłe 200 tys. zł NIW przeznaczył także na wsparcie rolniczego portalu kalendarzrolnikow.pl. Jego wydawcą jest Wydawnictwo Duszpasterstwa Rolników. Jak czytamy na jego stronie, ma ono za zadanie “służyć człowiekowi zgodnie z katolicką nauką Kościoła” i “przypominać człowiekowi o jego ludzkiej godności, o jego ukierunkowaniu na zbawienie i życie wieczne, do której doczesność jest przygotowaniem”. ","type":"unstyled","depth":0,"entityRanges":[{"key":31,"length":23,"offset":154}],"inlineStyleRanges":[{"style":"BOLD","length":11,"offset":8},{"style":"BOLD","length":35,"offset":113}]},{"key":"58vvi","data":{},"text":"Media lokalne, ale swoje ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":24,"offset":0}]},{"key":"d78gr","data":{},"text":"NIW przyznał granty także niedużym mediom lokalnym. Nawet w tych przypadkach jednak trafiły w zaufane ręce. Na przykład 90.993,03 zł na projekt Rozwój lokalnej gazety \"Twoje Nowiny\" dostało Stowarzyszenie Inicjatyw Ziemi Chełmińskiej \"Dolina Dolnej Wisły\", zarejestrowane dopiero w lutym 2021 r. Jego I wiceprezeską jest Anna Szwed, która (bez powodzenia) kandydowała z list PiS w ostatnich wyborach samorządowych, parlamentarnych i europejskich. Z list PiS w wyborach samorządowych bez powodzenia startowała też II wiceprezes Katarzyna Buchholz-Gugała, obecnie sołtyska Bieńkówki.  ","type":"unstyled","depth":0,"entityRanges":[{"key":32,"length":15,"offset":415},{"key":33,"length":12,"offset":433},{"key":34,"length":10,"offset":498}],"inlineStyleRanges":[{"style":"BOLD","length":12,"offset":120},{"style":"BOLD","length":65,"offset":190}]},{"key":"8ik66","data":{},"text":"Wydawałoby się też, że wsparciem oddolnej inicjatywy jest przyznanie 196.171,49 zł Komitetowi Obywatelskiemu Ziemi Kłodzkiej na “Gazetę Noworudzką”. Kiedy jednak przyjrzymy się biogramowi jej prezesa Warcisława Martynowskiego, okazuje się, że w PRL-u był zasłużonym działaczem “Solidarności” i “Solidarności Walczącej”, a w III RP członkiem partii braci Kaczyńskich: Porozumienia Centrum i Prawa i Sprawiedliwości. ","type":"unstyled","depth":0,"entityRanges":[{"key":35,"length":48,"offset":177}],"inlineStyleRanges":[{"style":"BOLD","length":55,"offset":69}]},{"key":"3tqk4","data":{},"text":"Poza tym 198.715,46 zł znalazło się dla Stowarzyszenia Projekt Błonie, którego prezeską jest Marzena Cichewicz, radna Błonia z ramienia PiS. Dzięki grantowi będzie mogła “wzmocnić potencjał lokalnego medium”. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":13,"offset":9},{"style":"BOLD","length":29,"offset":40}]},{"key":"cp5qg","data":{},"text":"Dla zięciów ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"dl2dm","data":{},"text":"197.909,34 zł na Magazyn Akademicki Koncept dostała bliska władzy Fundacja Inicjatyw Młodzieżowych. Obecnie wydawany jest w 300 tysiącach bezpłatnych egzemplarzy. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":13,"offset":0},{"style":"BOLD","length":32,"offset":66}]},{"key":"3ia3e","data":{},"text":"Jak pisała “Wirtualna Polska”, współzałożyciel fundacji Mariusz Chłopik był radnym PiS, członkiem sztabu wyborczego Andrzeja Dudy i sztabu PiS w wyborach parlamentarnych w 2015 roku. Potem był dyrektorem w Agencji Rozwoju Przemysłu, a obecnie w PKO BP. Prywatnie jest zięciem Konstantego Radziwiłła, wojewody mazowieckiego, byłego ministra zdrowia w rządzie PiS. Mężem drugiej córki Radziwiłła jest z kolei Jakub Greloff, zasiadający w radzie FIM. ","type":"unstyled","depth":0,"entityRanges":[{"key":36,"length":25,"offset":4}],"inlineStyleRanges":[]},{"key":"9p3u8","data":{},"text":"Flagowym przedsięwzięciem FIM jest Akademia Liderów Rzeczypospolitej. Jej prelegentami byli premier Mateusz Morawiecki, prezes PKO Zbigniew Jagiełło, była wicepremier Jadwiga Emilewicz i prezesi spółek Skarbu Państwa.  ","type":"unstyled","depth":0,"entityRanges":[{"key":37,"length":17,"offset":74}],"inlineStyleRanges":[]},{"key":"el4tq","data":{},"text":"Na Centrum Analiz Klubu Lidera Rzeczpospolitej fundacja dostała z NIW w tym rozdaniu także 288.549,46 zł w konkursie na rozwój think tanków obywatelskich. Razem: 486.458,8 zł. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":13,"offset":91},{"style":"BOLD","length":12,"offset":162}]},{"key":"13g24","data":{},"text":"NIW kwotą 181.669,42 zł wsparł także projekt p.t. “Profesjonalizacja zespołu Międzymiastowo działającego w ramach Klubu Jagiellońskiego”. KJ to konserwatywny think-tank z Krakowa, z którym związani byli dzisiejsi politycy obozu rządzącego, m.in. Jarosław Gowin, Ryszard Legutko, Krzysztof Szczerski. Prezes Klubu Piotr Trudnowski w rozmowie z OKO.press w sierpniu 2020 r. przyznawał: ","type":"unstyled","depth":0,"entityRanges":[{"key":38,"length":14,"offset":77},{"key":39,"length":10,"offset":372}],"inlineStyleRanges":[{"style":"BOLD","length":13,"offset":10},{"style":"BOLD","length":21,"offset":114}]},{"key":"6qsvn","data":{},"text":"„Trudno nam sobie wyobrazić w realiach III RP rząd, który będzie w większym stopniu, chociaż na poziomie deklaratywnym, podzielał nasze diagnozy i wartości. Jednocześnie chcemy być instytucją, która wychodząc z podobnych założeń i wyznając bliskich światopogląd, stale dostarcza PiS uczciwej krytyki”. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"5e2v2","data":{},"text":"Think tanki bez doświadczenia ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":29,"offset":0}]},{"key":"fncbr","data":{},"text":"Ostatni z trzech konkursów NIW (PROO 4a) ma wspierać rozwój think tanków obywatelskich. Jak wyjaśnia strona Instytutu think tanki to “organizacje, które opracowują badania, analizy i opinie związane ze sprawami krajowymi lub międzynarodowymi, w celu merytorycznego wspierania procesów podejmowania strategicznych decyzji lub przyjmowania rozwiązań i regulacji”. Warunkiem otrzymania dotacji jest doświadczenie w tworzeniu analiz w ciągu ostatnich dwóch lat. ","type":"unstyled","depth":0,"entityRanges":[{"key":40,"length":25,"offset":92}],"inlineStyleRanges":[]},{"key":"33esh","data":{},"text":"Takim doświadczeniem nie mogą się pochwalić Patryk Palczewski i Mateusz Rojewski, dwudziestoparoletni założyciele Fundacji Instytut Spraw Konstytucyjnych. Fundacja została zarejestrowana dopiero w grudniu 2020. Mają jednak doświadczenie polityczne: obaj są warszawskimi radnymi PiS. Na “prowadzenie, organizowanie i finansowanie działalności badawczej z zakresu Polskiego konstytucjonalizmu” dostali z NIW 231.846,08 zł.  ","type":"unstyled","depth":0,"entityRanges":[{"key":41,"length":17,"offset":44},{"key":42,"length":16,"offset":64},{"key":43,"length":14,"offset":172}],"inlineStyleRanges":[{"style":"BOLD","length":39,"offset":114},{"style":"BOLD","length":13,"offset":406}]},{"key":"bhnbs","data":{},"text":"Krótki staż ma też Fundacja Rozwoju Powiatu Łęczyńskiego, która na “THINK TANK w Powiecie Łęczyńskim” dostała 235.589,15 zł. Jej statutowym działaniem jest przede wszystkim “podtrzymywanie i rozpowszechnianie tradycji narodowej i państwowej”. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":37,"offset":19},{"style":"BOLD","length":13,"offset":110}]},{"key":"57cbr","data":{},"text":"Z kolei w październiku 2020 roku zarejestrowano Fundację Matuzalem. Jej wiceprezesem jest (były?) ksiądz archidiecezji warszawskiej Sergiusz Dębecki. Obecnie przygotowujący się do egzaminu psychoterapeuta, który specjalizuje się m.in. w “radzeniu sobie z tzw. konfliktami sumienia\". Jego fundacja otrzymała 275.501,77 zł na projekt p.t. “Od zatomizowanej bezradności i lęku jednostki do harmonijnego życia w lokalnej społeczności”. ","type":"unstyled","depth":0,"entityRanges":[{"key":44,"length":33,"offset":98},{"key":45,"length":15,"offset":189}],"inlineStyleRanges":[{"style":"BOLD","length":18,"offset":48},{"style":"BOLD","length":13,"offset":307}]},{"key":"a5iq0","data":{},"text":"Partyjne i katolickie ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":21,"offset":0}]},{"key":"9kv7","data":{},"text":"NIW docenił jeszcze jeden katolicki think tank. 118.426,88 zł otrzymało Stowarzyszenie Chrześcijańskich Dzieł Wychowania powołane przez jezuitów. Jak czytamy na jego stronie, zajmuje się ono grupowaniem polskich ośrodków kształceniowych i osób, zaangażowanych w “dzieła wychowawcze Kościoła katolickiego”.  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":13,"offset":48},{"style":"BOLD","length":48,"offset":72}]},{"key":"8tp87","data":{},"text":"Skuteczne wnioski w tym rozdaniu pisały też think tanki powiązane z władzą. Jak pisaliśmy wyżej granty dostały Fundacja Polska Wielki Projekt, Fundacja Inicjatyw Młodzieżowych i Instytut im. Kazimierza Promyka.  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":30,"offset":111},{"style":"BOLD","length":32,"offset":143},{"style":"BOLD","length":31,"offset":178}]},{"key":"6hv33","data":{},"text":"Wsparcie wysokości 290.618,84 zł dostała też Fundacja Klubu Ronina. Jej prezes Józef Orzeł w 1990 r. wspólnie z Jarosławem Kaczyńskim zakładał partię Porozumienie Centrum. Klub Ronina, miejsce dyskusji prawicowców, wspólnie z Rafałem Ziemkiewiczem założył w 2007 roku. Dziś jest m.in. członkiem rady nadzorczej Polskiej Fundacji Narodowej z ramienia PKO BP oraz rady nadzorczej Reduty Dobrego Imienia. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":13,"offset":19},{"style":"BOLD","length":21,"offset":45}]},{"key":"3n8f9","data":{},"text":"W radzie Fundacji Klubu Ronina zasiada prezes Reduty Maciej Świrski, Marcin Wolski, publicysta TVP i doradca jej zarządu oraz prof. Andrzej Nowak, historyk, członek Kolegium IPN. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"98rll","data":{},"text":"Grant dostała też fundacja imienia zmarłego w katastrofie smoleńskiej szefa IPN Janusza Kurtyki. 288.711,66 zł wesprze projekt p.t. “Punkt styczności - eliminacja deficytów modułu think tankowego Fundacji im. Janusza Kurtyki w celu zwiększenia wpływu na polityki publiczne w obszarze polityki pamięci”. Prezesem fundacji jest Paweł Kurtyka, członek rad nadzorczych spółek Skarbu Państwa PGE Baltica sp. z o.o. oraz MS TFI S.A. Cztery lata temu jako 26-latek został na krótko przewodniczącym rady Agencji Mienia Wojskowego. ","type":"unstyled","depth":0,"entityRanges":[{"key":46,"length":6,"offset":458}],"inlineStyleRanges":[{"style":"BOLD","length":13,"offset":97},{"style":"BOLD","length":28,"offset":196}]}],"entityMap":{"0":{"data":{"url":"https://niw.gov.pl/wp-content/uploads/2020/06/PROO-2a-Lista-rankingowa.pdf","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"1":{"data":{"slug":"pfn-duda-fundacja-republikanska","type":"LEGACY_INTERNAL"},"type":"LINK","mutability":"MUTABLE"},"2":{"data":{"slug":"muza-dei-jurek-ziobro-glinski","type":"LEGACY_INTERNAL"},"type":"LINK","mutability":"MUTABLE"},"3":{"data":{"nodes":["1cc81cce-79fa-4d2f-a6a0-ca7a6c8b3181"]},"type":"RELATED_CONTENTS","mutability":"IMMUTABLE"},"4":{"data":{"url":"https://www.niw.gov.pl/wp-content/uploads/2021/04/lista-rankingowa-wniosk%c3%b3w-ZAKWALIFIKOWANYCH.pdf","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"5":{"data":{"url":"https://wyborcza.pl/magazyn/7,124059,23268280,salonik-pani-bieleckiej-na-zapleczu-pis-tu-sie-spotyka-nowa.html","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"6":{"data":{"url":"https://polskawielkiprojekt.pl/rada-programowa-fundacji/","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"7":{"data":{"url":"https://www.pap.pl/aktualnosci/news%2C733172%2Crozpoczal-sie-x-kongres-polska-wielki-projekt.html","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"8":{"data":{"url":"https://polskawielkiprojekt.pl/nagroda/","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"9":{"data":{"url":"https://rejestr.io/krs/363504/fundacja-pomorska-inicjatywa-historyczna","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"10":{"data":{"url":"https://wyborcza.pl/1,75398,19917325,glosowanie-na-cztery-rece-w-sejmie-opozycja-wystapila-o-nagranie.html","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"11":{"data":{"url":"https://tvn24.pl/polska/malgorzata-zwiercan-rozpoczela-prace-w-kancelarii-premiera-ra992905-2587035","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"12":{"data":{"url":"https://rejestr.io/krs/834289/fundacja-edukacja-do-wartosci","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"13":{"data":{"url":"http://sanctuspaulus.pl/stowarzyszenie/nasza-misja","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"14":{"data":{"url":"https://rejestr.io/krs/794650/fundacja-instytut-im-kazimierza-promyka","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"15":{"data":{"url":"https://www.rp.pl/Polityka/301109951-Polityczny-flirt-PiS-z-najwieksza-organizacja-studencka.html","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"16":{"data":{"url":"https://natemat.pl/320193,26-latek-szefem-biura-jaroslawa-kaczynskiego-kim-jest-michal-moskal","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"17":{"data":{"url":"https://www.niw.gov.pl/wp-content/uploads/2021/01/PROO-3_FAQ_2021.pdf","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"18":{"data":{"url":"https://rejestr.io/krs/869221/fundacja-edukacji-i-mediow","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"19":{"data":{"url":"https://prawy.pl/8732-ruch-narodowy-ma-nowe-wladze/","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"20":{"data":{"url":"https://rejestr.io/krs/20227/dalmor","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"21":{"data":{"slug":"rosyjski-cien-nad-polskim-facebookiem-andruszkiewicz-korwin","type":"LEGACY_INTERNAL"},"type":"LINK","mutability":"MUTABLE"},"22":{"data":{"slug":"sukces-sledztwa-oko-press-fb-usunal-strony-promujace-m-in-fake-newsy-i-adama-andruszkiewicza","type":"LEGACY_INTERNAL"},"type":"LINK","mutability":"MUTABLE"},"23":{"data":{"nodes":["085f771a-9d87-4253-8889-f11dbe25bf3d"]},"type":"RELATED_CONTENTS","mutability":"IMMUTABLE"},"24":{"data":{"slug":"straz-narodowa-reaktywacja-przedwojennych-bojowek","type":"LEGACY_INTERNAL"},"type":"LINK","mutability":"MUTABLE"},"25":{"data":{"nodes":["44bfd2a9-4b25-424b-bcf3-ddc3e23e2873"]},"type":"RELATED_CONTENTS","mutability":"IMMUTABLE"},"26":{"data":{"url":"https://rejestr.io/krs/525824/fundacja-narodowy-instytut-spoleczny","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"27":{"data":{"url":"https://nlad.pl/manifest/","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"28":{"data":{"slug":"patosu-trollingu-reakcje-smolensk","type":"LEGACY_INTERNAL"},"type":"LINK","mutability":"MUTABLE"},"29":{"data":{"url":"https://www.niw.gov.pl/wp-content/uploads/2020/06/lista-rankingowa-PROO-3_wnioski-do-realizacji.pdf","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"30":{"data":{"url":"https://fundacjaklopotowskiego.pl/projekty/","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"31":{"data":{"url":"https://www.wydawnictwodr.pl/16/o-firmie#","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"32":{"data":{"url":"https://www.wnp.pl/parlamentarny/osoba/anna-szwed,10624.html","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"33":{"data":{"url":"https://www.wnp.pl/parlamentarny/osoba/anna-szwed,193554.html","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"34":{"data":{"url":"http://wybierzpis.org.pl/kandydaci?search%5Bregion%5D=2\u0026search%5Bdistrict%5D=34\u0026search%5Bprovince%5D=202\u0026search%5BcandidateName%5D=","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"35":{"data":{"url":"https://sw.ipn.gov.pl/ws/biogramy/4969,Warcislaw-Janusz-Martynowski-Ladek-Zdroj.html","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"36":{"data":{"url":"https://wiadomosci.wp.pl/fundacja-promuje-wizyte-trumpa-ma-bliskie-zwiazki-z-pis-i-pieniadze-z-rzadu-6140892365809281a","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"37":{"data":{"url":"https://konfederacjaipr.pl/pl/2020/08/26/akademia-liderow-rzeczypospolitej-oczko-w-glowie-fundacji-inicjatyw-mlodziezowych/","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"38":{"data":{"url":"https://klubjagiellonski.pl/temat/miedzymiastowo/","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"39":{"data":{"slug":"pis-oceniaja-ledwo-na-troje-ale-wciaz-jest-im-najblizszy-klub-jagiellonski-zmieni-polska-prawice","type":"LEGACY_INTERNAL"},"type":"LINK","mutability":"MUTABLE"},"40":{"data":{"url":"https://niw.gov.pl/proo-priorytet-4-faq-najczesciej-zadawane-pytania/","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"41":{"data":{"url":"http://warszawskipis.pl/osoba/patryk-palczewski/","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"42":{"data":{"url":"http://warszawskipis.pl/osoba/mateusz-rojewski/","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"43":{"data":{"url":"https://rejestr.io/krs/871660/fundacja-instytut-spraw-konstytucyjnych","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"44":{"data":{"url":"https://www.youtube.com/watch?v=2MLFiV5sLlE","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"45":{"data":{"url":"https://odchudzanieodglowy.pl/O_nas","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"},"46":{"data":{"url":"https://krakow.wyborcza.pl/krakow/1,44425,19438857,25-letni-syn-janusza-kurtyki-szefem-rady-nadzorczej-agencji.html","type":"EXTERNAL"},"type":"LINK","mutability":"MUTABLE"}}},"member_only_for_x_day":7,"display_at_homepage":true,"additional_label":"","featured_image":{"__typename":"assets","original_url":"https://oko.press/images/2016/11/KA161107_029-e1480351429206.jpg","sizes":{},"credit":"Kuba Atys / Agencja Gazeta","caption":"07.11.2016  Warszawa. Minister kultury Piotr Glinski podczas prezentacji projektu budynkow Muzeum Historii Polski . Fot . Kuba Atys / Agencja Gazeta","alt":"Minister kultury Piotr Gliński. Podległy mu Narodowy Instytut Wolności wydał 11 mln zł na wsparcie bliskich władzy organizacji pozarządowych."},"gallery_images_aggregate({\"limit\":3})":{"__typename":"gallery_images_aggregate","aggregate":{"__typename":"gallery_images_aggregate_fields","count":0},"nodes":[]},"live_updates({\"order_by\":{\"timestamp\":\"desc\"}})":[],"seo_fields":{"__typename":"seo_fields","slug":"niw-11-mln-zl-ngo-nacjonalistyczne-katolickie","meta_title":"Miliony złotych z NIW na organizacje nacjonalistyczne i katolickie OKO.press","meta_description":"Nadzorowany przez Piotra Glińskiego Narodowy Instytut Wolności ogłosił wyniki konkursów dla organizacji pozarządowych - m.in. dla Ordo Iuris.","meta_keyword":"NIW granty","meta_image":{"__typename":"assets","original_url":"https://oko.press/images/2016/11/KA161107_029-e1480351429206.jpg","sizes":{},"credit":"Kuba Atys / Agencja Gazeta","caption":"07.11.2016  Warszawa. Minister kultury Piotr Glinski podczas prezentacji projektu budynkow Muzeum Historii Polski . Fot . Kuba Atys / Agencja Gazeta","alt":"Minister kultury Piotr Gliński. Podległy mu Narodowy Instytut Wolności wydał 11 mln zł na wsparcie bliskich władzy organizacji pozarządowych."},"facebook_title":"Instytut Glińskiego rozdał 11 mln zł NGO’som nacjonalistycznym, katolickim i PiS-owskim","facebook_description":"","facebook_image":{"__typename":"assets","original_url":"https://oko.press/images/2016/11/KA161107_029-e1480351429206.jpg","sizes":{},"credit":"Kuba Atys / Agencja Gazeta","caption":"07.11.2016  Warszawa. Minister kultury Piotr Glinski podczas prezentacji projektu budynkow Muzeum Historii Polski . Fot . Kuba Atys / Agencja Gazeta","alt":"Minister kultury Piotr Gliński. Podległy mu Narodowy Instytut Wolności wydał 11 mln zł na wsparcie bliskich władzy organizacji pozarządowych."},"twitter_title":"","twitter_description":"","twitter_image":{"__typename":"assets","original_url":"https://oko.press/images/2016/11/KA161107_029-e1480351429206.jpg","sizes":{},"credit":"Kuba Atys / Agencja Gazeta","caption":"07.11.2016  Warszawa. Minister kultury Piotr Glinski podczas prezentacji projektu budynkow Muzeum Historii Polski . Fot . Kuba Atys / Agencja Gazeta","alt":"Minister kultury Piotr Gliński. Podległy mu Narodowy Instytut Wolności wydał 11 mln zł na wsparcie bliskich władzy organizacji pozarządowych."},"meta_robots_index":true,"meta_robots_follow":true},"metadata_authors":[{"__typename":"metadata_authors","author":{"__typename":"authors","name":"Flis","first_name":"Daniel"}}],"metadata_taxonomy({\"where\":{\"_or\":[{\"taxonomy\":{\"type\":{\"_eq\":\"topic\"}}},{\"taxonomy\":{\"type\":{\"_eq\":\"category\"}}}]}})":[{"__typename":"metadata_taxonomy","taxonomy":{"__ref":"taxonomy:1a5e95bd-4b62-41e5-be2f-f9ee1cdbb65a"}},{"__typename":"metadata_taxonomy","taxonomy":{"__ref":"taxonomy:75a6024a-4d96-4df1-b621-8d8f552f137f"}},{"__typename":"metadata_taxonomy","taxonomy":{"__ref":"taxonomy:de72af85-7f18-44c6-9869-a7dd16501f1d"}},{"__typename":"metadata_taxonomy","taxonomy":{"__ref":"taxonomy:f16a221c-601e-4a84-bd3f-513f83cb4391"}}],"podcast_fields":null,"audio_reportage_fields":null,"text_to_speech":"disabled","voice":null,"status":"published"},"content:9f56226f-d0f2-4510-9a1f-e43b94f3066d":{"__typename":"content","id":"9f56226f-d0f2-4510-9a1f-e43b94f3066d","title":"Miliony z NIW dla organizacji związanych z wiceszefem Ordo Iuris. A w tle coraz silniejsze powiązania","type":"post","publish_at":"2021-05-20T05:30:24","content":{"blocks":[{"key":"dg5be","data":{},"text":"O Tymoteuszu Zychu zrobiło się w ubiegłym tygodniu głośno. W poniedziałek (10 maja 2021) Ordo Iuris ogłosiło, że będzie on rektorem nowo powołanej uczelni - Collegium Intermarium. Ma ona kształcić konserwatywnych prawników, a tym samym przybliżać Ordo Iuris do realizacji jego celu - uzyskania jak największego wpływu na kształt prawa w Polsce i UE. ","type":"unstyled","depth":0,"entityRanges":[{"key":0,"length":21,"offset":157}],"inlineStyleRanges":[]},{"key":"92n2v","data":{},"text":"Zych jest również:  ","type":"unstyled","depth":0,"entityRanges":[{"key":1,"length":4,"offset":0}],"inlineStyleRanges":[]},{"key":"f5t0r","data":{},"text":"prezesem Fundacji Edukacja do Wartości, która jest formalnym założycielem Collegium Intermarium, ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"17io2","data":{},"text":"prezesem Fundacji Ośrodek Analiz Prawnych, Gospodarczych i Społecznych im. Hipolita Cegielskiego ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"7iaac","data":{},"text":"oraz wiceprezesem związku stowarzyszeń Konfederacja Inicjatyw Pozarządowych RP.  ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"ffn4v","data":{},"text":"Jak ustaliło OKO.press, wszystkie te organizacje od kilku lat dostają państwowe dotacje z Narodowego Instytutu Wolności - Centrum Rozwoju Społeczeństwa Obywatelskiego (dalej: NIW).  ","type":"unstyled","depth":0,"entityRanges":[{"key":2,"length":3,"offset":175}],"inlineStyleRanges":[]},{"key":"b4bec","data":{},"text":"Otrzymały już 9 grantów, o łącznej wartości 3 343 248 zł, ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":12,"offset":44}]},{"key":"6ogh0","data":{},"text":"w tym roku 4 ich projekty, na łączną kwotę 1 280 700 zł znalazły się na listach rezerwowych (niektóre z dużymi szansami na realizację), ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":12,"offset":43}]},{"key":"372sf","data":{},"text":"a ubiegają się jeszcze o co najmniej 5 kolejnych dotacji - w sumie 2 021 700 zł.  ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":12,"offset":67}]},{"key":"3qehk","data":{},"text":"O 300 000 zł dofinansowania z NIW zabiega także powiązana z Ordo Iuris Fundacja na rzecz Rzetelnej Debaty Publicznej. ","type":"unstyled","depth":0,"entityRanges":[{"key":3,"length":7,"offset":34}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":2}]},{"key":"6r68g","data":{},"text":"Nie byłoby w tym nic dziwnego i niepokojącego, gdyby nie fakt, że  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"4fpf4","data":{},"text":"od 2018 roku Tymoteusz Zych jest równocześnie członkiem 11-osobowej rady Narodowego Instytutu Wolności, który przyznaje dotacje, ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"1b1j8","data":{},"text":"w radzie NIW zasiadają także 3 osoby, które od jesieni będą wykładowcami rozkręcanego przez Zycha Collegium Intermarium, ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"33ecg","data":{},"text":"zajęcia w Collegium prowadzić ma też jeden z wicedyrektorów NIW, ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"n3qe","data":{},"text":"a drugi wicedyrektor NIW działał do niedawna z Zychem w Konfederacji Inicjatyw Pozarządowych RP (był jej prezesem). ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"9tror","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":4,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"d7e30","data":{},"text":"Pączkujące Ordo Iuris ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"64it0","data":{},"text":"Ordo Iuris, którego wiceprezesem jest Tymoteusz Zych, jest jedną z najbardziej znanych ultrakatolickich organizacji w Polsce. Jej celem jest zyskanie jak największego wpływu na porządek prawny (łac. ordo iuris) w Polsce i UE i zmienianie go na konserwatywno-katolicką modłę. W dużym stopniu przyczyniła się ona do ograniczenia prawa Polek do aborcji, chce też m.in. wypowiedzenia przez Polskę antyprzemocowej konwencji stambulskiej. ","type":"unstyled","depth":0,"entityRanges":[{"key":5,"length":10,"offset":0},{"key":6,"length":51,"offset":141},{"key":7,"length":65,"offset":366}],"inlineStyleRanges":[]},{"key":"f6kr2","data":{},"text":"Działacze Ordo Iuris przekonują, że aby skutecznie realizować swoje cele, muszą i chcą pozostać całkowicie niezależni od władzy i publicznego finansowania. Na stronie internetowej OI piszą: „Świadomie rezygnujemy z grantów i dotacji publicznych, których pozyskanie mogłoby ograniczać naszą niezależność. Jedynie dzięki Darczyńcom możemy kontrolować poczynania władzy, bez obawy o dalsze funkcjonowanie”. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"2hshr","data":{},"text":"I rzeczywiście organizacja zbiera na swoją działalność coraz wyższe kwoty. Według unijnego rejestru przejrzystości, w 2020 roku jej budżet sięgnął 1 510 462 euro, czyli około 6,7 mln zł. Z tego na lobbing w UE miała przeznaczyć pomiędzy 50 tys. a 100 tys. euro.","type":"unstyled","depth":0,"entityRanges":[{"key":8,"length":32,"offset":82}],"inlineStyleRanges":[{"style":"BOLD","length":14,"offset":147}]},{"key":"2m4fj","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":9,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"d236r","data":{},"text":"Ale to tylko część obrazka. Bo ludzie Ordo Iuris, korzystając z wzorów ruchu Tradition, Family, Property (TFP), w którym tkwią jego korzenie, zakładają szereg organizacji pozarządowych, realizujących różne zadania powiązane z celami OI. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"ba8o4","data":{},"text":" I już te organizacje nie tylko nie stronią od publicznego wsparcia, ale przeciwnie: intensywnie o nie zabiegają. ","type":"blockquote","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"1hrme","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":10,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"epq4m","data":{},"text":"Korzenie Ordo Iuris ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"3ulg9","data":{},"text":"Korzenie Ordo Iuris tkwią w organizacjach, które powstały z inicjatywy ludzi zawiązanych z radykalnym ruchem religijnym Tradition, Family, Property (TFP), czyli Tradycja, Rodzina, Własność. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":9},{"style":"BOLD","length":33,"offset":120}]},{"key":"4gov7","data":{},"text":"Założycielem TFP był wywodzący się z rodziny brazylijskich plantatorów trzciny cukrowej Plinio Corrêa de Oliveira. W latach 60. skupił on wokół siebie zamożnych katolików, którzy obawiali się, że w ich kraju dojdzie do rewolucji na wzór kubański. Deklarowali, że chcą bronić tradycji i religii. ","type":"unstyled","depth":0,"entityRanges":[{"key":11,"length":25,"offset":88}],"inlineStyleRanges":[]},{"key":"btpsp","data":{},"text":"W latach 80. Kościół Katolicki w Brazylii odciął się od TFP. „Jego ezoteryczny charakter, fanatyzm religijny, kult, jakim obdarza się osobę jego założyciela oraz jego matki, nadużywanie imienia Najświętszej Maryi Panny (...) nie mogą w żaden sposób zasłużyć na aprobatę Kościoła. Z przykrością patrzymy na kłopotliwość świeckiego stowarzyszenia, które przybiera formę katolickiej instytucji religijnej, bez łączności z prawowitymi duszpasterzami. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"1m0kp","data":{},"text":" Tym samym, biskupi Brazylii przestrzegają katolików, aby nie zapisywali się do TFP, ani z nim nie współpracowali” - pisał w komunikacie tamtejszy Episkopat.  ","type":"blockquote","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"akj5u","data":{},"text":"Ruch budził kontrowersje także w innych krajach. Wenezuela w 1984 roku, po śledztwie przeprowadzonym przez Prokuraturę Generalną, zakazała mu działalności na swoim terenie. Francuska śledcza komisja parlamentarna uznała go w 1995 roku za sektę. Później sąd uznał, że powinna zachować większą powściągliwość w sformułowaniach. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"954ka","data":{},"text":"Ordo Iuris w Polsce ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"2hdv4","data":{},"text":"W naszym kraju TFP w latach 90. dopiero kiełkowało - jak pisał Konrad Szczygieł z Fundacji Reporterów - działo się to za sprawą Leonarda Przybysza \"delegata brazylijskiej organizacji, szukającego w Polsce partnerów do współpracy\". ","type":"unstyled","depth":0,"entityRanges":[{"key":12,"length":5,"offset":57}],"inlineStyleRanges":[]},{"key":"25o79","data":{},"text":"Jego współpracownikami na blisko dwie dekady zostali krakowianie, koledzy ze studiów, działacze Klubu Zachowawczo-Monarchistycznego: Sławomir Olejniczak, Sławomir Skiba i Arkadiusz Stelmach. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"f44gf","data":{},"text":" W 1999 roku z inicjatywy Przybysza i tej trójki powstało Stowarzyszenie Kultury Chrześcijańskiej im. ks. Piotra Skargi. Delegat TFP zasiadł w komisji rewizyjnej, a krakowscy monarchiści objęli zarząd.  ","type":"blockquote","depth":0,"entityRanges":[{"key":13,"length":61,"offset":58}],"inlineStyleRanges":[{"style":"BOLD","length":61,"offset":58}]},{"key":"372dj","data":{},"text":"Organizacja od lat zarabia duże pieniądze. Jej patent - zaczerpnięty od siostrzanych organizacji TFP w innych krajach - polega na rozsyłaniu milionów listów z medalikami, różańcami albo obrazkami świętych, do których dołączone są pisma z prośbą o wsparcie \"co łaska\". Listy pisane są tak, że ich odbiorcy (zwłaszcza osoby w podeszłym wieku), przekonani są, że stowarzyszenie prowadzi z nimi indywidualną korespondencję. I chętniej wpłacają pieniądze z nawet niewielkich emerytur. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"2gbfd","data":{},"text":" W 2001 roku stowarzyszenie \"skargowców\" założyło nową organizację - Fundację Instytut Edukacji Społecznej i Religijnej im. ks. Piotra Skargi.  ","type":"blockquote","depth":0,"entityRanges":[{"key":14,"length":73,"offset":69}],"inlineStyleRanges":[{"style":"BOLD","length":73,"offset":69}]},{"key":"a8iih","data":{},"text":"W zarządzie fundacji do 2019 roku zasiadali Olejniczak, Skiba i Stelmach, a w radzie - przedstawiciele TFP z Brazylii, Francji i Niemiec. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"c0v5e","data":{},"text":"Kilka lat temu doszło jednak do konfliktu pomiędzy krakowskimi monarchistami, a zagranicznymi przedstawicielami TFP. Ci drudzy odwołali zarząd fundacji. I powołali nowy: Jędrzeja Stępkowskiego (brata Aleksandra Stępkowskiego, pierwszego szefa Ordo Iuris, dziś sędziego Sądu Najwyższego), Macieja Maleszyka i Fernando Antunez-Aldunate. Dwaj Polacy wywodzą się z Krucjaty Młodych, Chilijczyk jest działaczem FTP. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"bf5nt","data":{},"text":"Spór dotyczył kontroli nad finansami fundacji. Podobnie jak stowarzyszenie im. Skargi, zbiera ona ogromne pieniądze, organizując listowe akcje z medalikami itp. Jak ujawnili dziennikarze, tylko w latach 2014-18 na jej konto wpłynęło blisko 200 mln zł darowizn. Pieniądze inwestuje m.in. w nieruchomości. Ale też w ciągu kilku lat wspomogła kwotą ponad 9 mln euro zagraniczne organizacje walczące z LGBT, przeciwko prawu do aborcji, za ograniczeniem dostępu do antykoncepcji i możliwości rozwodów itd. ","type":"unstyled","depth":0,"entityRanges":[{"key":15,"length":21,"offset":165},{"key":16,"length":32,"offset":330}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":240},{"style":"BOLD","length":10,"offset":352}]},{"key":"gs3a","data":{},"text":" Założyła także w 2013 roku i do 2019 roku wspierała finansowo najbardziej znaną ultrakatolicką organizację w Polsce - Fundację Instytut na rzecz Kultury Prawnej Ordo Iuris.  ","type":"blockquote","depth":0,"entityRanges":[{"key":17,"length":53,"offset":119}],"inlineStyleRanges":[{"style":"BOLD","length":53,"offset":119}]},{"key":"5pdmt","data":{},"text":"Stawia sobie ona za cel uzyskanie jak największego wpływu na porządek prawny (łac. ordo iuris) w Polsce i UE, by zmienić go na konserwatywno-katolicką modłę. Związani z nią ludzie tworzą kolejne organizacje (niekojarzone powszechnie z OI), które działając na rozmaite sposoby, mają przybliżać ich do tego celu. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"2mbq2","data":{},"text":"Pierwszym szefem Ordo Iuris był wspomniany już Aleksander Stępkowski, obecny sędzia i rzecznik Sądu Najwyższego. Dziś prezesem jest mec. Jerzy Kwaśniewski, a jego zastępcą Tymoteusz Zych. ","type":"unstyled","depth":0,"entityRanges":[{"key":18,"length":17,"offset":137},{"key":19,"length":14,"offset":172}],"inlineStyleRanges":[{"style":"BOLD","length":17,"offset":137},{"style":"BOLD","length":14,"offset":172}]},{"key":"a8klp","data":{},"text":"W 2019 roku, w konflikcie \"skargowców\" Kwaśniewski stanął po stronie \"monarchistów\" (Stelmach i Olejniczak do dziś są członkami rady fundacji OI). Ale profil działalności Ordo Iuris wciąż jest bliski ideom TFP. W znacznym stopniu przyczyniła się ona do ograniczenia prawa Polek do aborcji. Chce też m.in. wypowiedzenia przez Polskę antyprzemocowej konwencji stambulskiej. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"fchkq","data":{},"text":"O działalności Ordo Iuris pisaliśmy na OKO.press wielokrotnie. Wszystkie artykuły o tej organizacji znajdziecie tutaj.","type":"unstyled","depth":0,"entityRanges":[{"key":20,"length":5,"offset":112}],"inlineStyleRanges":[]},{"key":"305tq","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":21,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"f85t6","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":22,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"b515o","data":{},"text":"Tak jest w przypadku organizacji, w których władzach zasiada wiceszef Ordo Iuris Tymoteusz Zych, 35-letni radca prawny i wykładowca akademicki. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"2k79i","data":{},"text":"Jak wynika z oficjalnej notki o nim, jest on „autorem licznych ekspertyz, opinii prawnych i artykułów naukowych z zakresu ochrony praw człowieka, prawa rodzinnego i polityki rodzinnej, prawa konstytucyjnego oraz międzynarodowego prawa publicznego. Jego opinie i ekspertyzy były wykorzystywane w procesie legislacyjnym, a także przyjmowane zarówno przez polskie i zagraniczne sądy oraz trybunały (...)”. ","type":"unstyled","depth":0,"entityRanges":[{"key":23,"length":16,"offset":13}],"inlineStyleRanges":[]},{"key":"610pl","data":{},"text":"Coraz częściej jego działalność skupia uwagę publiczną. Kilka miesięcy temu 34 eurodeputowanych z grupy ds. praw osób LGBTI, zaprotestowało przeciwko powołaniu go do Komitetu Ekonomiczno-Społecznego UE, opiniującego unijne projekty legislacyjne. A konkretnie do jednej z grup tego komitetu, zajmującej się m.in. sprawami osób LGBT i równouprawnienia kobiet. Zycha zgłoszono do niej jesienią 2020 roku jako kandydata wspomnianej już wyżej Konfederacji Inicjatyw Pozarządowych RP, której jest współzałożycielem i wiceprezesem. ","type":"unstyled","depth":0,"entityRanges":[{"key":24,"length":14,"offset":125},{"key":25,"length":39,"offset":438}],"inlineStyleRanges":[]},{"key":"b4of7","data":{},"text":" Wcześniej - bo już w lutym 2018 - Zych został przedstawicielem konserwatywnych organizacji pozarządowych w radzie Narodowego Instytutu Wolności, rządowej agencji, która zarządza programami wsparcia NGOsów. W 2021 roku powołano go do rady na kolejną kadencję. ","type":"blockquote","depth":0,"entityRanges":[{"key":26,"length":39,"offset":219}],"inlineStyleRanges":[{"style":"BOLD","length":36,"offset":108}]},{"key":"89n16","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":27,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"3j2ee","data":{},"text":"Rada Narodowego Instytutu Wolności powołana w lutym 2021 roku: ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":62,"offset":0}]},{"key":"68ia3","data":{},"text":"członek powołany przez prezydenta RP:  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":37,"offset":0}]},{"key":"a4vtv","data":{},"text":"Marek Rymsza, doradca prezydenta Andrzeja Dudy,  ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"d61gu","data":{},"text":"członek powołany przez ministra finansów:  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":41,"offset":0}]},{"key":"60mcg","data":{},"text":"Piotr Patkowski, podsekretarz stanu w ministerstwie finansów, w przeszłości działacz Stowarzyszenia KoLiber i współpracownik Instytutu Sobieskiego,  ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"9tfj6","data":{},"text":"członek reprezentujący jednostki samorządu terytorialnego:  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":58,"offset":0}]},{"key":"82pq3","data":{},"text":"Iwona Gibas, wieloletnia dyrektor biura poselskiego Beaty Szydło, członkini zarządu województwa małopolskiego,  ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"2nm9o","data":{},"text":"3 członków powołanych przez Przewodniczącego Komitetu ds. Pożytku Publicznego (Piotra Glińskiego):  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":98,"offset":0}]},{"key":"5ccgf","data":{},"text":"Piotr Mazurek, wiceprzewodniczący Komitetu ds. Pożytku Publicznego, sekretarz stanu w KPRM, działacz PiS, kiedyś współpracownik Fundacji Republikańskiej oraz wiceprezes Stowarzyszenia KoLiber, ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"17anm","data":{},"text":"Ewa Leś, wykładowca Uniwersytetu Warszawskiego, członkini Narodowej Rady Rozwoju powołanej przez prezydenta Andrzeja Dudę, ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"6bl70","data":{},"text":"Bartłomiej Orzeł, pełnomocnik rządu ds. programu \"Czyste Powietrze\", kiedyś związany z Klubem Jagiellońskim,  ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"9st4r","data":{},"text":"5 członków reprezentujących organizacje pozarządowe:  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":52,"offset":0}]},{"key":"79fe1","data":{},"text":"Tymoteusz Zych, wiceprezes Fundacji na rzecz Kultury Prawnej Ordo Iuris, ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"5n2ib","data":{},"text":"Wojciech Jachimowicz, przedstawiciel Dolnośląskiego Towarzystwa Regionalnego, ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"8brmb","data":{},"text":"Jarosław Bierecki, prezes Fundacji Wspierania Ubezpieczeń Wzajemnych, brat senatora Grzegorza Biereckiego (twórcy systemu SKOK), ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"4dcmd","data":{},"text":"Anna Budzanowska, była wiceminister edukacji i nauki w rządzie PiS, ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"daqrs","data":{},"text":"Eliasz Grubiński, wieloletni instruktor Związku Harcerstwa Rzeczypospolitej, wolontariusz Fundacji Action-Life; do jesieni 2020 członek gabinetu politycznego wicepremiera Jarosława Kaczyńskiego, od jesieni - wicedyrektor Departamentu Analiz Przygotowań Obronnych Administracji w kancelarii premiera.\n ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"4t2av","data":{},"text":"   ","type":"atomic","depth":0,"entityRanges":[{"key":28,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"9bcn4","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":29,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"csk70","data":{},"text":"Monitoring prawa i walka z fejkniusami ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"175lk","data":{},"text":"Niewiele ponad pół roku przed wejściem do rady Narodowego Instytutu Wolności, Zych wraz z czworgiem znajomych z Ordo Iuris założył Fundację Ośrodek Analiz Prawnych, Gospodarczych i Społecznych im. Hipolita Cegielskiego. I został jej prezesem.","type":"unstyled","depth":0,"entityRanges":[{"key":30,"length":87,"offset":131}],"inlineStyleRanges":[{"style":"BOLD","length":87,"offset":131}]},{"key":"altig","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":31,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"a6rrs","data":{},"text":"Poza Tymoteuszem Zychem, fundatorami Ośrodka im. Cegielskiego są:  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"24er6","data":{},"text":"Jerzy Kwaśniewski, adwokat, prezes fundacji Ordo Iuris, ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"56e2n","data":{},"text":"Bartosz Lewandowski, również adwokat, dyrektor Centrum Interwencji Procesowej Ordo Iuris, ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"33arh","data":{},"text":"Olaf Szczypiński, były koordynator Zespołu Analitycznego Centrum Analiz Legislacyjnych Ordo Iuris, współautor raportu \"Jakiej polityki rodzinnej potrzebuje Polska\" ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"4518s","data":{},"text":"i Karolina Pawłowska, dyrektorka Centrum Prawa Międzynarodowego Ordo Iuris, działająca też w konserwatywnej Konfederacji Kobiet RP.  ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"8sn25","data":{},"text":"W zarządzie fundacji, poza Zychem, zasiadają Kwaśniewski, Lewandowski, Szczypiński i Paweł Pawłowski, mąż Karoliny Pawłowskiej. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"fgvrm","data":{},"text":"Ten ostatni jest także członkiem rady wspomnianej na początku tekstu Fundacji na rzecz Rzetelnej Debaty Publicznej, której patronuje Ordo Iuris. W 2020 ta organizacja stworzyła portal fact-checkingowy sprawdzimy.info. W tym roku ubiega się o 300 000 zł z NIW, na projekt \"Kontra - Budujemy forum debaty publicznej 300 000 zł\". Został on zakwalifikowany do oceny merytorycznej.\n ","type":"unstyled","depth":0,"entityRanges":[{"key":32,"length":45,"offset":69},{"key":33,"length":38,"offset":337}],"inlineStyleRanges":[{"style":"BOLD","length":45,"offset":69}]},{"key":"4m7de","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":34,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"ekbn","data":{},"text":"Pierwszą siedzibą fundacji było mieszkanie przy ul. Jaracza w Warszawie, należące do rodziny Jerzego Kwaśniewskiego, wiceprezesa Ośrodka (ds. finansowych), a równocześnie prezesa fundacji Ordo Iuris. Dziś organizacja rezyduje przy Pl. Grzybowskim, w budynkach Parafii Wszystkich Świętych. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"4n0cc","data":{},"text":"Niemal od początku swej działalności Ośrodek im. Cegielskiego korzystał z publicznego wsparcia, choć początkowo nie było ono duże. W 2018 roku dostał 34 300 zł dotacji z Ministerstwa Nauki i Szkolnictwa Wyższego, którym rządził wówczas Jarosław Gowin, i 74 000 zł z podlegającego ministrowi Piotrowi Glińskiemu Narodowego Centrum Kultury. Organizacja pisała też analizy na zlecenie prawicowych polityków.","type":"unstyled","depth":0,"entityRanges":[{"key":35,"length":17,"offset":150},{"key":36,"length":9,"offset":254},{"key":37,"length":26,"offset":311}],"inlineStyleRanges":[{"style":"BOLD","length":9,"offset":150},{"style":"BOLD","length":9,"offset":254}]},{"key":"5r4be","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":38,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"2tuc8","data":{},"text":"W 2018 roku Ministerstwo Nauki i Szkolnictwa Wyższego przyznało Ośrodkowi im. Cegielskiego 34 300 zł dotacji na projekt \"Akademia Analityka\" (prowadzone w trzech miastach warsztaty z „tworzenia materiałów analitycznych” i \"skutecznego komunikowania przekazu\"). ","type":"unstyled","depth":0,"entityRanges":[{"key":39,"length":17,"offset":91}],"inlineStyleRanges":[{"style":"BOLD","length":9,"offset":91}]},{"key":"48cat","data":{},"text":"Narodowe Centrum Kultury przekazało Ośrodkowi 74 000 zł na projekt „Sztuka prawem chroniona” (trzy konferencje o ochronie praw autorskich i poradnik na ten temat, pod red. Tymoteusza Zycha). ","type":"unstyled","depth":0,"entityRanges":[{"key":40,"length":9,"offset":46},{"key":41,"length":22,"offset":140}],"inlineStyleRanges":[{"style":"BOLD","length":9,"offset":46}]},{"key":"b2r84","data":{},"text":"Fundacja pisała także zlecone analizy. W 2018 roku, na zamówienie Jana Klawitera (wtedy posła niezależnego, obecnie z PiS) przygotowała opracowanie nt. polityki klimatycznej i energetycznej UE. A na zlecenie Dobromira Sośnierza (wtedy eurodeputowanego, obecnie posła Konfederacji) - w 2018 roku napisała raport o \"praworządności proceduralnej\" w Parlamencie Europejskim i w 2019 analizę „Manifestu z Ventotene” Altiero Spinellego (dokument nazwano „symbolem paneuropejskiej konspiracji lewicy, wskazującej kierunek marszu UE”). Publikacja powstała pod redakcją Zycha, przy wsparciu ekspertów Ordo Iuris. \n ","type":"unstyled","depth":0,"entityRanges":[{"key":42,"length":78,"offset":448}],"inlineStyleRanges":[]},{"key":"45ml","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":43,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"dqodm","data":{},"text":"W sumie, przez pierwsze półtora roku działalności, Ośrodek im. Cegielskiego miał 223 tys. zł przychodu z darowizn i usług. W kolejnych latach wpływy znacznie poszły w górę. ","type":"unstyled","depth":0,"entityRanges":[{"key":44,"length":21,"offset":81}],"inlineStyleRanges":[]},{"key":"1a3kt","data":{},"text":"Fundacja dostała aż 5 dotacji z Narodowego Instytutu Wolności - łącznie 1 675 898 zł. Z tego:  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":13,"offset":72}]},{"key":"675bd","data":{},"text":"700 000 zł na trzyletni projekt „W stronę wolności - Sąd Arbitrażowy przy Ośrodku Analiz Prawnych Gospodarczych i Społecznych im. Hipolita Cegielskiego” (grant z PROO 2019, priorytet 1a - wsparcie działań misyjnych i rozwoju instytucjonalnego); ","type":"unordered-list-item","depth":0,"entityRanges":[{"key":45,"length":23,"offset":162}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":0}]},{"key":"2nd3g","data":{},"text":"285 088 zł na projekt „Rozwój Ośrodka Analiz”, w ramach którego przez rok prowadzono monitoring legislacji, m.in. dotyczącej organizacji pozarządowych (PROO 2019, priorytet 4 - rozwój instytucjonalny think-tanków obywatelskich); ","type":"unordered-list-item","depth":0,"entityRanges":[{"key":46,"length":22,"offset":152}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":0}]},{"key":"c7t6j","data":{},"text":"372 460 zł na „Budowę zaplecza fundraisingowego Ośrodka Analiz Cegielskiego” (PROO 2020, priorytet 2a - budowa początkowych kapitałów żelaznych); ","type":"unordered-list-item","depth":0,"entityRanges":[{"key":47,"length":23,"offset":78}],"inlineStyleRanges":[{"style":"BOLD","length":7,"offset":0}]},{"key":"4rllj","data":{},"text":"119 950 zł na prowadzenie w szkołach zajęć, w ramach projektu „Młody człowiek w świecie dezinformacji” (FIO 2020, priorytet 3 - rozwój edukacji obywatelskiej i kompetencji społecznych) ","type":"unordered-list-item","depth":0,"entityRanges":[{"key":48,"length":21,"offset":104}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":0}]},{"key":"c5n38","data":{},"text":"i 198 400 zł na realizację w latach 2020-2021 portalu fact-checkingowego Odfejkuj.info (PROO 2020, priorytet 3 - rozwój instytucjonalny lokalnych organizacji strażniczych).  ","type":"unordered-list-item","depth":0,"entityRanges":[{"key":49,"length":22,"offset":88}],"inlineStyleRanges":[{"style":"BOLD","length":12,"offset":0}]},{"key":"4h1t3","data":{},"text":"Na Odfejkuj.info można dziś znaleźć m.in. sprostowania \"fake-newsów\", że różańce Żołnierzy Chrystusa służą do smagania i zabijania, że w Polsce powstała organizacja anty-Ordo Iuris albo że popierany przez OI projekt \"Zatrzymaj aborcję\" zakładał sankcje karne dla kobiet. Na stronę przekierowuje internautów inny portal fact-checkingowy - sprawdzimy.info - założony w ub. roku pod patronatem Ordo Iuris. ","type":"unstyled","depth":0,"entityRanges":[{"key":50,"length":57,"offset":73},{"key":51,"length":36,"offset":144},{"key":52,"length":61,"offset":208},{"key":53,"length":25,"offset":376}],"inlineStyleRanges":[]},{"key":"93fm0","data":{},"text":"W tym roku na liście rezerwowej wniosków, które mogą dostać dotację z NIW, jeśli zwolnią się jakieś środki, znalazł się projekt \"Badamy samorządy - Rozwój Ośrodka Analiz Cegielskiego\" (PROO 2021), wyceniony na 265 400 zł. ","type":"unstyled","depth":0,"entityRanges":[{"key":54,"length":26,"offset":14}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":210}]},{"key":"acfr6","data":{},"text":"Organizacja ubiega się także o 310 200 zł na \"Wzmocnienie kompetencji organizacji obywatelskich i wspólnot lokalnych w zakresie crowdfundingu\" (NOWEFIO 2021). Przeszła już pozytywnie ocenę formalną. ","type":"unstyled","depth":0,"entityRanges":[{"key":55,"length":25,"offset":172}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":31}]},{"key":"2ldbu","data":{},"text":"(Uwaga! W linkach znajdziecie pełne listy dotacji przyznanych w ramach poszczególnych programów.)","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"ITALIC","length":97,"offset":0}]},{"key":"28kvp","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":56,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"c5a0v","data":{},"text":"Konfederacja bliska Glińskiemu ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"7q80f","data":{},"text":"Kolejną organizacją pozarządową, z którą związany jest Tymoteusz Zych, a która otrzymuje dotacje z Narodowego Instytutu Wolności jest Konfederacja Inicjatyw Pozarządowych Rzeczpospolitej (KIPR). ","type":"unstyled","depth":0,"entityRanges":[{"key":57,"length":60,"offset":134}],"inlineStyleRanges":[{"style":"BOLD","length":60,"offset":134}]},{"key":"e64mm","data":{},"text":"Powstała w marcu 2017 roku - gdy w resorcie ministra Piotra Glińskiego pisano ustawę o NIW i trwała gorąca dyskusja, kto powinien dzielić w Polsce środki dla organizacji pozarządowych. Od razu zaatakowała Fundację Batorego, której rząd chciał odebrać prawo dzielenia tzw. funduszy norweskich. Zarzucała jej wspieranie \"kontrowersyjnych\" projektów (np. dotyczących LGBT), które - jej zdaniem - godzą w polski porządek prawny. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"fpnp4","data":{},"text":" W zamyśle założycieli, Konfederacja ma być prawicową alternatywą dla Ogólnopolskiej Fundacji Organizacji Pozarządowych, która występuje często w rozmowach z władzą jako reprezentacja NGOsów.  ","type":"blockquote","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"fcear","data":{},"text":"Członkami Konfederacji zostały m.in. fundacje Ordo Iuris i Ośrodek im. Cegielskiego. Trzy ostatnie siedziby KIPR to kolejno: mieszkanie rodziny szefa Ordo Iuris Jerzego Kwaśniewskiego przy ul. Jaracza w Warszawie, budynek PAST-y, gdzie swą siedzibę ma Ordo Iuris i w końcu Parafia Wszystkich Świętych, gdzie mieści się też Ośrodek im. Cegielskiego. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"8bfij","data":{},"text":"Od początku działalności Konfederacja jest dotowana przez państwo. W 2017 roku przyznano jej 76 230 zł ze sławnego Funduszu Sprawiedliwości, podlegającego ministrowi Ziobro i 54 000 zł z Narodowego Centrum Kultury, które nadzoruje minister Gliński. ","type":"unstyled","depth":0,"entityRanges":[{"key":58,"length":9,"offset":93},{"key":59,"length":24,"offset":115},{"key":60,"length":9,"offset":175}],"inlineStyleRanges":[{"style":"BOLD","length":9,"offset":93},{"style":"BOLD","length":9,"offset":175}]},{"key":"bg1pv","data":{},"text":"Dzięki realizowanym przez nią projektom, rządzący - nie do końca w zgodzie z prawdą - mogą chwalić się, że wspierają jawność w życiu publicznym, prowadzą dialog z organizacjami pozarządowymi oraz dbają o prawa i wolności obywatelskie.","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"6e59c","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":61,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"247r5","data":{},"text":"W listopadzie 2017 roku Konfederacja zorganizowała Kongres Inicjatyw Pozarządowych, na który zjechało kilkuset przedstawicieli organizacji pozarządowych - głównie konserwatywnych. Poruszano podczas niego m.in. sprawy finansowania NGOsów i współpracy z instytucjami państwowymi. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"6dcdg","data":{},"text":"Prelegentami byli m.in. Tymoteusz Zych i wicepremier, a równocześnie przewodniczący Komitetu ds. Pożytku Publicznego Piotr Gliński. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"ahmfv","data":{},"text":"Podlegające Glińskiemu Narodowe Centrum Kultury wyłożyło na organizację kongresu 54 000 zł (w ramach programu dotacyjnego Kultura Interwencje 2017). ","type":"unstyled","depth":0,"entityRanges":[{"key":62,"length":9,"offset":81},{"key":63,"length":24,"offset":122}],"inlineStyleRanges":[{"style":"BOLD","length":9,"offset":81}]},{"key":"968d4","data":{},"text":"Również w listopadzie 2017 roku nadzorowany przez ministra Zbigniewa Ziobro Fundusz Sprawiedliwości przyznało Konfederacji 76 230 zł dotacji na realizację projektu „Tu mieszkam, tu strzegę - kompendium wiedzy i seminarium dla osób prowadzących działalność strażniczą samorządu terytorialnego”.","type":"unstyled","depth":0,"entityRanges":[{"key":64,"length":9,"offset":123}],"inlineStyleRanges":[{"style":"BOLD","length":9,"offset":123}]},{"key":"7foso","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":65,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"83ldo","data":{},"text":"W ramach projektu Konfederacja zorganizowała seminarium skierowane do watchdogów na temat dostępu do informacji publicznej. Ale uwaga - do informacji dotyczących samorządu terytorialnego, a nie wszystkich publicznych instytucji. Powstało też kompendium na ten temat, zredagowane przez Tymoteusza Zycha i Olafa Szczypińskiego (były koordynator Zespołu Analitycznego Centrum Analiz Legislacyjnych Ordo Iuris, założyciel Ośrodka im. Cegielskiego). ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"bqnou","data":{},"text":"Dzięki temu resort Ziobry, który sam od lat ogranicza dostęp do informacji publicznej (także o wydatkach z Funduszu Sprawiedliwości), może pochwalić się, że wspiera jawność w instytucjach publicznych. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"aba75","data":{},"text":"W 2018 roku Konfederacja, razem z Ordo Iuris, zorganizowała Forum Praw i Wolności - dużą konferencję na Stadionie Narodowym, w związku z 70. rocznicą przyjęcia Powszechnej Deklaracji Praw Człowieka. Patronatem objęły ją ministerstwa nauki i kultury. A sponsorem była państwowa spółka PKP Informatyka.\n ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"rfge","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":66,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"b4dqu","data":{},"text":"Od 2019 roku Konfederacja dostaje duże wsparcie z Narodowego Instytutu Wolności. Według naszych ustaleń, NIW przyznał jej 3 dotacje, o łącznej wartości 1 167 350 zł. W tym:  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":12,"offset":152}]},{"key":"37b0t","data":{},"text":"268 200 zł na realizację w latach 2019-2020 projektu „Konfederacja organizacjom - upowszechnianie wiedzy z zakresu ochrony danych osobowych” (z programu FIO 2019, priorytet 4 - silne organizacje pozarządowe); ","type":"unordered-list-item","depth":0,"entityRanges":[{"key":67,"length":30,"offset":144}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":0}]},{"key":"4hkln","data":{},"text":"699 150 zł na „Rozwój instytucjonalny Konfederacji Inicjatyw Pozarządowych RP” w latach 2019-2021 (PROO 2019, priorytet 1a - wsparcie działań misyjnych i rozwoju instytucjonalnego) ","type":"unordered-list-item","depth":0,"entityRanges":[{"key":68,"length":23,"offset":99}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":0}]},{"key":"592q6","data":{},"text":"i 200 000 zł na „Wzmocnienie i rozwój portalu branżowego dla NGO aktywiusz.pl” w latach 2020-2021 (PROO 2020, priorytet 3 - rozwój instytucjonalny lokalnych organizacji strażniczych i mediów obywatelskich).  ","type":"unordered-list-item","depth":0,"entityRanges":[{"key":69,"length":22,"offset":99}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":2}]},{"key":"7sjca","data":{},"text":"Na Aktywiuszu, poza poradami dla organizacji pozarządowych, można znaleźć np. odpowiedź na pytanie \"dlaczego patriotów przezywają faszystami\" albo informacje o ośrodku monitorowania chrystianofobii, czy o bractwach rycerskich. ","type":"unstyled","depth":0,"entityRanges":[{"key":70,"length":42,"offset":99},{"key":71,"length":37,"offset":160},{"key":72,"length":22,"offset":203}],"inlineStyleRanges":[]},{"key":"dkqsm","data":{},"text":"Obecnie Konfederacja ubiega się o kolejną dotację - 311 700 zł na projekt \"Budujemy networking polskich NGO\" (NOWEFIO 2021). Przeszedł on już wstępną weryfikację i został zakwalifikowany do oceny merytorycznej. ","type":"unstyled","depth":0,"entityRanges":[{"key":73,"length":12,"offset":110}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":52}]},{"key":"3emla","data":{},"text":"Kolejne 2 projekty organizacji trafiły na listę rezerwową (do realizacji, jeśli zwolnią się środki):  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"d4dfc","data":{},"text":"„Hub dla NGO Kapitałem Żelaznym KIPR”, na który organizacja chciała dostać 416 900 zł (PROO 2021, priorytet 2a) ","type":"unordered-list-item","depth":0,"entityRanges":[{"key":74,"length":23,"offset":87}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":75}]},{"key":"80ps2","data":{},"text":"i \"Wzmocnienie instytucjonalne Think Tanku Konfederacji Inicjatyw Pozarządowych RP\", który wyceniła na 298 400 zł (PROO 2021, priorytet 4). ","type":"unordered-list-item","depth":0,"entityRanges":[{"key":75,"length":22,"offset":115}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":103}]},{"key":"3ioo8","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":76,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"c019a","data":{},"text":"W latach 2018-20 na listach rezerwowych projektów do finansowania znalazły się 3 projekty Konfederacji:  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"4hmdm","data":{},"text":"„Wsparcie i budowa sieci regionalnych małych organizacji pozarządowych: szkolenia, ePoradnik kodeks postępowania w zakresie danych osobowych” - wyceniony na 138 300 zł (FIO 2018, priorytet 4); ","type":"unordered-list-item","depth":0,"entityRanges":[{"key":77,"length":21,"offset":169}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":157}]},{"key":"11ova","data":{},"text":"„Wzmocnienie instytucjonalne Think Tanku Konfederacji Inicjatyw Pozarządowych RP” - 273 880 zł (PROO 2020, priorytet 4); ","type":"unordered-list-item","depth":0,"entityRanges":[{"key":78,"length":22,"offset":96}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":84}]},{"key":"3931c","data":{},"text":"i \"Kapitał żelazny KIPR jako wzmocnienie kapitału społecznego w Polsce\" - 385 600 zł (PROO 2020, priorytet 2a).\n ","type":"unordered-list-item","depth":0,"entityRanges":[{"key":79,"length":23,"offset":86}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":74}]},{"key":"4rt1a","data":{},"text":"    ","type":"atomic","depth":0,"entityRanges":[{"key":80,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"293pk","data":{},"text":"(Uwaga! W linkach pełne listy dotacji przyznanych w ramach poszczególnych programów.)","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"ITALIC","length":85,"offset":0}]},{"key":"d644b","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":81,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"41rn","data":{},"text":"Wicedyrektor z korzeniami w Konfederacji ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"n1pd","data":{},"text":"W kwietniu 2021 roku dotychczasowy prezes Konfederacji Inicjatyw Pozarządowych RP - Przemysław Jaśkiewicz - powołany został na stanowisko wicedyrektora Narodowego Instytutu Wolności. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":21,"offset":84},{"style":"BOLD","length":43,"offset":138}]},{"key":"3gfim","data":{},"text":"W rejestrze sądowym wciąż jeszcze wpisany jest jako szef KIPR, ale w odpowiedzi na pytania OKO.press wyjaśnia, że 12 kwietnia 2021 złożył rezygnację z tej funkcji. \"Natomiast Krajowy Rejestr Sądowy ciągle jeszcze nie uaktualnił wpisu, na co nie mam wpływu” - pisze.","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"695mo","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":82,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"bcer9","data":{},"text":"Edukacja do Wartości ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"b6ku6","data":{},"text":"Najmłodszą organizacją związaną z Tymoteuszem Zychem jest Fundacja Edukacja do Wartości. ","type":"unstyled","depth":0,"entityRanges":[{"key":83,"length":29,"offset":58}],"inlineStyleRanges":[{"style":"BOLD","length":29,"offset":58}]},{"key":"as0p1","data":{},"text":"Powstała na początku 2020 roku. Zych jest jej prezesem, a wiceprezesem Jerzy Kwaśniewski (szef Ordo Iuris). W radzie fundacji zasiadają Marcin Olszówka (działa również w Polskim Towarzystwie Prawa Wyznaniowego) i Karolina Pawłowska (szefowa Centrum Prawa Międzynarodowego Ordo Iuris,  współzałożycielka fundacji Ośrodek im. Cegielskiego). ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"5a2kq","data":{},"text":"W tym roku organizacji przyznano 500 000 zł dotacji z Narodowego Instytutu Wolności, na \"Budowę początkowych kapitałów żelaznych\" (PROO 2021, priorytet 2a - wsparcie budowy początkowych kapitałów żelaznych). ","type":"unstyled","depth":0,"entityRanges":[{"key":84,"length":23,"offset":131}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":33}]},{"key":"5uc62","data":{},"text":"Ubiega się jeszcze o wsparcie na 3 kolejne projekty:  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"curu0","data":{},"text":"\"Rozwój organizacyjny Fundacji Edukacja do Wartości\" (wniosek o 700 000 zł z PROO 2021, priorytet 1a), ","type":"unordered-list-item","depth":0,"entityRanges":[{"key":85,"length":23,"offset":77}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":64}]},{"key":"e1frm","data":{},"text":"\"Stworzenie forum debaty publicznej online\" (300 000 zł z NOWEFIO 2021, priorytet 3) ","type":"unordered-list-item","depth":0,"entityRanges":[{"key":86,"length":25,"offset":58}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":45}]},{"key":"6ff36","data":{},"text":"\"Platforma e-learningowa dla organizacji pozarządowych\" (400 000 zł z NOWEFIO 2021, priorytet 4).  ","type":"unordered-list-item","depth":0,"entityRanges":[{"key":87,"length":25,"offset":70}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":57}]},{"key":"7d0m2","data":{},"text":"Wszystkie te projekty przeszły pomyślnie weryfikację formalną i zostały zakwalifikowane do oceny merytorycznej. Na listę rezerwową trafił zaś projekt \"Rozwój think-tanku Fundacji Edukacja do wartości\", na który fundacja Zycha chciała dostać 300 000 zł (z PROO 2021, priorytet 4). ","type":"unstyled","depth":0,"entityRanges":[{"key":88,"length":22,"offset":255}],"inlineStyleRanges":[{"style":"BOLD","length":10,"offset":241}]},{"key":"10fth","data":{},"text":"Wykładowcy z Narodowego Instytutu Wolności ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"5cj9s","data":{},"text":"To Fundacja Edukacja do Wartości jest założycielem uczelni Collegium Intermarium, której uruchomienie ogłosili w ubiegłym tygodniu ludzie Ordo Iuris. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"9qb2l","data":{},"text":"Misją uczelni ma być \"edukacja oparta na klasycznych wartościach cywilizacji europejskiej: rzymskiej kulturze prawnej, greckiej filozofii i etyce chrześcijańskiej\". ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"25vqh","data":{},"text":"„Liczymy na to, że dzięki temu nowemu projektowi, który jest naturalnym etapem rozwoju Instytutu Ordo Iuris, to absolwenci Collegium Intermarium będą wkrótce kształtować politykę, prawo i tożsamość Europy Środkowej jako regionu ludzi świadomych, pozbawionych kompleksów wobec państw Zachodu i Wschodu oraz wykształconych na najwyższym światowym poziomie” - pisali w komunikacie rozesłanym do sympatyków Ordo Iuris założyciele szkoły. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"b9onm","data":{},"text":"Model jej działania ma być zbliżony do kształcenia w uczelniach Opus Dei - każdy student ma mieć własnego tutora, czyli opiekuna, który czuwa nad jego rozwojem. A rozwój polegać ma nie tylko na przygotowaniu studenta do zawodu, ale na jego wszechstronnej formacji. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":6,"offset":106},{"style":"BOLD","length":8,"offset":255}]},{"key":"5de7r","data":{},"text":"Uczelnia ogłosiła już, kto od jesieni będzie prowadził w niej zajęcia. Na liście przyszłych członków kadry znaleźli się m.in.:  ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"8093i","data":{},"text":"Michał Rulski - zastępca dyrektora Narodowego Instytutu Wolności, były wicedyrektor Departamentu Społeczeństwa Obywatelskiego w kancelarii premiera, ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":13,"offset":0},{"style":"BOLD","length":49,"offset":16}]},{"key":"11f3v","data":{},"text":"Piotr Mazurek - członek rady NIW reprezentujący przewodniczącego Komitetu ds. Pożytku Publicznego, czyli Piotra Glińskiego, sam jest wiceprzewodniczącym tego komitetu, a także sekretarzem stanu w kancelarii premiera i pełnomocnikiem rządu ds. polityki młodzieżowej; ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":13,"offset":0},{"style":"BOLD","length":16,"offset":16}]},{"key":"1gtgp","data":{},"text":"Bartłomiej Orzeł - kolejny członek rady NIW reprezentujący Glińskiego, ekonomista, dziennikarz, współzałożyciel portalu Jagiellonski24.pl, od września 2020 roku pełnomocnik rządu ds. programu „Czyste Powietrze” ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":16,"offset":0},{"style":"BOLD","length":16,"offset":27}]},{"key":"enkev","data":{},"text":"i Piotr Patkowski - członek rady NIW, reprezentujący Ministerstwo Finansów, wiceminister tego resortu i zarazem Główny Rzecznik Dyscypliny Finansów Publicznych. ","type":"unordered-list-item","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":15,"offset":2},{"style":"BOLD","length":8,"offset":28}]},{"key":"dol5a","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":89,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"duo8","data":{},"text":"\"Nie ma konfliktu interesów\" ","type":"header-two","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"3d1o7","data":{},"text":"Zapytaliśmy wymienioną wyżej czwórkę, czy to, że będą wykładowcami uczelni prowadzonej przez fundację, która otrzymuje i ubiega się o dotacje z NIW, a równocześnie zasiadają we władzach NIW, nie jest konfliktem interesów. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"fenrr","data":{},"text":"Wicedyrektor NIW, Michał Rulski odpisał: \"O konflikcie interesów nie można mówić, gdyż nie ma żadnej formalnej zależności czy współzależności pomiędzy moją osobą oraz piastowaną funkcją, a wspomnianą Fundacją\". ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"9ia3m","data":{},"text":"Podkreślił, że \"kluczem dla efektywnego funkcjonowania systemu szkolnictwa wyższego i nauki jest wolność nauczania, badań naukowych oraz autonomia uczelni”. A on \"w swojej działalności naukowej i dydaktycznej zawsze pamięta o odpowiedzialności za jakość i rzetelność prowadzonych badań oraz za wychowanie młodego pokolenia\". ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"45hjq","data":{},"text":"Bartłomiej Orzeł z rady NIW, w rozmowie z nami tłumaczy: „Collegium Intermarium chyba nie jest beneficjentem środków z NIW. Jeśli chodzi o Fundację do Wartości - nie wydaje mi się żeby był to konflikt interesów. Z prostego powodu: rada opiniuje ogólny kształt programów dotacyjnych czy regulaminów, jest organem doradczym, natomiast samej oceny wniosków dokonują już wyznaczone do tego osoby. Nie mam wpływu na ich oceny i decyzje”. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"3u3k7","data":{},"text":"Na to, że rada NIW nie ma wpływu na decyzje o dofinansowywaniu konkretnych projektów i że wybierają je specjalnie powoływani eksperci, wskazują w swoich odpowiedziach również Piotr Mazurek i Piotr Patkowski. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"845nb","data":{},"text":"Mazurek wyjaśnia też, że Collegium Intermarium zwróciło się do niego \"z propozycją współpracy w zakresie umiejscowienia treści związanych z organizacjami pozarządowymi w planowanym programie studiów\", a ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"e1ajo","data":{},"text":" on zawsze pozytywnie odpowiada \"na wszelkie propozycje działań umożliwiających pochwalenie się ogromnym dorobkiem rządu Prawa i Sprawiedliwości w zakresie wspierania rozwoju społeczeństwa obywatelskiego\". ","type":"blockquote","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"aqd8","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":90,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"4io1l","data":{},"text":"Odpowiedź Piotra Mazurka z KPRM: ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":32,"offset":0}]},{"key":"egeaj","data":{},"text":"\"W odpowiedzi na Pani pytania uprzejmie informuję, że uczelnia Collegium Intermarium zwróciła się do mnie z propozycją współpracy w zakresie umiejscowienia treści związanych z organizacjami pozarządowymi w planowanym programie studiów. Chodzi o współpracę merytoryczną, jak i bezpośrednie zaangażowanie w prowadzenie zajęć. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"e11rn","data":{},"text":"Osobiście zawsze pozytywnie odpowiadam na wszelkie propozycje działań umożliwiających pochwalenie się ogromnym dorobkiem rządu Prawa i Sprawiedliwości w zakresie wspierania rozwoju społeczeństwa obywatelskiego, jak i podzielenie się moimi osobistymi doświadczeniami w ponad 11-letniej działalności społecznej w trzecim sektorze. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"1c943","data":{},"text":"Chętnie dzielę się także, zwłaszcza z młodszymi słuchaczami, posiadaną wiedzą z zakresu nauk politycznych czy historycznych. Prowadziłem dziesiątki, jeśli nie setki, zajęć, spotkań, warsztatów czy seminariów i szkoleń dla najróżniejszych grup, osób, organizacji czy środowisk obywatelskich. Ostatnio np. w ramach zajęć korepetycyjnych z WOS i historii dla maturzystów w ramach akcji jednego z NGO-sów. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"37s4o","data":{},"text":"Jestem otwarty na współpracę ze wszelkimi organizacjami, instytucjami czy uczelniami wyższymi, które są zainteresowane moją wiedzą i doświadczeniem. W miarę możliwości czasowych staram się odpowiadać pozytywnie na wszelkie tego typu zaproszenia, zarówno jednorazowe, jak i cykliczne. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"6hgpe","data":{},"text":"Absolutnie nie jest uprawnione łączenie w/w współpracy z uczelnią Collegium Intermarium z jakimikolwiek konkursami dotacyjnymi Narodowego Instytutu Wolności. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"ao6nl","data":{},"text":"Zgodnie z powszechnie dostępnymi przepisami, które regulują ich przeprowadzanie, Rada NIW nie ma i nigdy nie miała żadnego wpływu na decyzje o dofinansowywaniu konkretnych projektów. Wnioski są oceniane przez zewnętrznych ekspertów – dwóch równolegle, a w razie rozbieżności w ocenie – także przez trzeciego. Listy rankingowe zatwierdza panel ekspertów losowo dobranych spośród wszystkich oceniających - osobno do każdego konkursu. Nigdy do grona ekspertów NIW nie należałem, ani nie aspirowałem. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"ebcd2","data":{},"text":"Warto także dodać, że z danych powszechnie dostępnych na stronie internetowej NIW-CRSO wynika, że fundacja, o którą Pani pyta, a która jest podmiotem odrębnym od uczelni Collegium Intermarium, złożyła do NIW dwa wnioski grantowe, które zostały do tej pory rozpatrzone: jeden uzyskał dofinansowanie, a drugi nie otrzymał dotacji. Niezależnie od przedstawionego stanu prawnego i braku wpływu członków Rady na te decyzje, trudno doszukiwać się jakiegokolwiek „preferowania” tego podmiotu przez NIW-CRSO. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"771b2","data":{},"text":"Z wyrazami szacunku ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"tgb1","data":{},"text":"Piotr Mazurek ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"bar2i","data":{},"text":"Sekretarz stanu ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"29vre","data":{},"text":"Pełnomocnik Rządu ds. Polityki Młodzieżowej ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"cfsje","data":{},"text":"Wiceprzewodniczący Komitetu ds. Pożytku Publicznego ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"ehit","data":{},"text":"Kancelaria Prezesa Rady Ministrów\" ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"1fu51","data":{},"text":"Odpowiedź wydziału prasowego ministerstwa finansów, udzielona w imieniu Piotra Patkowskiego: ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":92,"offset":0}]},{"key":"b0uth","data":{},"text":"Pani Redaktor, ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"92lu2","data":{},"text":"rada NIW nie ma wpływu na ocenę wniosków, których dokonują niezależni eksperci według określonych procedur. Minister Piotr Patkowski nie bierze udziału i nigdy nie brał udziału w ocenie takich wniosków. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"i8fo","data":{},"text":"Z poważaniem ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"df4ki","data":{},"text":"Wydział Prasowy ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"flbk0","data":{},"text":"Biuro Komunikacji i Promocji\"\n ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"7i4mr","data":{},"text":"  ","type":"atomic","depth":0,"entityRanges":[{"key":91,"length":1,"offset":0}],"inlineStyleRanges":[]},{"key":"fbbl3","data":{},"text":"Działacze organizacji pozarządowych, z którymi rozmawialiśmy, wskazują jednak na zagrożenia, wiążące się z tym, że w radzie NIW zasiada członek władz organizacji ubiegających się o dotacje (Tymoteusz Zych), kolejni trzej członkowie rady i wicedyrektor NIW będą wykładowcami zakładanej przez niego uczelni (Mazurek, Orzeł, Patkowski i Rulski), a drugi wicedyrektor NIW jest kolegą Zycha z Konfederacji Inicjatyw Pozarządowych RP. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"2992n","data":{},"text":"Przypominają, że to dyrekcja Instytutu sprawuje nadzór nad właściwą realizacją obecnych i przyszłych programów wsparcia społeczeństwa obywatelskiego (PROO i FIO). I to ona decyduje o zasadach konkursów NIW, a także powołuje ekspertów oceniających poszczególne wnioski i zatwierdza listę projektów do realizacji. Rada z kolei zatwierdza regulaminy konkursów o dofinansowanie. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"9oth2","data":{},"text":"\"Jeśli ktoś zasiada we władzach NIW, a równocześnie jest związany z organizacjami pozarządowymi, istnieje ryzyko, że będzie wpływał na taki kształt konkursów NIW albo taki dobór ekspertów oceniających wnioski, by pieniądze dostawały NGOsy o konkretnym profilu. Poza tym, liczna obecność we władzach NIW osób kojarzonych z konkretnymi organizacjami może psychologicznie wpływać na ekspertów\" - mówi wieloletnia szefowa znanego stowarzyszenia, które korzysta z publicznych dotacji. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"36skr","data":{},"text":"Tymoteusz Zych nie odpowiedział na nasze pytania dotyczące konfliktu interesów i działalności organizacji, w których działa oraz Collegium Intermarium. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"5l7th","data":{},"text":"Uczelnia zainauguruje swoją działalność 28 maja 2021, międzynarodową konferencją „Intermarium. Przestrzeń Wolności i Ładu”. Według publicznych zapowiedzi Zycha, wezmą w niej udział m.in. Piotr Mazurek z KRPM i rady NIW oraz Piotr Gliński, przewodniczący Komitetu ds. Pożytku Publicznego nadzorujący NIW. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"fa3ar","data":{},"text":"Edycja z 25 maja 2021 roku: ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":27,"offset":0}]},{"key":"35isp","data":{},"text":"Wymieniając w tekście blisko 30-krotnie nazwę Ordo Iuris, raz - w wyniku oczywistej omyłki pisarskiej - użyliśmy nazwy Opus Dei (pisząc, że Tymoteusz Zych, wraz ze znajomymi z OD - a nie, jak powinno być: z OI - utworzył Ośrodek im. Cegielskiego). Omyłkowo określiliśmy też Konfederację Inicjatyw Pozarządowych RP mianem \"fundacji\" - jest ona związkiem stowarzyszeń (wynikało to z opisu w tekście i dołączonego do tekstu wypisu z KRS). Oba błędy zostały poprawione. ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"67v2h","data":{},"text":"Sprostowanie ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":12,"offset":0}]},{"key":"e5jgf","data":{},"text":"\"Nieprawdą jest, że dr r.pr. Tymoteusz Zych zasiada we władzach Narodowego Instytutu Wolności ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"ohj3","data":{},"text":"dr r.pr. Tymoteusz Zych\" ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"1r9eb","data":{},"text":"Odpowiedź redakcji ","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[{"style":"BOLD","length":18,"offset":0}]},{"key":"4v0fm","data":{},"text":"Zgodnie z Prawem prasowym, odpowiedź redakcj zostanie opublikowana dzień po publikacji sprostowania.","type":"unstyled","depth":0,"entityRanges":[],"inlineStyleRanges":[]},{"key":"4vc3q","data":{},"text":" ","type":"atomic","depth":0,"entityRanges":[{"key
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /nodes/{nodeId} {
      allow read: if resource.data.type == "article" || resource.data.type == "person" || resource.data.type == "place";
      allow create: if request.auth != null && resource.data.revision_id == null;
    }

    match /notes/{noteId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.resource.data.userUid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    match /revisions/{revisionId} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    match /extractions/{extractionId} {
      allow read: if request.auth != null && request.auth.token.datascience == true;
      allow write: if false;
    }

    match /votes/{voteId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null 
          && voteId.matches('.*_' + request.auth.uid)
          && request.resource.data.userUid == request.auth.uid;
      }
    }
  }